---
// ─────────────────────────────────────────────────────────────
// ChatWidget — Asistente consultivo de Marcyan ("Marcy").
// Isla cliente: botón flotante + panel de chat. Habla con /api/chat
// (la API key vive en el servidor). Cuando el modelo lo decide, /api/chat
// devuelve { action:{type:'capture'} } y el widget muestra una CAPTURA
// INLINE mínima (nombre + email/teléfono) que postea a /api/contact (leads)
// o /api/handoff. La PII viaja SOLO del formulario a esos endpoints,
// NUNCA al modelo.
//
// REDISEÑO (solo capa visual/UX): avatar ilustrado "Marcy" (MarcyAvatar),
// pantalla de BIENVENIDA (avatar + temas + diagnóstico gratis), CONVERSACIÓN
// con burbujas, y en móvil el panel va a PANTALLA COMPLETA. La lógica y el
// blindaje del bot NO cambian (mismo contrato /api/chat, captura, handoff,
// invitesContact, stripMarkdown, focus-trap, VisualViewport).
//
// SEGURIDAD: el texto del modelo se limpia de markdown y se pinta con
// textContent (sin innerHTML); solo se "linkifican" tokens conocidos.
// La tarjeta de captura se construye con HTML ESTÁTICO (sin interpolar
// texto del modelo/usuario); los valores se asignan vía .value.
// ─────────────────────────────────────────────────────────────
import Icon from './ui/Icon.astro';
import MarcyAvatar from './chat/MarcyAvatar.astro';
import { nap } from '../i18n/content';

interface Props { lang?: 'es' | 'en'; }
const { lang = 'es' } = Astro.props;

const telHref = (p: string) => 'tel:' + p.replace(/[^\d+]/g, '');

// Canales directos (tarjeta "Mensaje directo") — derivados del NAP de Houston.
const waHref = `https://wa.me/${nap.houston.replace(/\D/g, '')}`;        // WhatsApp
const smsHref = `sms:${nap.houston.replace(/[^\d+]/g, '')}`;             // iMessage / SMS

const STR = {
  es: {
    open: 'Abrir el chat de ayuda',
    close: 'Cerrar el chat',
    title: 'Marcy',
    status: 'Responde al instante',
    greeting: '¡Hola! 👋 Soy Marcy, el asistente de Marcyan. Cuéntame de tu negocio o qué quieres lograr en línea y te oriento. Y si quieres, te preparamos una muestra gratis de tu sitio.',
    welcomeTitle: 'Hola, soy Marcy',
    welcomeSub: '¿Cómo prefieres contactarnos?',
    welcomeHint: 'Elige la opción que mejor se adapte a ti.',
    fabNudge: 'Respuesta en vivo',
    placeholder: 'Escribe tu mensaje…',
    send: 'Enviar mensaje',
    typing: 'Escribiendo…',
    error: 'No pude responder ahora. Cuéntanos tu proyecto en /formulario.',
    privacy: 'Asistente informativo. Tus mensajes se tratan con privacidad.',
    leaveData: 'Dejar mis datos',
    fullForm: 'formulario completo',
    // Captura inline
    capTitleSample: 'Te preparamos una muestra gratis',
    capTitleContact: 'Déjanos tus datos y te contactamos',
    capSub: 'Solo tu nombre y el mejor email o teléfono. Sin compromiso.',
    capName: 'Nombre',
    capEmail: 'Email',
    capPhone: 'Teléfono',
    capSend: 'Enviar',
    capSending: 'Enviando…',
    capDismiss: 'Ahora no',
    capConsentPre: 'Al enviar aceptas nuestra',
    capConsentLink: 'política de privacidad',
    capOk: '¡Gracias! Lo recibimos (folio %ID%). El equipo te contacta en menos de 24 horas. 🚀',
    capErr: 'No pudimos enviar tus datos. Intenta de nuevo o escríbenos en /formulario.',
    capRequired: 'Déjanos al menos un email o un teléfono.',
    human: 'Hablar con una persona',
    capTitleHuman: 'Te conecto con una persona',
    capSubHuman: 'Déjanos cómo contactarte y un asesor te escribe. (No es chat en vivo.)',
    capHandoffOk: 'Listo, le avisamos a una persona. Te contacta por email o WhatsApp pronto. 🙌',
    ctaFree: 'Diagnóstico gratis',
    ctaFreeMsg: 'Quiero un diagnóstico gratis de mi visibilidad en IA.',
    // Selector de canal (pantalla de bienvenida)
    optChatTitle: 'Chat con Marcy',
    optChatSub: 'Te guío y respondo en tiempo real.',
    optDirectTitle: 'Mensaje directo',
    optDirectSub: 'Habla con nosotros por tu canal favorito.',
    optFormTitle: 'Formulario de contacto',
    optFormSub: 'Cuéntanos sobre tu proyecto y te responderemos.',
    optDiagSub: 'Revisamos tu web, SEO o presencia online.',
  },
  en: {
    open: 'Open the help chat',
    close: 'Close the chat',
    title: 'Marcy',
    status: 'Replies instantly',
    greeting: 'Hi! 👋 I’m Marcy, Marcyan’s assistant. Tell me about your business or what you want to achieve online and I’ll guide you. And if you like, we’ll prepare a free sample of your site.',
    welcomeTitle: 'Hi, I’m Marcy',
    welcomeSub: 'How would you like to reach us?',
    welcomeHint: 'Pick the option that suits you best.',
    fabNudge: 'Live reply',
    placeholder: 'Type your message…',
    send: 'Send message',
    typing: 'Typing…',
    error: 'I couldn’t reply right now. Tell us about your project at /formulario.',
    privacy: 'Informational assistant. Your messages are handled privately.',
    leaveData: 'Leave my details',
    fullForm: 'full form',
    capTitleSample: 'We’ll prepare a free sample for you',
    capTitleContact: 'Leave your details and we’ll reach out',
    capSub: 'Just your name and the best email or phone. No strings attached.',
    capName: 'Name',
    capEmail: 'Email',
    capPhone: 'Phone',
    capSend: 'Send',
    capSending: 'Sending…',
    capDismiss: 'Not now',
    capConsentPre: 'By submitting you accept our',
    capConsentLink: 'privacy policy',
    capOk: 'Thank you! We got it (ref %ID%). The team will reach out within 24 hours. 🚀',
    capErr: 'We couldn’t send your details. Please try again or reach us at /formulario.',
    capRequired: 'Please leave at least an email or a phone number.',
    human: 'Talk to a person',
    capTitleHuman: 'I’ll connect you with a person',
    capSubHuman: 'Leave your contact and an advisor will reach out. (Not live chat.)',
    capHandoffOk: 'Done. We notified a person. They’ll reach out by email or WhatsApp soon. 🙌',
    ctaFree: 'Free diagnosis',
    ctaFreeMsg: 'I’d like a free diagnosis of my AI visibility.',
    optChatTitle: 'Chat with Marcy',
    optChatSub: 'I’ll guide you and reply in real time.',
    optDirectTitle: 'Direct message',
    optDirectSub: 'Reach us on your favorite channel.',
    optFormTitle: 'Contact form',
    optFormSub: 'Tell us about your project and we’ll reply.',
    optDiagSub: 'We’ll review your site, SEO, or online presence.',
  },
};

// Temas de la bienvenida (grid) + chips de respuesta rápida (conversación).
// Cada uno SIEMBRA un mensaje de usuario (mismo patrón que ya existía).
const TOPICS = {
  es: [
    { label: 'Diseño web', icon: 'lucide:layout-dashboard', msg: 'Cuéntame sobre el diseño web.' },
    { label: 'IA chatbot', icon: 'lucide:bot', msg: '¿Qué es la IA conversacional que ofrecen?' },
    { label: 'Precios', icon: 'lucide:tag', msg: '¿Cuáles son sus precios?' },
    { label: 'SEO para IA', icon: 'lucide:radar', msg: '¿Qué es el SEO para IA (AEO) y el diagnóstico?' },
  ],
  en: [
    { label: 'Web design', icon: 'lucide:layout-dashboard', msg: 'Tell me about your web design.' },
    { label: 'AI chatbot', icon: 'lucide:bot', msg: 'What is the AI assistant service?' },
    { label: 'Pricing', icon: 'lucide:tag', msg: 'What are your prices?' },
    { label: 'AI SEO', icon: 'lucide:radar', msg: 'What is AI SEO (AEO) and the free diagnosis?' },
  ],
};

const t = STR[lang];
const topics = TOPICS[lang];

// Tokens seguros que el cliente puede convertir en enlaces (nunca innerHTML del modelo).
const links = [
  { token: '/formulario', href: '/formulario' },
  { token: nap.email, href: 'mailto:' + nap.email },
  { token: nap.houston, href: telHref(nap.houston) },
  { token: nap.miami, href: telHref(nap.miami) },
];
const clientConfig = { lang, strings: t, links, referredBy: 'Asistente del sitio (chatbot)' };
---

<div class="mrc-chat" id="mrc-chat" data-mrc-root data-stage="welcome">
  <!-- Burbuja sutil de atención (aparece a los pocos segundos) -->
  <span class="mrc-nudge" data-mrc-nudge hidden aria-hidden="true">{t.fabNudge}</span>

  <!-- Botón flotante -->
  <button
    type="button"
    class="mrc-fab"
    data-mrc-fab
    aria-haspopup="dialog"
    aria-expanded="false"
    aria-controls="mrc-chat-panel"
    aria-label={t.open}
  >
    <span class="mrc-fab-ic mrc-fab-ic--open"><Icon name="lucide:message-circle" /></span>
    <span class="mrc-fab-ic mrc-fab-ic--close"><Icon name="lucide:x" /></span>
  </button>

  <!-- Panel -->
  <section
    id="mrc-chat-panel"
    class="mrc-panel"
    role="dialog"
    aria-modal="true"
    aria-label={t.title}
    tabindex="-1"
    hidden
  >
    <div class="mrc-fx" aria-hidden="true"></div>

    <header class="mrc-head">
      <span class="mrc-head-id">
        <span class="mrc-avatar"><MarcyAvatar variant="mini" defer /></span>
        <span class="mrc-head-tx">
          <b>{t.title}</b>
          <span class="mrc-status"><span class="mrc-live" aria-hidden="true"></span>{t.status}</span>
        </span>
      </span>
      <button type="button" class="mrc-human" data-mrc-human aria-label={t.human} title={t.human}>
        <Icon name="lucide:user-round" />
      </button>
      <button type="button" class="mrc-close" data-mrc-close aria-label={t.close}>
        <Icon name="lucide:x" />
      </button>
    </header>

    <!-- Estado BIENVENIDA — selector de canal de contacto -->
    <div class="mrc-welcome" data-mrc-welcome>
      <span class="mrc-hero-avatar"><MarcyAvatar variant="hero" defer /></span>
      <h2 class="mrc-welcome-title">{t.welcomeTitle}</h2>
      <p class="mrc-welcome-sub">{t.welcomeSub}</p>
      <p class="mrc-welcome-hint">{t.welcomeHint}</p>

      <div class="mrc-options">
        <!-- Chat con Marcy → entra a la conversación -->
        <button type="button" class="mrc-opt" data-act="chat">
          <span class="mrc-opt-ic"><Icon name="lucide:message-circle" /></span>
          <span class="mrc-opt-tx">
            <span class="mrc-opt-title">{t.optChatTitle}</span>
            <span class="mrc-opt-sub">{t.optChatSub}</span>
          </span>
          <span class="mrc-opt-arrow" aria-hidden="true"><Icon name="lucide:arrow-right" /></span>
        </button>

        <!-- Mensaje directo → canales externos (no es botón: contiene enlaces) -->
        <div class="mrc-opt mrc-opt--channels">
          <span class="mrc-opt-ic"><Icon name="lucide:send" /></span>
          <span class="mrc-opt-tx">
            <span class="mrc-opt-title">{t.optDirectTitle}</span>
            <span class="mrc-opt-sub">{t.optDirectSub}</span>
            <span class="mrc-opt-pills">
              <a class="mrc-pill" href={waHref} target="_blank" rel="noopener noreferrer">
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M19.05 4.91A9.82 9.82 0 0 0 12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38c1.43.78 3.04 1.19 4.66 1.19h.004c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01zM12.04 20.15h-.003a8.2 8.2 0 0 1-4.19-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.18 8.18 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.25-8.23 2.2 0 4.27.86 5.82 2.42a8.16 8.16 0 0 1 2.41 5.82c0 4.54-3.7 8.23-8.24 8.23zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.39.11-.51.11-.11.25-.29.37-.43.12-.14.16-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.43-.14 0-.31-.01-.48-.01a.92.92 0 0 0-.66.31c-.23.25-.87.85-.87 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28z"/></svg>
                WhatsApp
              </a>
              <a class="mrc-pill" href={smsHref}>
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12 3C6.9 3 2.75 6.36 2.75 10.5c0 2.36 1.36 4.47 3.48 5.85-.17 1.2-.77 2.35-1.69 3.26a.5.5 0 0 0 .44.85c1.9-.32 3.39-1.03 4.49-1.79.78.2 1.6.31 2.53.31 5.1 0 9.25-3.36 9.25-7.5S17.1 3 12 3z"/></svg>
                iMessage
              </a>
            </span>
          </span>
        </div>

        <!-- Formulario de contacto → captura inline -->
        <button type="button" class="mrc-opt" data-act="form">
          <span class="mrc-opt-ic"><Icon name="lucide:file-pen-line" /></span>
          <span class="mrc-opt-tx">
            <span class="mrc-opt-title">{t.optFormTitle}</span>
            <span class="mrc-opt-sub">{t.optFormSub}</span>
          </span>
          <span class="mrc-opt-arrow" aria-hidden="true"><Icon name="lucide:arrow-right" /></span>
        </button>

        <!-- Diagnóstico gratis (acción dominante) → siembra el mensaje de diagnóstico -->
        <button type="button" class="mrc-opt mrc-opt--gold" data-msg={t.ctaFreeMsg}>
          <span class="mrc-opt-ic"><Icon name="lucide:sparkles" /></span>
          <span class="mrc-opt-tx">
            <span class="mrc-opt-title">{t.ctaFree}</span>
            <span class="mrc-opt-sub">{t.optDiagSub}</span>
          </span>
          <span class="mrc-opt-arrow" aria-hidden="true"><Icon name="lucide:arrow-right" /></span>
        </button>
      </div>
    </div>

    <!-- Estado CONVERSACIÓN -->
    <div class="mrc-log" data-mrc-log role="log" aria-live="polite" aria-atomic="false"></div>

    <div class="mrc-chips" data-mrc-chips>
      {topics.map((c) => (
        <button type="button" class="mrc-chip" data-msg={c.msg}>{c.label}</button>
      ))}
    </div>

    <form class="mrc-form" data-mrc-form>
      <label class="mrc-sr" for="mrc-chat-input">{t.placeholder}</label>
      <textarea
        id="mrc-chat-input"
        class="mrc-input"
        data-mrc-input
        rows="1"
        placeholder={t.placeholder}
        autocomplete="off"
        maxlength="2000"
      ></textarea>
      <button type="button" class="mrc-send" data-mrc-send aria-label={t.send}>
        <Icon name="lucide:arrow-up" />
      </button>
    </form>

    <p class="mrc-foot">
      <span class="mrc-foot-note"><Icon name="lucide:shield-check" />{t.privacy}</span>
      <span class="mrc-foot-actions">
        <button type="button" class="mrc-foot-link" data-mrc-leave>{t.leaveData}</button>
      </span>
    </p>
  </section>

  <script type="application/json" data-mrc-config set:html={JSON.stringify(clientConfig)} />
</div>

<style>
  .mrc-chat { position: fixed; right: clamp(12px, 3vw, 24px); bottom: clamp(12px, 3vw, 24px); z-index: var(--z-drawer); transition: bottom var(--duration-base) var(--ease-out-expo); }
  /* móvil: cuando la barra CTA inferior "Iniciar Proyecto" está visible, el FAB sube por
     encima de ella (altura de la barra + holgura) para que no coincidan. */
  @media (max-width: 767px) {
    :global(body.has-ctabar) .mrc-chat { bottom: calc(var(--tap-min) + var(--space-3) * 3 + env(safe-area-inset-bottom)); }
  }

  /* ── Burbuja de atención ────────────────────────────────── */
  .mrc-nudge {
    position: absolute; right: 66px; bottom: 14px; white-space: nowrap;
    padding: 8px var(--space-3); border-radius: var(--radius-pill);
    background: var(--bg-elevated); border: 1px solid var(--accent-teal-line); color: var(--fg-primary);
    font-family: var(--font-body); font-size: var(--text-xs);
    box-shadow: var(--shadow-card);
    animation: mrc-nudge-in var(--duration-slow) var(--ease-out-expo);
  }
  .mrc-nudge[hidden] { display: none; }
  .mrc-nudge::after {
    content: ''; position: absolute; right: -5px; top: 50%; transform: translateY(-50%) rotate(45deg);
    width: 10px; height: 10px; background: var(--bg-elevated);
    border-right: 1px solid var(--accent-teal-line); border-top: 1px solid var(--accent-teal-line);
  }
  @keyframes mrc-nudge-in { from { opacity: 0; transform: translateX(8px); } to { opacity: 1; transform: none; } }

  /* ── Botón flotante (icono de mensaje, verde/teal — alta jerarquía) ── */
  .mrc-fab {
    position: relative; display: inline-flex; align-items: center; justify-content: center;
    width: 58px; height: 58px; min-width: var(--tap-min); min-height: var(--tap-min);
    border-radius: 50%; cursor: pointer;
    background: var(--accent-teal); color: var(--fg-inverse); border: none;
    box-shadow: var(--shadow-teal), 0 6px 24px rgba(0, 0, 0, 0.5);
    transition: transform var(--duration-base) var(--ease-out-expo), box-shadow var(--duration-base) var(--ease-out-expo);
  }
  .mrc-fab:hover { transform: translateY(-2px) scale(1.04); box-shadow: var(--shadow-teal), 0 10px 32px rgba(0, 0, 0, 0.6); }
  .mrc-fab:focus-visible { outline: 2px solid var(--accent-teal); outline-offset: 3px; }
  .mrc-fab-ic { position: absolute; display: inline-flex; align-items: center; justify-content: center; transition: opacity var(--duration-base), transform var(--duration-base); }
  .mrc-fab-ic :global(svg) { width: 24px; height: 24px; stroke-width: 2; }
  .mrc-fab-ic--close { opacity: 0; transform: rotate(-90deg) scale(0.6); }
  .mrc-chat[data-open] .mrc-fab-ic--open { opacity: 0; transform: rotate(90deg) scale(0.6); }
  .mrc-chat[data-open] .mrc-fab-ic--close { opacity: 1; transform: none; }

  /* ── Panel ──────────────────────────────────────────────── */
  .mrc-panel[hidden] { display: none; }
  .mrc-panel {
    position: absolute; right: 0; bottom: calc(58px + var(--space-3));
    display: flex; flex-direction: column;
    width: min(384px, calc(100vw - 24px)); height: min(760px, calc(100vh - 88px));
    background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg);
    box-shadow: var(--shadow-modal); overflow: hidden;
    animation: mrc-in var(--duration-base) var(--ease-out-expo);
    transform-origin: bottom right;
  }
  @keyframes mrc-in { from { opacity: 0; transform: translateY(12px) scale(0.98); } to { opacity: 1; transform: none; } }

  /* fondo ambiental (glow oro/teal + estrellas sutiles) */
  .mrc-fx { position: absolute; inset: 0; z-index: 0; pointer-events: none;
    background:
      radial-gradient(150px 130px at 90% 4%, var(--accent-gold-glow), transparent 70%),
      radial-gradient(190px 170px at 4% 98%, rgba(var(--accent-teal-rgb), 0.10), transparent 72%);
  }
  .mrc-fx::after {
    content: ''; position: absolute; inset: 0; opacity: 0.5;
    background-image:
      radial-gradient(1.5px 1.5px at 18% 22%, rgba(var(--star-rgb), 0.6), transparent),
      radial-gradient(1px 1px at 72% 14%, rgba(var(--star-rgb), 0.5), transparent),
      radial-gradient(1px 1px at 40% 58%, rgba(var(--star-rgb), 0.4), transparent),
      radial-gradient(1.5px 1.5px at 86% 72%, rgba(var(--star-rgb), 0.5), transparent),
      radial-gradient(1px 1px at 26% 84%, rgba(var(--star-rgb), 0.45), transparent),
      radial-gradient(1px 1px at 60% 36%, rgba(var(--star-rgb), 0.4), transparent);
  }
  /* contenido por encima del fondo */
  .mrc-head, .mrc-welcome, .mrc-log, .mrc-chips, .mrc-form, .mrc-foot { position: relative; z-index: 1; }

  .mrc-head {
    display: flex; align-items: center; gap: var(--space-3);
    padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, var(--accent-teal-dim), transparent);
  }
  .mrc-head-id { display: flex; align-items: center; gap: var(--space-3); flex: 1; min-width: 0; }
  .mrc-avatar {
    flex: 0 0 auto; display: grid; place-items: center; width: 38px; height: 38px;
    background: radial-gradient(circle, var(--accent-teal-dim), transparent 70%);
  }
  .mrc-avatar :global(.marcy img) { width: 38px; height: 38px; }
  .mrc-head-tx { display: flex; flex-direction: column; line-height: 1.25; min-width: 0; }
  .mrc-head-tx b { font-family: var(--font-display); font-size: var(--text-md); font-weight: 600; color: var(--fg-primary); }
  .mrc-status { display: inline-flex; align-items: center; gap: var(--space-2); font-size: var(--text-xs); color: var(--fg-secondary); }
  .mrc-live { width: 6px; height: 6px; border-radius: 50%; background: var(--accent-teal); box-shadow: 0 0 0 0 var(--accent-teal); animation: mrc-pulse 2s ease-out infinite; }
  @keyframes mrc-pulse { 0% { box-shadow: 0 0 0 0 var(--accent-teal-line); } 70% { box-shadow: 0 0 0 6px transparent; } 100% { box-shadow: 0 0 0 0 transparent; } }
  .mrc-close, .mrc-human {
    flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center;
    width: var(--tap-min); height: var(--tap-min); border-radius: var(--radius-md);
    background: transparent; border: none; cursor: pointer;
    transition: color var(--duration-fast), background var(--duration-fast);
  }
  .mrc-close { color: var(--fg-secondary); }
  .mrc-close:hover { color: var(--fg-primary); background: var(--bg-elevated); }
  .mrc-human { color: var(--accent-gold); }
  .mrc-human:hover { background: var(--accent-gold-dim); }
  .mrc-close:focus-visible, .mrc-human:focus-visible { outline: 2px solid var(--accent-teal); outline-offset: 2px; }
  .mrc-human :global(svg), .mrc-close :global(svg) { width: 18px; height: 18px; }

  /* ── Estado BIENVENIDA ──────────────────────────────────── */
  .mrc-welcome {
    flex: 1; min-height: 0; overflow-y: auto; overscroll-behavior: contain;
    scrollbar-width: thin; scrollbar-color: var(--accent-teal-line) transparent;
    display: flex; flex-direction: column; align-items: center; text-align: center;
    gap: var(--space-2); padding: var(--space-3) var(--space-4);
  }
  .mrc-hero-avatar {
    margin-top: 0;
    filter: drop-shadow(0 10px 22px rgba(var(--accent-teal-rgb), 0.20));
  }
  .mrc-hero-avatar :global(.marcy img) { height: 76px; width: auto; max-width: none; }
  .mrc-welcome-title { font-family: var(--font-display); font-size: var(--text-xl); font-weight: 600; color: var(--fg-primary); letter-spacing: var(--tracking-tight); }
  .mrc-welcome-sub { font-size: var(--text-sm); color: var(--fg-secondary); margin-top: calc(-1 * var(--space-1)); }
  .mrc-welcome-hint { font-size: var(--text-xs); color: var(--fg-subtle); }

  /* Lista de canales (tarjetas) */
  .mrc-options {
    width: 100%; max-width: 360px; margin-top: var(--space-2);
    display: flex; flex-direction: column; gap: var(--space-2);
  }
  .mrc-opt {
    width: 100%; display: flex; align-items: center; gap: var(--space-3);
    padding: 10px var(--space-4); border-radius: var(--radius-lg); min-height: 52px;
    background: var(--bg-elevated); border: 1px solid var(--border); text-align: left; font-family: var(--font-body);
    transition: border-color var(--duration-fast), background var(--duration-fast), transform var(--duration-fast), box-shadow var(--duration-fast);
  }
  button.mrc-opt { cursor: pointer; color: var(--fg-primary); }
  button.mrc-opt:hover { border-color: var(--accent-teal-line); background: var(--accent-teal-dim); transform: translateY(-1px); }
  button.mrc-opt:focus-visible { outline: 2px solid var(--accent-teal); outline-offset: 2px; }
  .mrc-opt-ic {
    flex: 0 0 auto; display: grid; place-items: center; width: 44px; height: 44px; border-radius: 50%;
    background: var(--accent-teal-dim); border: 1px solid var(--accent-teal-line); color: var(--accent-teal);
  }
  .mrc-opt-ic :global(svg) { width: 20px; height: 20px; }
  .mrc-opt-tx { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 2px; }
  .mrc-opt-title { font-family: var(--font-display); font-size: var(--text-md); font-weight: 600; color: var(--fg-primary); }
  .mrc-opt-sub { font-size: var(--text-xs); color: var(--fg-secondary); line-height: var(--leading-normal); overflow-wrap: anywhere; }
  .mrc-opt-arrow {
    flex: 0 0 auto; display: grid; place-items: center; width: 32px; height: 32px; border-radius: 50%;
    border: 1px solid var(--border); color: var(--accent-teal);
  }
  .mrc-opt-arrow :global(svg) { width: 16px; height: 16px; }

  /* "Mensaje directo": no es botón; lleva pills de canal */
  .mrc-opt--channels { cursor: default; }
  .mrc-opt-pills { display: flex; flex-wrap: nowrap; gap: var(--space-2); margin-top: var(--space-2); }
  .mrc-pill {
    flex: 1 1 0; min-width: 0; justify-content: center;
    display: inline-flex; align-items: center; gap: var(--space-2);
    padding: 7px var(--space-3); border-radius: var(--radius-md);
    background: var(--bg-card); border: 1px solid var(--accent-teal-line); color: var(--fg-primary);
    font-family: var(--font-body); font-size: var(--text-sm); font-weight: 500; text-decoration: none;
    transition: border-color var(--duration-fast), background var(--duration-fast);
  }
  .mrc-pill:hover { background: var(--accent-teal-dim); border-color: var(--accent-teal); }
  .mrc-pill:focus-visible { outline: 2px solid var(--accent-teal); outline-offset: 2px; }
  .mrc-pill svg { width: 16px; height: 16px; flex: 0 0 auto; fill: var(--accent-teal); }

  /* "Diagnóstico gratis": acción dominante en oro */
  .mrc-opt--gold { background: var(--accent-gold-dim); border-color: var(--accent-gold-line); }
  .mrc-opt--gold .mrc-opt-ic { background: var(--accent-gold-dim); border-color: var(--accent-gold-line); color: var(--accent-gold); }
  .mrc-opt--gold .mrc-opt-title { color: var(--accent-gold); }
  .mrc-opt--gold .mrc-opt-arrow { border-color: var(--accent-gold-line); color: var(--accent-gold); }
  button.mrc-opt--gold:hover { border-color: var(--accent-gold); background: var(--accent-gold-dim); box-shadow: var(--shadow-gold); }
  button.mrc-opt--gold:focus-visible { outline-color: var(--accent-gold); }

  /* ── Estado CONVERSACIÓN ────────────────────────────────── */
  .mrc-log {
    flex: 1; min-height: 0; display: flex; flex-direction: column; gap: var(--space-3);
    padding: var(--space-4); overflow-y: auto; overscroll-behavior: contain;
  }

  .mrc-chips { display: flex; flex-wrap: wrap; gap: var(--space-2); padding: 0 var(--space-4) var(--space-3); }
  .mrc-chip {
    font-size: var(--text-xs); font-family: var(--font-body);
    padding: 6px var(--space-3); border-radius: var(--radius-pill);
    background: var(--bg-elevated); border: 1px solid var(--border); color: var(--fg-secondary); cursor: pointer;
    transition: color var(--duration-fast), border-color var(--duration-fast), background var(--duration-fast);
  }
  .mrc-chip:hover { color: var(--accent-teal); border-color: var(--accent-teal-line); background: var(--accent-teal-dim); }
  .mrc-chip:focus-visible { outline: 2px solid var(--accent-teal); outline-offset: 2px; }

  /* Cambio de estado: bienvenida ↔ conversación */
  .mrc-chat[data-stage="welcome"] .mrc-log,
  .mrc-chat[data-stage="welcome"] .mrc-chips,
  .mrc-chat[data-stage="welcome"] .mrc-form,
  .mrc-chat[data-stage="welcome"] .mrc-head-id,
  .mrc-chat[data-stage="welcome"] .mrc-human { display: none; }
  .mrc-chat[data-stage="welcome"] .mrc-head { justify-content: flex-end; background: transparent; border-bottom-color: transparent; }
  .mrc-chat[data-stage="chat"] .mrc-welcome { display: none; }

  .mrc-form {
    display: flex; align-items: flex-end; gap: var(--space-2);
    padding: var(--space-3) var(--space-4); border-top: 1px solid var(--border); background: var(--bg-2);
  }
  .mrc-input {
    flex: 1; min-width: 0; resize: none; max-height: 120px;
    font-family: var(--font-body); font-size: var(--text-sm); line-height: var(--leading-normal);
    color: var(--fg-primary); background: var(--bg-card);
    border: 1px solid var(--border); border-radius: var(--radius-md);
    padding: 10px var(--space-3);
  }
  .mrc-input::placeholder { color: var(--fg-subtle); }
  .mrc-input:focus-visible { outline: none; border-color: var(--accent-teal-line); box-shadow: 0 0 0 2px var(--accent-teal-dim); }
  /* iOS hace auto-zoom al enfocar un input con font-size < 16px y descuadra el
     panel fijo en móvil. En táctil subimos el campo a 16px para evitarlo
     (en desktop se queda compacto). */
  @media (pointer: coarse), (--lt-sm) { .mrc-input { font-size: var(--text-base); } }
  .mrc-send {
    flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center;
    width: var(--tap-min); height: var(--tap-min); border-radius: var(--radius-md);
    background: var(--accent-teal); color: var(--fg-inverse); border: none; cursor: pointer;
    transition: opacity var(--duration-fast), transform var(--duration-fast);
  }
  .mrc-send:hover { transform: translateY(-1px); }
  .mrc-send:focus-visible { outline: 2px solid var(--accent-teal); outline-offset: 2px; }
  .mrc-send:disabled { opacity: 0.45; cursor: not-allowed; transform: none; }
  .mrc-send :global(svg) { width: 18px; height: 18px; stroke-width: 2; }

  .mrc-foot {
    display: flex; align-items: center; justify-content: space-between; gap: var(--space-2);
    padding: 0 var(--space-4) var(--space-3); font-size: var(--text-xs); color: var(--fg-subtle);
  }
  .mrc-foot-note { display: inline-flex; align-items: center; gap: var(--space-2); min-width: 0; }
  .mrc-foot-note :global(svg) { width: 14px; height: 14px; color: var(--accent-teal); flex: 0 0 auto; }
  .mrc-foot-link {
    background: transparent; border: none; cursor: pointer; padding: 2px 0;
    font-size: var(--text-xs); color: var(--fg-secondary); text-decoration: underline; font-family: var(--font-body);
  }
  .mrc-foot-link:hover { color: var(--accent-teal); }
  .mrc-foot-link:focus-visible { outline: 2px solid var(--accent-teal); outline-offset: 2px; }

  .mrc-sr { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0; }

  /* Móvil: PANTALLA COMPLETA (sensación de app nativa), CONSCIENTE DEL TECLADO.
     El JS expone --mrc-vvh (alto visible real), --mrc-vvtop (desplazamiento del
     viewport visual) y --mrc-kb (alto del teclado, VisualViewport) para que el
     panel ocupe el área visible y el input quede SIEMPRE por encima del teclado. */
  @media (--lt-sm) {
    .mrc-panel {
      position: fixed; left: 0; right: 0; bottom: auto;
      top: var(--mrc-vvtop, 0px);
      width: auto; height: var(--mrc-vvh, 100dvh);
      border-radius: 0; border: none;
    }
    .mrc-chat[data-open] .mrc-fab, .mrc-chat[data-open] .mrc-nudge { display: none; }
    .mrc-options { max-width: 460px; }
    .mrc-hero-avatar :global(.marcy img) { height: clamp(92px, 24vw, 112px); }
  }

  @media (--motion-reduce) {
    .mrc-fab, .mrc-fab-ic, .mrc-panel, .mrc-live, .mrc-send, .mrc-nudge, .mrc-opt, .mrc-pill { animation: none !important; transition: none !important; }
  }
  @media print { .mrc-chat { display: none !important; } }
</style>

<style is:global>
  /* Elementos dinámicos (los crea el JS → sin atributo de scope de Astro) y el
     avatar Marcy (otro componente). Scopeados a mano bajo .mrc-chat. */
  .mrc-chat .mrc-bub {
    max-width: 88%; padding: var(--space-3) var(--space-4); border-radius: 14px;
    font-size: var(--text-sm); line-height: var(--leading-normal); word-wrap: break-word; white-space: pre-wrap;
  }
  .mrc-chat .mrc-ai { align-self: flex-start; background: var(--bg-elevated); border: 1px solid var(--border); color: var(--fg-primary); border-bottom-left-radius: 4px; }
  .mrc-chat .mrc-user { align-self: flex-end; background: var(--accent-teal); color: var(--fg-inverse); border-bottom-right-radius: 4px; }
  .mrc-chat .mrc-sys { align-self: center; background: transparent; border: 1px dashed var(--border); color: var(--fg-secondary); font-size: var(--text-xs); max-width: 100%; }
  .mrc-chat .mrc-link { color: var(--accent-teal); text-decoration: underline; }
  .mrc-chat .mrc-user .mrc-link { color: var(--fg-inverse); }

  .mrc-chat .mrc-typing { align-self: flex-start; display: inline-flex; gap: 4px; padding: var(--space-3) var(--space-4); background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 14px; border-bottom-left-radius: 4px; }
  .mrc-chat .mrc-typing span { width: 6px; height: 6px; border-radius: 50%; background: var(--fg-subtle); animation: mrc-typedot 1.2s infinite ease-in-out; }
  .mrc-chat .mrc-typing span:nth-child(2) { animation-delay: 0.15s; }
  .mrc-chat .mrc-typing span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes mrc-typedot { 0%, 60%, 100% { transform: translateY(0); opacity: 0.4; } 30% { transform: translateY(-4px); opacity: 1; } }
  @media (prefers-reduced-motion: reduce) { .mrc-chat .mrc-typing span { animation: none; } }

  /* Avatar Marcy (imagen): el héroe flota suave; el glow ambiental (.mrc-fx)
     titila. Solo con el chat abierto y si el usuario no pidió reducir movimiento
     (imagen estática en reduced-motion). */
  @media (prefers-reduced-motion: no-preference) {
    .mrc-chat[data-open] .marcy--hero img { animation: mrc-float 4.5s ease-in-out infinite; }
    .mrc-chat[data-open] .mrc-fx::after { animation: mrc-twinkle 7s ease-in-out infinite; }
  }
  @keyframes mrc-float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-5px); } }
  @keyframes mrc-twinkle { 0%, 100% { opacity: 0.5; } 50% { opacity: 0.28; } }

  /* Tarjeta de captura inline (HTML estático, sin datos del modelo/usuario) */
  .mrc-chat .mrc-capture {
    align-self: stretch; background: var(--bg-elevated); border: 1px solid var(--accent-teal-line);
    border-radius: var(--radius-md); padding: var(--space-4); display: flex; flex-direction: column; gap: var(--space-3);
  }
  .mrc-chat .mrc-cap-title { font-family: var(--font-display); font-size: var(--text-sm); font-weight: 600; color: var(--fg-primary); }
  .mrc-chat .mrc-cap-sub { font-size: var(--text-xs); color: var(--fg-secondary); line-height: var(--leading-normal); }
  .mrc-chat .mrc-cap-row { display: flex; gap: var(--space-2); }
  .mrc-chat .mrc-cap-row > * { flex: 1; min-width: 0; }
  .mrc-chat .mrc-capture input {
    width: 100%; font-family: var(--font-body); font-size: var(--text-sm); color: var(--fg-primary);
    background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 9px var(--space-3);
  }
  .mrc-chat .mrc-capture input:focus-visible { outline: none; border-color: var(--accent-teal-line); box-shadow: 0 0 0 2px var(--accent-teal-dim); }
  /* iOS: evitar auto-zoom al enfocar (font-size >= 16px en táctil). */
  @media (pointer: coarse), (max-width: 479.98px) { .mrc-chat .mrc-capture input { font-size: var(--text-base); } }
  .mrc-chat .mrc-cap-hp { position: absolute !important; left: -9999px !important; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
  .mrc-chat .mrc-cap-consent { font-size: 10px; color: var(--fg-subtle); line-height: var(--leading-normal); }
  .mrc-chat .mrc-cap-consent a { color: var(--accent-teal); text-decoration: underline; }
  .mrc-chat .mrc-cap-actions { display: flex; gap: var(--space-2); align-items: center; }
  .mrc-chat .mrc-cap-send {
    flex: 1; padding: 10px var(--space-4); border: none; border-radius: var(--radius-md);
    background: var(--accent-teal); color: var(--fg-inverse); cursor: pointer; min-height: var(--tap-min);
    font-family: var(--font-display); font-size: var(--text-sm); font-weight: 600;
  }
  .mrc-chat .mrc-cap-send:disabled { opacity: 0.5; cursor: not-allowed; }
  .mrc-chat .mrc-cap-dismiss { background: transparent; border: none; color: var(--fg-secondary); cursor: pointer; font-size: var(--text-xs); text-decoration: underline; }
  .mrc-chat .mrc-cap-result { font-size: var(--text-sm); line-height: var(--leading-normal); }
  .mrc-chat .mrc-cap-result.ok { color: var(--accent-teal); }
  .mrc-chat .mrc-cap-result.err { color: var(--color-error); }
</style>

<script>
  import { stripMarkdown, invitesContact } from '../lib/chat-format.mjs';

  const root = document.getElementById('mrc-chat');
  const cfgEl = root && root.querySelector('[data-mrc-config]');
  if (root && cfgEl) {
    const cfg = JSON.parse(cfgEl.textContent || '{}');
    const T = cfg.strings || {};
    const LINKS = Array.isArray(cfg.links) ? cfg.links : [];
    const lang = cfg.lang === 'en' ? 'en' : 'es';
    const REFERRED_BY = cfg.referredBy || 'chatbot';

    const fab = root.querySelector('[data-mrc-fab]');
    const panel = document.getElementById('mrc-chat-panel');
    const closeBtn = root.querySelector('[data-mrc-close]');
    const log = root.querySelector('[data-mrc-log]');
    const form = root.querySelector('[data-mrc-form]');
    const input = root.querySelector('[data-mrc-input]');
    const sendBtn = root.querySelector('[data-mrc-send]');
    const chipRow = root.querySelector('[data-mrc-chips]');
    const welcomeEl = root.querySelector('[data-mrc-welcome]');
    const leaveBtn = root.querySelector('[data-mrc-leave]');
    const nudge = root.querySelector('[data-mrc-nudge]');

    const sid = (crypto && crypto.randomUUID)
      ? crypto.randomUUID()
      : String(Date.now()) + Math.random().toString(36).slice(2);

    let history = [];      // solo pares user/assistant completados (alternancia válida)
    let lastUserText = '';
    let busy = false;
    let opened = false;
    let started = false;   // ya pasó de bienvenida a conversación
    let captured = false;  // ya envió sus datos

    // Cambia de estado bienvenida → conversación; inyecta el saludo de Marcy
    // como primera burbuja (display-only, NO entra al historial del modelo).
    function setStage(s) { if (root) root.setAttribute('data-stage', s); }
    function ensureChat() {
      if (started) return;
      started = true;
      setStage('chat');
      appendBubble('ai', T.greeting || '');
      // El elemento activado (tema/CTA de bienvenida) se oculta al cambiar de
      // estado → mover el foco a un elemento estable DENTRO del diálogo para no
      // perder el focus-trap/ESC mientras /api/chat responde (el input está
      // deshabilitado por setBusy; el finally lo re-enfoca al terminar).
      if (opened && closeBtn) closeBtn.focus();
    }

    // ── Linkify SEGURO: solo tokens conocidos → nodos DOM ──
    function linkify(text) {
      const frag = document.createDocumentFragment();
      if (!LINKS.length) { frag.appendChild(document.createTextNode(text)); return frag; }
      const escaped = LINKS.map((l) => l.token.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'));
      const rx = new RegExp('(' + escaped.join('|') + ')', 'g');
      let last = 0; let m;
      while ((m = rx.exec(text)) !== null) {
        if (m.index > last) frag.appendChild(document.createTextNode(text.slice(last, m.index)));
        const obj = LINKS.find((l) => l.token === m[0]);
        const a = document.createElement('a');
        a.href = obj.href; a.textContent = m[0]; a.className = 'mrc-link';
        frag.appendChild(a);
        last = m.index + m[0].length;
      }
      if (last < text.length) frag.appendChild(document.createTextNode(text.slice(last)));
      return frag;
    }

    function appendBubble(role, text) {
      const b = document.createElement('div');
      b.className = 'mrc-bub mrc-' + role;
      if (role === 'ai') b.appendChild(linkify(stripMarkdown(text)));
      else b.textContent = text;
      log.appendChild(b);
      log.scrollTop = log.scrollHeight;
    }
    function showTyping() {
      const ty = document.createElement('div');
      ty.className = 'mrc-typing'; ty.setAttribute('data-mrc-typing', '');
      ty.setAttribute('aria-label', T.typing || 'Typing');
      ty.appendChild(document.createElement('span'));
      ty.appendChild(document.createElement('span'));
      ty.appendChild(document.createElement('span'));
      log.appendChild(ty); log.scrollTop = log.scrollHeight;
    }
    function hideTyping() { const ty = log.querySelector('[data-mrc-typing]'); if (ty) ty.remove(); }
    function setBusy(v) { busy = v; if (sendBtn) sendBtn.disabled = v; if (input) input.disabled = v; }

    async function send(textRaw) {
      const text = (textRaw || '').trim();
      if (!text || busy) return;
      lastUserText = text;
      setBusy(true);
      ensureChat();
      appendBubble('user', text);
      if (input) input.value = '';
      autoGrow();
      showTyping();

      const recent = history.slice(-18);
      const reqMessages = recent.concat([{ role: 'user', content: text }]);
      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: reqMessages, sessionId: sid, lang }),
        });
        let data = null; try { data = await res.json(); } catch (_) {}
        hideTyping();
        if (data && data.reply) {
          appendBubble('ai', data.reply);
          history = reqMessages.concat([{ role: 'assistant', content: data.reply }]);
          if (data.action && data.action.type === 'capture') {
            openCapture(data.action.variant === 'muestra_gratis' ? 'muestra_gratis' : 'contacto');
          } else if (!captured && invitesContact(data.reply)) {
            // El bot invitó a dejar datos pero no disparó la herramienta → abrimos
            // la captura igual, para que el formulario prometido SÍ aparezca.
            openCapture('contacto');
          }
        } else {
          appendBubble('sys', (data && data.error) || T.error);
        }
      } catch (_) {
        hideTyping();
        appendBubble('sys', T.error);
      } finally {
        setBusy(false);
        if (opened && input) input.focus();
      }
    }

    function autoGrow() {
      if (!input) return;
      input.style.height = 'auto';
      input.style.height = Math.min(input.scrollHeight, 120) + 'px';
    }

    // ── Captura inline (HTML estático; valores vía .value; PII solo → /api/contact|/api/handoff) ──
    function openCapture(variant) {
      ensureChat();
      if (captured) return;
      if (log.querySelector('[data-mrc-capture]')) { // ya hay una abierta → enfocar
        const n = log.querySelector('#mrc-c-name'); if (n) n.focus();
        return;
      }
      const title = variant === 'handoff' ? (T.capTitleHuman || T.capTitleContact)
        : variant === 'muestra_gratis' ? T.capTitleSample : T.capTitleContact;
      const card = document.createElement('div');
      card.className = 'mrc-capture';
      card.setAttribute('data-mrc-capture', '');
      // HTML estático (todas las cadenas son nuestras, no del modelo/usuario).
      card.innerHTML =
        '<div class="mrc-cap-title"></div>' +
        '<p class="mrc-cap-sub"></p>' +
        '<input id="mrc-c-name" type="text" autocomplete="name" maxlength="120" />' +
        '<div class="mrc-cap-row">' +
          '<input id="mrc-c-email" type="email" autocomplete="email" inputmode="email" maxlength="200" />' +
          '<input id="mrc-c-phone" type="tel" autocomplete="tel" inputmode="tel" maxlength="50" />' +
        '</div>' +
        '<input id="mrc-c-hp" class="mrc-cap-hp" type="text" tabindex="-1" autocomplete="off" aria-hidden="true" />' +
        '<p class="mrc-cap-consent"></p>' +
        '<div class="mrc-cap-actions">' +
          '<button type="button" class="mrc-cap-send" data-mrc-capsend></button>' +
          '<button type="button" class="mrc-cap-dismiss" data-mrc-capdismiss></button>' +
        '</div>' +
        '<p class="mrc-cap-result" data-mrc-capresult hidden></p>';
      // Rellenar textos por separado (textContent / placeholder → seguro).
      card.querySelector('.mrc-cap-title').textContent = title;
      card.querySelector('.mrc-cap-sub').textContent = variant === 'handoff' ? (T.capSubHuman || T.capSub) : T.capSub;
      card.querySelector('#mrc-c-name').placeholder = T.capName;
      card.querySelector('#mrc-c-email').placeholder = T.capEmail;
      card.querySelector('#mrc-c-phone').placeholder = T.capPhone;
      card.querySelector('[data-mrc-capsend]').textContent = T.capSend;
      card.querySelector('[data-mrc-capdismiss]').textContent = T.capDismiss;
      const consent = card.querySelector('.mrc-cap-consent');
      consent.appendChild(document.createTextNode((T.capConsentPre || '') + ' '));
      const cl = document.createElement('a'); cl.href = '/privacidad'; cl.textContent = T.capConsentLink || 'privacidad';
      consent.appendChild(cl); consent.appendChild(document.createTextNode('.'));

      log.appendChild(card);
      log.scrollTop = log.scrollHeight;

      const need = (lastUserText || '').slice(0, 1000);
      card.querySelector('[data-mrc-capdismiss]').addEventListener('click', () => card.remove());
      card.querySelector('[data-mrc-capsend]').addEventListener('click', () => submitCapture(card, variant, need));
      const nameEl = card.querySelector('#mrc-c-name'); if (nameEl) nameEl.focus();
    }

    async function submitCapture(card, variant, need) {
      const get = (id) => { const el = card.querySelector(id); return el ? el.value.trim() : ''; };
      const email = get('#mrc-c-email');
      const phone = get('#mrc-c-phone');
      const result = card.querySelector('[data-mrc-capresult]');
      const sendB = card.querySelector('[data-mrc-capsend]');
      if (!email && !phone) {
        if (result) { result.hidden = false; result.className = 'mrc-cap-result err'; result.textContent = T.capRequired; }
        return;
      }
      // Handoff: pedir hablar con una persona → /api/handoff (no crea lead; avisa al fundador).
      if (variant === 'handoff') {
        if (sendB) { sendB.disabled = true; sendB.textContent = T.capSending; }
        if (result) result.hidden = true;
        try {
          const res = await fetch('/api/handoff', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: get('#mrc-c-name'), contact: email || phone, message: need, lang, website_hp: get('#mrc-c-hp') }),
          });
          let data = null; try { data = await res.json(); } catch (_) {}
          if (res.ok && data && data.ok) {
            captured = true;
            card.querySelectorAll('input, .mrc-cap-send, .mrc-cap-dismiss').forEach((el) => { el.disabled = true; });
            card.querySelectorAll('input, .mrc-cap-row, .mrc-cap-actions, .mrc-cap-consent').forEach((el) => { el.style.display = 'none'; });
            if (result) { result.hidden = false; result.className = 'mrc-cap-result ok'; result.textContent = T.capHandoffOk || T.capOk; }
          } else { throw new Error('bad response'); }
        } catch (_) {
          if (sendB) { sendB.disabled = false; sendB.textContent = T.capSend; }
          if (result) { result.hidden = false; result.className = 'mrc-cap-result err'; result.textContent = T.capErr; }
        }
        return;
      }

      const note = variant === 'muestra_gratis' ? 'Solicitó una muestra gratis vía el asistente del sitio.' : 'Pidió que lo contacten vía el asistente del sitio.';
      const body = {
        source: 'chat',
        owner_name: get('#mrc-c-name'),
        email,
        phone,
        main_objective: need,
        additional_notes: note + (need ? ' Mensaje: ' + need : ''),
        referred_by: REFERRED_BY,
        website_hp: get('#mrc-c-hp'),
      };
      if (sendB) { sendB.disabled = true; sendB.textContent = T.capSending; }
      if (result) result.hidden = true;
      try {
        const res = await fetch('/api/contact', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
        });
        let data = null; try { data = await res.json(); } catch (_) {}
        if (res.ok && data && data.ok) {
          captured = true;
          card.querySelectorAll('input, .mrc-cap-send, .mrc-cap-dismiss').forEach((el) => { el.disabled = true; });
          card.querySelectorAll('input, .mrc-cap-row, .mrc-cap-actions, .mrc-cap-consent').forEach((el) => { el.style.display = 'none'; });
          if (result) { result.hidden = false; result.className = 'mrc-cap-result ok'; result.textContent = (T.capOk || 'OK').replace('%ID%', data.refId || data.projectId || '—'); }
        } else { throw new Error('bad response'); }
      } catch (_) {
        if (sendB) { sendB.disabled = false; sendB.textContent = T.capSend; }
        if (result) { result.hidden = false; result.className = 'mrc-cap-result err'; result.textContent = T.capErr; }
      }
    }

    // ── Teclado móvil: ajusta el panel al área visible (VisualViewport) ──
    // Sin esto, al abrir el teclado el área visible se encoge pero el panel
    // fijo no, y se pierde el header/los mensajes. Exponemos --mrc-kb (alto del
    // teclado), --mrc-vvh (alto visible real) y --mrc-vvtop (desplazamiento del
    // viewport visual) que el CSS de pantalla completa usa.
    const vv = window.visualViewport;
    function syncViewport() {
      if (!vv || !root) return;
      const kb = Math.max(0, Math.round(window.innerHeight - vv.height - vv.offsetTop));
      root.style.setProperty('--mrc-kb', kb + 'px');
      root.style.setProperty('--mrc-vvh', Math.round(vv.height) + 'px');
      root.style.setProperty('--mrc-vvtop', Math.round(vv.offsetTop) + 'px');
      if (opened && log) log.scrollTop = log.scrollHeight;
    }
    if (vv) {
      vv.addEventListener('resize', syncViewport);
      vv.addEventListener('scroll', syncViewport);
    }

    // El asset grande del avatar (héroe) está diferido (data-src) para no
    // descargarlo en el render inicial del sitio. Se activa al abrir el chat.
    let deferredLoaded = false;
    function loadDeferredAssets() {
      if (deferredLoaded) return;
      deferredLoaded = true;
      root.querySelectorAll('[data-mrc-defer]').forEach((img) => {
        const pic = img.closest('picture');
        if (pic) pic.querySelectorAll('source[data-srcset]').forEach((s) => { s.srcset = s.getAttribute('data-srcset'); });
        const ds = img.getAttribute('data-src');
        if (ds) img.src = ds;
        img.removeAttribute('data-mrc-defer');
      });
    }

    // ── Abrir / cerrar panel ──
    function openPanel() {
      loadDeferredAssets();
      panel.hidden = false;
      root.setAttribute('data-open', '');
      fab.setAttribute('aria-expanded', 'true');
      opened = true;
      if (nudge) nudge.hidden = true;
      syncViewport();
      requestAnimationFrame(() => {
        // En bienvenida NO enfocamos el input (en móvil abriría el teclado);
        // enfocamos la primera tarjeta de canal. En conversación, el input.
        if (root.getAttribute('data-stage') === 'chat' && input) { input.focus(); return; }
        const first = panel.querySelector('[data-mrc-welcome] button, [data-mrc-welcome] a[href]');
        (first || closeBtn || panel).focus();
      });
    }
    function closePanel() {
      panel.hidden = true;
      root.removeAttribute('data-open');
      fab.setAttribute('aria-expanded', 'false');
      opened = false;
      if (input) input.blur();         // cierra el teclado
      root.style.setProperty('--mrc-kb', '0px');
      root.style.setProperty('--mrc-vvtop', '0px');
      fab.focus();
    }
    function toggle() { (opened ? closePanel : openPanel)(); }

    // ── Eventos ──
    fab.addEventListener('click', toggle);
    if (closeBtn) closeBtn.addEventListener('click', closePanel);
    const humanBtn = root.querySelector('[data-mrc-human]');
    if (humanBtn) humanBtn.addEventListener('click', () => openCapture('handoff'));
    if (form) form.addEventListener('submit', (e) => { e.preventDefault(); send(input && input.value); });
    if (sendBtn) sendBtn.addEventListener('click', () => send(input && input.value));
    if (input) {
      input.addEventListener('input', autoGrow);
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(input.value); }
      });
    }
    // Chips de respuesta rápida (conversación): SIEMBRAN un mensaje de usuario.
    function seedFrom(container) {
      if (!container) return;
      container.addEventListener('click', (e) => {
        const btn = e.target && e.target.closest ? e.target.closest('[data-msg]') : null;
        if (btn) send(btn.getAttribute('data-msg'));
      });
    }
    seedFrom(chipRow);
    // Selector de canal (bienvenida): cada tarjeta enruta a su acción. Los enlaces
    // de canal (WhatsApp/iMessage) son <a href> nativos → no necesitan JS aquí.
    if (welcomeEl) welcomeEl.addEventListener('click', (e) => {
      const el = e.target && e.target.closest ? e.target.closest('[data-act], [data-msg]') : null;
      if (!el) return;
      const act = el.getAttribute('data-act');
      if (act === 'chat') { ensureChat(); if (input) input.focus(); return; }
      if (act === 'form') { openCapture('contacto'); return; }
      const msg = el.getAttribute('data-msg');
      if (msg) send(msg);
    });
    if (leaveBtn) leaveBtn.addEventListener('click', () => { if (!opened) openPanel(); openCapture('contacto'); });

    // Burbuja de atención: una vez por sesión, a los pocos segundos de cargar.
    try {
      if (nudge && !sessionStorage.getItem('mrcNudge')) {
        setTimeout(() => {
          if (!opened && nudge) {
            nudge.hidden = false;
            try { sessionStorage.setItem('mrcNudge', '1'); } catch (_) {}
            setTimeout(() => { if (nudge && !opened) nudge.hidden = true; }, 9000);
          }
        }, 3500);
      }
    } catch (_) {}

    // Al enfocar un campo: reajusta al teclado y, si está dentro del log (campos
    // de la captura), lo deja a la vista por encima del teclado.
    panel.addEventListener('focusin', () => {
      syncViewport();
      setTimeout(() => {
        syncViewport();
        const a = document.activeElement;
        if (a && a.scrollIntoView && log && log.contains(a)) a.scrollIntoView({ block: 'center' });
      }, 280);
    });

    // ESC + focus-trap dentro del panel
    panel.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { e.preventDefault(); closePanel(); return; }
      if (e.key !== 'Tab') return;
      const nodes = panel.querySelectorAll('button, a[href], textarea, input, [tabindex]:not([tabindex="-1"])');
      const list = Array.prototype.filter.call(nodes, (el) => !el.disabled && el.offsetParent !== null);
      if (!list.length) return;
      const first = list[0]; const lastEl = list[list.length - 1];
      if (e.shiftKey && document.activeElement === first) { e.preventDefault(); lastEl.focus(); }
      else if (!e.shiftKey && document.activeElement === lastEl) { e.preventDefault(); first.focus(); }
    });
  }
</script>
