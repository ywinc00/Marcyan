---
// ─────────────────────────────────────────────────────────────
// ChatWidget — Asistente de Marcyan (v0, informativo y blindado).
// Isla cliente: botón flotante + panel. Habla SOLO con /api/chat
// (la API key vive en el servidor; el widget jamás la ve).
// Bilingüe ES/EN (según `lang`), a11y (foco, aria, teclado, 44px),
// tokens del DS v2 (acento teal, igual que la sección IA), y respeta
// prefers-reduced-motion. Montado site-wide desde Layout.astro.
//
// SEGURIDAD del lado cliente: el texto del modelo se pinta con
// textContent (sin innerHTML), y solo se "linkifican" tokens conocidos
// y seguros (/formulario, email y teléfonos) construyendo nodos DOM.
// ─────────────────────────────────────────────────────────────
import Icon from './ui/Icon.astro';
import { nap } from '../i18n/content';

interface Props { lang?: 'es' | 'en'; }
const { lang = 'es' } = Astro.props;

const telHref = (p: string) => 'tel:' + p.replace(/[^\d+]/g, '');

const STR = {
  es: {
    open: 'Abrir el chat de ayuda',
    close: 'Cerrar el chat',
    title: 'Asistente Marcyan',
    status: 'Responde al instante',
    greeting: '¡Hola! 👋 Soy el asistente de Marcyan Studio. Pregúntame por precios, servicios o cómo empezar tu proyecto.',
    placeholder: 'Escribe tu mensaje…',
    send: 'Enviar mensaje',
    typing: 'Escribiendo…',
    error: 'No pude responder ahora. Cuéntanos tu proyecto en /formulario.',
    privacy: 'Asistente informativo. No guardamos tus mensajes.',
  },
  en: {
    open: 'Open the help chat',
    close: 'Close the chat',
    title: 'Marcyan Assistant',
    status: 'Replies instantly',
    greeting: 'Hi! 👋 I’m Marcyan Studio’s assistant. Ask me about pricing, services, or how to start your project.',
    placeholder: 'Type your message…',
    send: 'Send message',
    typing: 'Typing…',
    error: 'I couldn’t reply right now. Tell us about your project at /formulario.',
    privacy: 'Informational assistant. We don’t store your messages.',
  },
};
const CHIPS = {
  es: [
    { label: 'Precios', msg: '¿Cuáles son sus precios?' },
    { label: 'Diseño web', msg: 'Cuéntame sobre el diseño web.' },
    { label: 'IA conversacional', msg: '¿Qué es la IA conversacional que ofrecen?' },
    { label: 'Empezar', msg: '¿Cómo empiezo un proyecto con ustedes?' },
  ],
  en: [
    { label: 'Pricing', msg: 'What are your prices?' },
    { label: 'Web design', msg: 'Tell me about your web design.' },
    { label: 'AI assistant', msg: 'What is the AI assistant service?' },
    { label: 'Get started', msg: 'How do I start a project with you?' },
  ],
};

const t = STR[lang];
const chips = CHIPS[lang];

// Tokens seguros que el cliente puede convertir en enlaces (nunca innerHTML del modelo).
const links = [
  { token: '/formulario', href: '/formulario' },
  { token: nap.email, href: 'mailto:' + nap.email },
  { token: nap.houston, href: telHref(nap.houston) },
  { token: nap.miami, href: telHref(nap.miami) },
];
const clientConfig = { lang, strings: { typing: t.typing, error: t.error }, links };
---

<div class="mrc-chat" id="mrc-chat" data-mrc-root>
  <!-- Botón flotante -->
  <button
    type="button"
    class="mrc-fab"
    data-mrc-fab
    aria-haspopup="dialog"
    aria-expanded="false"
    aria-controls="mrc-chat-panel"
    aria-label={t.open}
  >
    <span class="mrc-fab-ic mrc-fab-ic--open"><Icon name="lucide:message-circle" /></span>
    <span class="mrc-fab-ic mrc-fab-ic--close"><Icon name="lucide:x" /></span>
  </button>

  <!-- Panel -->
  <section
    id="mrc-chat-panel"
    class="mrc-panel"
    role="dialog"
    aria-modal="true"
    aria-label={t.title}
    hidden
  >
    <header class="mrc-head">
      <span class="mrc-avatar"><Icon name="lucide:bot" /></span>
      <span class="mrc-head-tx">
        <b>{t.title}</b>
        <span class="mrc-status"><span class="mrc-live" aria-hidden="true"></span>{t.status}</span>
      </span>
      <button type="button" class="mrc-close" data-mrc-close aria-label={t.close}>
        <Icon name="lucide:x" />
      </button>
    </header>

    <div class="mrc-log" data-mrc-log role="log" aria-live="polite" aria-atomic="false">
      <div class="mrc-bub mrc-ai">{t.greeting}</div>
    </div>

    <div class="mrc-chips" data-mrc-chips>
      {chips.map((c) => (
        <button type="button" class="mrc-chip" data-msg={c.msg}>{c.label}</button>
      ))}
    </div>

    <form class="mrc-form" data-mrc-form>
      <label class="mrc-sr" for="mrc-chat-input">{t.placeholder}</label>
      <textarea
        id="mrc-chat-input"
        class="mrc-input"
        data-mrc-input
        rows="1"
        placeholder={t.placeholder}
        autocomplete="off"
        maxlength="2000"
      ></textarea>
      <button type="button" class="mrc-send" data-mrc-send aria-label={t.send}>
        <Icon name="lucide:arrow-up" />
      </button>
    </form>

    <p class="mrc-privacy">{t.privacy}</p>
  </section>

  <script type="application/json" data-mrc-config set:html={JSON.stringify(clientConfig)} />
</div>

<style>
  .mrc-chat { position: fixed; right: clamp(12px, 3vw, 24px); bottom: clamp(12px, 3vw, 24px); z-index: var(--z-drawer); }

  /* ── Botón flotante ─────────────────────────────────────── */
  .mrc-fab {
    position: relative; display: inline-flex; align-items: center; justify-content: center;
    width: 56px; height: 56px; min-width: var(--tap-min); min-height: var(--tap-min);
    border-radius: 50%; cursor: pointer;
    background: var(--accent-teal); color: var(--fg-inverse); border: none;
    box-shadow: var(--shadow-teal), 0 6px 24px rgba(0, 0, 0, 0.5);
    transition: transform var(--duration-base) var(--ease-out-expo), box-shadow var(--duration-base) var(--ease-out-expo);
  }
  .mrc-fab:hover { transform: translateY(-2px) scale(1.04); }
  .mrc-fab:focus-visible { outline: 2px solid var(--accent-teal); outline-offset: 3px; }
  .mrc-fab-ic { position: absolute; display: inline-flex; transition: opacity var(--duration-base), transform var(--duration-base); }
  .mrc-fab-ic :global(svg) { width: 24px; height: 24px; stroke-width: 2; }
  .mrc-fab-ic--close { opacity: 0; transform: rotate(-90deg) scale(0.6); }
  .mrc-chat[data-open] .mrc-fab-ic--open { opacity: 0; transform: rotate(90deg) scale(0.6); }
  .mrc-chat[data-open] .mrc-fab-ic--close { opacity: 1; transform: none; }

  /* ── Panel ──────────────────────────────────────────────── */
  .mrc-panel[hidden] { display: none; }
  .mrc-panel {
    position: absolute; right: 0; bottom: calc(56px + var(--space-3));
    display: flex; flex-direction: column;
    width: min(380px, calc(100vw - 24px)); height: min(560px, calc(100vh - 120px));
    background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg);
    box-shadow: var(--shadow-modal); overflow: hidden;
    animation: mrc-in var(--duration-base) var(--ease-out-expo);
    transform-origin: bottom right;
  }
  @keyframes mrc-in { from { opacity: 0; transform: translateY(12px) scale(0.98); } to { opacity: 1; transform: none; } }

  .mrc-head {
    display: flex; align-items: center; gap: var(--space-3);
    padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, var(--accent-teal-dim), transparent);
  }
  .mrc-avatar {
    flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--accent-teal-dim); border: 1px solid var(--accent-teal-line); color: var(--accent-teal);
  }
  .mrc-avatar :global(svg) { width: 18px; height: 18px; }
  .mrc-head-tx { display: flex; flex-direction: column; line-height: 1.25; min-width: 0; flex: 1; }
  .mrc-head-tx b { font-family: var(--font-display); font-size: var(--text-sm); font-weight: 600; color: var(--fg-primary); }
  .mrc-status { display: inline-flex; align-items: center; gap: var(--space-2); font-size: var(--text-xs); color: var(--fg-secondary); }
  .mrc-live { width: 6px; height: 6px; border-radius: 50%; background: var(--accent-teal); box-shadow: 0 0 0 0 var(--accent-teal); animation: mrc-pulse 2s ease-out infinite; }
  @keyframes mrc-pulse { 0% { box-shadow: 0 0 0 0 var(--accent-teal-line); } 70% { box-shadow: 0 0 0 6px transparent; } 100% { box-shadow: 0 0 0 0 transparent; } }
  .mrc-close {
    flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center;
    width: var(--tap-min); height: var(--tap-min); border-radius: var(--radius-md);
    background: transparent; border: none; color: var(--fg-secondary); cursor: pointer;
    transition: color var(--duration-fast), background var(--duration-fast);
  }
  .mrc-close:hover { color: var(--fg-primary); background: var(--bg-elevated); }
  .mrc-close:focus-visible { outline: 2px solid var(--accent-teal); outline-offset: 2px; }
  .mrc-close :global(svg) { width: 18px; height: 18px; }

  .mrc-log {
    flex: 1; min-height: 0; display: flex; flex-direction: column; gap: var(--space-3);
    padding: var(--space-4); overflow-y: auto; overscroll-behavior: contain;
  }

  .mrc-chips { display: flex; flex-wrap: wrap; gap: var(--space-2); padding: 0 var(--space-4) var(--space-3); }
  .mrc-chip {
    font-size: var(--text-xs); font-family: var(--font-body);
    padding: 6px var(--space-3); border-radius: var(--radius-pill);
    background: var(--bg-elevated); border: 1px solid var(--border); color: var(--fg-secondary); cursor: pointer;
    transition: color var(--duration-fast), border-color var(--duration-fast), background var(--duration-fast);
  }
  .mrc-chip:hover { color: var(--accent-teal); border-color: var(--accent-teal-line); background: var(--accent-teal-dim); }
  .mrc-chip:focus-visible { outline: 2px solid var(--accent-teal); outline-offset: 2px; }
  .mrc-chips[hidden] { display: none; }

  .mrc-form {
    display: flex; align-items: flex-end; gap: var(--space-2);
    padding: var(--space-3) var(--space-4); border-top: 1px solid var(--border); background: var(--bg-2);
  }
  .mrc-input {
    flex: 1; min-width: 0; resize: none; max-height: 120px;
    font-family: var(--font-body); font-size: var(--text-sm); line-height: var(--leading-normal);
    color: var(--fg-primary); background: var(--bg-card);
    border: 1px solid var(--border); border-radius: var(--radius-md);
    padding: 10px var(--space-3);
  }
  .mrc-input::placeholder { color: var(--fg-subtle); }
  .mrc-input:focus-visible { outline: none; border-color: var(--accent-teal-line); box-shadow: 0 0 0 2px var(--accent-teal-dim); }
  .mrc-send {
    flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center;
    width: var(--tap-min); height: var(--tap-min); border-radius: var(--radius-md);
    background: var(--accent-teal); color: var(--fg-inverse); border: none; cursor: pointer;
    transition: opacity var(--duration-fast), transform var(--duration-fast);
  }
  .mrc-send:hover { transform: translateY(-1px); }
  .mrc-send:focus-visible { outline: 2px solid var(--accent-teal); outline-offset: 2px; }
  .mrc-send:disabled { opacity: 0.45; cursor: not-allowed; transform: none; }
  .mrc-send :global(svg) { width: 18px; height: 18px; stroke-width: 2; }

  .mrc-privacy { padding: 0 var(--space-4) var(--space-3); font-size: var(--text-xs); color: var(--fg-subtle); text-align: center; }

  .mrc-sr { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0; }

  @media (--motion-reduce) {
    .mrc-fab, .mrc-fab-ic, .mrc-panel, .mrc-live, .mrc-send { animation: none !important; transition: none !important; }
  }
  @media print { .mrc-chat { display: none !important; } }
</style>

<style is:global>
  /* Burbujas dinámicas (las crea el JS → sin atributo de scope de Astro).
     Scopeadas a mano bajo .mrc-chat. */
  .mrc-chat .mrc-bub {
    max-width: 88%; padding: var(--space-3) var(--space-4); border-radius: 14px;
    font-size: var(--text-sm); line-height: var(--leading-normal); word-wrap: break-word; white-space: pre-wrap;
  }
  .mrc-chat .mrc-ai { align-self: flex-start; background: var(--bg-elevated); border: 1px solid var(--border); color: var(--fg-primary); border-bottom-left-radius: 4px; }
  .mrc-chat .mrc-user { align-self: flex-end; background: var(--accent-teal); color: var(--fg-inverse); border-bottom-right-radius: 4px; }
  .mrc-chat .mrc-sys { align-self: center; background: transparent; border: 1px dashed var(--border); color: var(--fg-secondary); font-size: var(--text-xs); max-width: 100%; }
  .mrc-chat .mrc-link { color: var(--accent-teal); text-decoration: underline; }
  .mrc-chat .mrc-user .mrc-link { color: var(--fg-inverse); }

  .mrc-chat .mrc-typing { align-self: flex-start; display: inline-flex; gap: 4px; padding: var(--space-3) var(--space-4); background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 14px; border-bottom-left-radius: 4px; }
  .mrc-chat .mrc-typing span { width: 6px; height: 6px; border-radius: 50%; background: var(--fg-subtle); animation: mrc-typedot 1.2s infinite ease-in-out; }
  .mrc-chat .mrc-typing span:nth-child(2) { animation-delay: 0.15s; }
  .mrc-chat .mrc-typing span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes mrc-typedot { 0%, 60%, 100% { transform: translateY(0); opacity: 0.4; } 30% { transform: translateY(-4px); opacity: 1; } }
  @media (prefers-reduced-motion: reduce) { .mrc-chat .mrc-typing span { animation: none; } }
</style>

<script>
  const root = document.getElementById('mrc-chat');
  const cfgEl = root && root.querySelector('[data-mrc-config]');
  if (root && cfgEl) {
    const cfg = JSON.parse(cfgEl.textContent || '{}');
    const T = cfg.strings || {};
    const LINKS = Array.isArray(cfg.links) ? cfg.links : [];
    const lang = cfg.lang === 'en' ? 'en' : 'es';

    const fab = root.querySelector('[data-mrc-fab]');
    const panel = document.getElementById('mrc-chat-panel');
    const closeBtn = root.querySelector('[data-mrc-close]');
    const log = root.querySelector('[data-mrc-log]');
    const form = root.querySelector('[data-mrc-form]');
    const input = root.querySelector('[data-mrc-input]');
    const sendBtn = root.querySelector('[data-mrc-send]');
    const chipRow = root.querySelector('[data-mrc-chips]');

    const sid = (crypto && crypto.randomUUID)
      ? crypto.randomUUID()
      : String(Date.now()) + Math.random().toString(36).slice(2);

    let history = [];   // solo pares user/assistant COMPLETADOS (alternancia válida)
    let busy = false;
    let opened = false;

    // ── Linkify SEGURO: solo tokens conocidos → nodos DOM (nunca innerHTML del modelo) ──
    function linkify(text) {
      const frag = document.createDocumentFragment();
      if (!LINKS.length) { frag.appendChild(document.createTextNode(text)); return frag; }
      const escaped = LINKS.map((l) => l.token.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'));
      const rx = new RegExp('(' + escaped.join('|') + ')', 'g');
      let last = 0; let m;
      while ((m = rx.exec(text)) !== null) {
        if (m.index > last) frag.appendChild(document.createTextNode(text.slice(last, m.index)));
        const obj = LINKS.find((l) => l.token === m[0]);
        const a = document.createElement('a');
        a.href = obj.href; a.textContent = m[0]; a.className = 'mrc-link';
        frag.appendChild(a);
        last = m.index + m[0].length;
      }
      if (last < text.length) frag.appendChild(document.createTextNode(text.slice(last)));
      return frag;
    }

    function appendBubble(role, text) {
      const b = document.createElement('div');
      b.className = 'mrc-bub mrc-' + role;
      if (role === 'ai') b.appendChild(linkify(text));
      else b.textContent = text;
      log.appendChild(b);
      log.scrollTop = log.scrollHeight;
    }
    function showTyping() {
      const t = document.createElement('div');
      t.className = 'mrc-typing'; t.setAttribute('data-mrc-typing', '');
      t.setAttribute('aria-label', T.typing || 'Typing');
      t.appendChild(document.createElement('span'));
      t.appendChild(document.createElement('span'));
      t.appendChild(document.createElement('span'));
      log.appendChild(t); log.scrollTop = log.scrollHeight;
    }
    function hideTyping() { const t = log.querySelector('[data-mrc-typing]'); if (t) t.remove(); }
    function setBusy(v) { busy = v; if (sendBtn) sendBtn.disabled = v; if (input) input.disabled = v; }

    async function send(textRaw) {
      const text = (textRaw || '').trim();
      if (!text || busy) return;
      setBusy(true);
      appendBubble('user', text);
      if (chipRow) chipRow.hidden = true;
      if (input) input.value = '';
      autoGrow();
      showTyping();

      const recent = history.slice(-18);
      const reqMessages = recent.concat([{ role: 'user', content: text }]);
      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: reqMessages, sessionId: sid, lang }),
        });
        let data = null; try { data = await res.json(); } catch (_) { /* respuesta no-JSON */ }
        hideTyping();
        if (data && data.reply) {
          appendBubble('ai', data.reply);
          history = reqMessages.concat([{ role: 'assistant', content: data.reply }]);
        } else {
          appendBubble('sys', (data && data.error) || T.error);
          // history NO se actualiza → la próxima petición mantiene alternancia válida
        }
      } catch (_) {
        hideTyping();
        appendBubble('sys', T.error);
      } finally {
        setBusy(false);
        if (opened && input) input.focus();
      }
    }

    function autoGrow() {
      if (!input) return;
      input.style.height = 'auto';
      input.style.height = Math.min(input.scrollHeight, 120) + 'px';
    }

    function openPanel() {
      panel.hidden = false;
      root.setAttribute('data-open', '');
      fab.setAttribute('aria-expanded', 'true');
      opened = true;
      requestAnimationFrame(() => { if (input) input.focus(); });
    }
    function closePanel() {
      panel.hidden = true;
      root.removeAttribute('data-open');
      fab.setAttribute('aria-expanded', 'false');
      opened = false;
      fab.focus();
    }
    function toggle() { (opened ? closePanel : openPanel)(); }

    // ── Eventos ──
    fab.addEventListener('click', toggle);
    if (closeBtn) closeBtn.addEventListener('click', closePanel);
    if (form) form.addEventListener('submit', (e) => { e.preventDefault(); send(input && input.value); });
    if (sendBtn) sendBtn.addEventListener('click', () => send(input && input.value));
    if (input) {
      input.addEventListener('input', autoGrow);
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(input.value); }
      });
    }
    if (chipRow) {
      chipRow.addEventListener('click', (e) => {
        const btn = e.target && e.target.closest ? e.target.closest('[data-msg]') : null;
        if (btn) send(btn.getAttribute('data-msg'));
      });
    }

    // ESC + focus-trap dentro del panel
    panel.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { e.preventDefault(); closePanel(); return; }
      if (e.key !== 'Tab') return;
      const nodes = panel.querySelectorAll('button, a[href], textarea, input, [tabindex]:not([tabindex="-1"])');
      const list = Array.prototype.filter.call(nodes, (el) => !el.disabled && el.offsetParent !== null);
      if (!list.length) return;
      const first = list[0]; const lastEl = list[list.length - 1];
      if (e.shiftKey && document.activeElement === first) { e.preventDefault(); lastEl.focus(); }
      else if (!e.shiftKey && document.activeElement === lastEl) { e.preventDefault(); first.focus(); }
    });
  }
</script>
