---
// ─────────────────────────────────────────────────────────────
// StarField — vida sutil en los fondos de las secciones (no el hero).
// Cada <section data-fx="gold|teal"> recibe su propio <canvas> en z-index:-1
// con POCAS estrellas (parpadeo + deriva muy lenta) y, de vez en cuando, UNA
// estrella fugaz tintada al acento de esa sección.
//
//  · Progresivo: sin JS no se dibuja nada (el fondo queda negro intacto).
//  · reduced-motion: un solo fotograma estático (estrellas quietas, sin fugaces).
//  · Rendimiento: 1 canvas por sección, arranca/para por IntersectionObserver y
//    se pausa con la pestaña oculta. Sin scroll-x (canvas width:100%, inset:0).
//
// Opcionales por sección: data-fx-density (def .6) · data-fx-shoot (def 1; "off" apaga).
// Se incluye UNA vez por página (su <script> descubre todas las [data-fx]).
// ─────────────────────────────────────────────────────────────
---

<style is:global>
  [data-fx] { position: relative; }
  [data-fx] > canvas.mfx {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    display: block;
  }
</style>

<script>
  const REDUCE = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const cs = getComputedStyle(document.documentElement);
  const rgbVar = (name: string, fb: string) => (cs.getPropertyValue(name).trim() || fb);
  const TINT: Record<string, string> = {
    gold: rgbVar('--accent-gold-rgb', '200, 169, 110'),
    teal: rgbVar('--accent-teal-rgb', '79, 195, 161'),
    neutral: rgbVar('--star-rgb', '240, 237, 232'),
  };
  const TAU = Math.PI * 2;

  interface Star { x: number; y: number; r: number; base: number; amp: number; sp: number; ph: number; drift: number; }
  interface Shooter { x: number; y: number; vx: number; vy: number; life: number; max: number; len: number; }

  function makeEngine(host: HTMLElement) {
    const canvas = document.createElement('canvas');
    canvas.className = 'mfx';
    canvas.setAttribute('aria-hidden', 'true');
    host.prepend(canvas);
    const ctx = canvas.getContext('2d');
    if (!ctx) return null;

    const tone = host.dataset.fx || 'gold';
    const rgb = TINT[tone] || TINT.gold;
    const density = parseFloat(host.dataset.fxDensity || '0.6');
    const shootScale = parseFloat(host.dataset.fxShoot || '1');
    const shootOff = host.dataset.fxShoot === 'off';

    let W = 0, H = 0, DPR = 1, t0 = 0, prev = 0, nextShoot = 0, raf = 0, running = false;
    let stars: Star[] = [], shooters: Shooter[] = [];

    function resize() {
      const r = host.getBoundingClientRect();
      DPR = Math.min(2, window.devicePixelRatio || 1);
      W = Math.max(1, Math.round(r.width));
      H = Math.max(1, Math.round(r.height));
      canvas.width = W * DPR;
      canvas.height = H * DPR;
      ctx!.setTransform(DPR, 0, 0, DPR, 0, 0);
      seed();
      staticDraw(); // fotograma base inmediato (sin parpadeo en blanco; el rAF lo reemplaza al animar)
    }
    function seed() {
      const per = 11; // estrellas por megapíxel → pocas y sutiles
      const count = Math.round((W * H / 1e6) * per * density);
      stars = [];
      for (let i = 0; i < count; i++) {
        stars.push({
          x: Math.random() * W, y: Math.random() * H,
          r: Math.random() * 1.0 + 0.4,
          base: Math.random() * 0.20 + 0.05,   // opacidad de reposo muy baja
          amp: Math.random() * 0.28 + 0.12,    // amplitud del parpadeo
          sp: Math.random() * 0.0008 + 0.0003, // velocidad del parpadeo
          ph: Math.random() * TAU,
          drift: (Math.random() - 0.5) * 0.010, // deriva horizontal lentísima
        });
      }
    }
    function scheduleShoot(now: number) {
      if (REDUCE || shootOff) { nextShoot = Infinity; return; }
      const base = 14000 / (shootScale || 1);        // "de vez en cuando" (~11–25 s)
      nextShoot = now + base * (0.7 + Math.random() * 1.1);
    }
    function spawnShoot() {
      const fromLeft = Math.random() < 0.5;
      const y = Math.random() * H * 0.5 + H * 0.05;
      const ang = (Math.random() * 0.16 + 0.10) * (fromLeft ? 1 : -1);
      const speed = 0.45 + Math.random() * 0.30;
      shooters.push({
        x: fromLeft ? -30 : W + 30, y,
        vx: (fromLeft ? 1 : -1) * Math.cos(ang) * speed,
        vy: Math.sin(Math.abs(ang)) * speed,
        life: 0, max: 800 + Math.random() * 500, len: 70 + Math.random() * 60,
      });
    }
    function frame(now: number) {
      let dt = prev ? now - prev : 16; prev = now; if (dt > 48) dt = 48;
      ctx!.clearRect(0, 0, W, H);
      for (const s of stars) {
        const tw = s.base + s.amp * (0.5 + 0.5 * Math.sin((now - t0) * s.sp + s.ph));
        s.x += s.drift; if (s.x < -2) s.x = W + 2; else if (s.x > W + 2) s.x = -2;
        ctx!.beginPath();
        ctx!.fillStyle = `rgba(${rgb},${tw.toFixed(3)})`;
        ctx!.arc(s.x, s.y, s.r, 0, TAU);
        ctx!.fill();
      }
      if (now >= nextShoot) { if (shooters.length === 0) spawnShoot(); scheduleShoot(now); }
      for (let i = shooters.length - 1; i >= 0; i--) {
        const sh = shooters[i];
        sh.life += dt; sh.x += sh.vx * dt * 0.9; sh.y += sh.vy * dt * 0.9;
        const p = sh.life / sh.max;
        const fade = p < 0.15 ? p / 0.15 : (p > 0.7 ? Math.max(0, (1 - p) / 0.3) : 1);
        const tx = sh.x - sh.vx * sh.len, ty = sh.y - sh.vy * sh.len;
        const g = ctx!.createLinearGradient(tx, ty, sh.x, sh.y);
        g.addColorStop(0, `rgba(${rgb},0)`);
        g.addColorStop(1, `rgba(${rgb},${(0.55 * fade).toFixed(3)})`);
        ctx!.strokeStyle = g; ctx!.lineWidth = 1.4; ctx!.lineCap = 'round';
        ctx!.beginPath(); ctx!.moveTo(tx, ty); ctx!.lineTo(sh.x, sh.y); ctx!.stroke();
        ctx!.beginPath(); ctx!.fillStyle = `rgba(${rgb},${(0.7 * fade).toFixed(3)})`;
        ctx!.arc(sh.x, sh.y, 1.3, 0, TAU); ctx!.fill();
        if (p >= 1 || sh.x < -80 || sh.x > W + 80 || sh.y > H + 80) shooters.splice(i, 1);
      }
      raf = requestAnimationFrame(frame);
    }
    function staticDraw() {
      ctx!.clearRect(0, 0, W, H);
      for (const s of stars) {
        ctx!.beginPath();
        ctx!.fillStyle = `rgba(${rgb},${(s.base + s.amp * 0.4).toFixed(3)})`;
        ctx!.arc(s.x, s.y, s.r, 0, TAU);
        ctx!.fill();
      }
    }
    function start() {
      if (running || REDUCE) return;
      if (!W || !H) resize();
      running = true; t0 = performance.now(); prev = 0;
      scheduleShoot(t0); raf = requestAnimationFrame(frame);
    }
    function stop() {
      running = false; if (raf) cancelAnimationFrame(raf); raf = 0;
    }

    resize();
    return { host, resize, start, stop };
  }

  const engines = Array.from(document.querySelectorAll<HTMLElement>('[data-fx]'))
    .map(makeEngine)
    .filter(Boolean) as Array<{ host: HTMLElement; resize: () => void; start: () => void; stop: () => void }>;

  if (engines.length && !REDUCE) {
    const visible = new Set<HTMLElement>();
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          const eng = engines.find((g) => g.host === e.target);
          if (!eng) continue;
          if (e.isIntersecting) { visible.add(eng.host); if (!document.hidden) eng.start(); }
          else { visible.delete(eng.host); eng.stop(); }
        }
      }, { rootMargin: '120px' });
      engines.forEach((g) => io.observe(g.host));
    } else {
      engines.forEach((g) => { visible.add(g.host); g.start(); });
    }

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) engines.forEach((g) => g.stop());
      else engines.forEach((g) => { if (visible.has(g.host)) g.start(); });
    });

    let rzT: number;
    window.addEventListener('resize', () => {
      clearTimeout(rzT);
      rzT = window.setTimeout(() => engines.forEach((g) => g.resize()), 160);
    }, { passive: true });
    // re-medir tras cargar fuentes/imágenes (evita canvas con alto viejo)
    window.addEventListener('load', () => engines.forEach((g) => g.resize()));
  }
</script>
