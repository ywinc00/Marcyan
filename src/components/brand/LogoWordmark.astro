---
// Logo principal horizontal: planeta + wordmark "MARCYAN" + descriptor.
// Para nav y footer. width controla el tamaño; mantiene proporción 400:160.
interface Props {
  width?: number | string;
  title?: string;
  decorative?: boolean;
  class?: string;
}
const { width = 200, title = 'Marcyan', decorative = false, class: cls } = Astro.props;
const uid = 'wm' + Math.random().toString(36).slice(2, 8);
---
<svg
  class:list={['logo-wordmark', cls]}
  width={width} viewBox="0 0 400 160"
  role={decorative ? 'presentation' : 'img'}
  aria-hidden={decorative ? 'true' : undefined}
  aria-label={decorative ? undefined : title}
>
  {!decorative && <title>{title}</title>}
  <defs>
    <radialGradient id={`${uid}-p`} cx="50%" cy="40%" r="50%">
      <stop offset="0%" stop-color="var(--accent-gold)" />
      <stop offset="60%" stop-color="var(--accent-gold-deep)" />
      <stop offset="100%" stop-color="var(--planet-core)" />
    </radialGradient>
    <radialGradient id={`${uid}-g`} cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="var(--accent-gold)" stop-opacity="0.30" />
      <stop offset="100%" stop-color="var(--accent-gold)" stop-opacity="0" />
    </radialGradient>
    <clipPath id={`${uid}-c`}><circle cx="56" cy="80" r="32" /></clipPath>
  </defs>

  <circle cx="56" cy="80" r="48" fill={`url(#${uid}-g)`} />
  <path d="M6 80 A50 14 0 0 0 106 80" fill="none" stroke="var(--accent-gold)" stroke-width="1.4" stroke-opacity="0.30" stroke-linecap="round" />
  <circle cx="56" cy="80" r="32" fill={`url(#${uid}-p)`} />
  <ellipse cx="66" cy="84" rx="28" ry="28" fill="rgba(0,0,0,0.45)" clip-path={`url(#${uid}-c)`} />
  <path d="M6 80 A50 14 0 0 1 106 80" fill="none" stroke="var(--accent-gold)" stroke-width="1.7" stroke-opacity="0.82" stroke-linecap="round" />
  <circle cx="106" cy="80" r="5" fill="var(--accent-teal)" />

  <text class="wm-name" x="124" y="72">MARCYAN</text>
  <text class="wm-sub" x="125" y="92">DIGITAL STUDIO</text>
</svg>

<style>
  .logo-wordmark { display: block; height: auto; }
  .wm-name {
    font-family: var(--font-display);
    font-size: 32px; font-weight: 700; letter-spacing: -1px;
    fill: var(--fg-primary);
  }
  .wm-sub {
    font-family: var(--font-body);
    font-size: 11px; font-weight: 400; letter-spacing: 3.5px;
    fill: var(--fg-secondary);
  }
</style>
