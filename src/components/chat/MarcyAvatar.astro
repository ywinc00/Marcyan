---
// ─────────────────────────────────────────────────────────────
// MarcyAvatar — mascota del asistente "Marcy" (Marcyan).
// Render 3D APROBADO por el dueño (robot negro glossy, ojos teal con glow,
// acentos oro, audífonos, anillo de Saturno sobre la cabeza + planeta en el
// pecho = motivo marciano). Entregado como imagen optimizada con transparencia.
//
//   variant="hero" → pose completa flotando (pantalla de bienvenida)  ~364×512
//   variant="mini" → busto (cabeza + cascos + anillo + planeta) para header/FAB  256×256
//
// Cada variante es <picture> con WebP (principal) + PNG (fallback), width/height
// explícitos (sin layout shift). El "parpadeo" del SVG anterior ya no aplica
// (imagen estática); la flotación y el glow ambiental viven en ChatWidget.
// reduced-motion → fijo.
//
// defer=true (lo usa el héroe): NO pone el src real en el HTML; lo deja en
// data-src/data-srcset y un placeholder transparente. ChatWidget lo activa al
// ABRIR el chat → el asset grande NO se descarga en el render inicial del sitio.
// (El mini va eager: el FAB es visible y ya lo muestra; el header reusa la caché.)
//
// Fuente: public/assets/bot/marcy-{hero,mini}.{webp,png} (ver README.md de esa
// carpeta para regenerarlos desde el render original).
// ─────────────────────────────────────────────────────────────
interface Props { variant?: 'hero' | 'mini'; defer?: boolean; class?: string; }
const { variant = 'mini', defer = false, class: cls = '' } = Astro.props;

const dims = variant === 'hero' ? { w: 364, h: 512 } : { w: 256, h: 256 };
// El héroe lleva alt descriptivo (la imagen aporta significado en la bienvenida);
// el mini es DECORATIVO (siempre va junto al texto "Marcy") → alt vacío.
const alt = variant === 'hero' ? 'Marcy, el asistente de Marcyan' : '';
const webp = `/assets/bot/marcy-${variant}.webp`;
const png = `/assets/bot/marcy-${variant}.png`;
// GIF 1×1 transparente (placeholder mientras el héroe está diferido).
const BLANK = 'data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==';
---
<picture class={`marcy marcy--${variant} ${cls}`}>
  <source srcset={defer ? undefined : webp} data-srcset={defer ? webp : undefined} type="image/webp" />
  <img
    src={defer ? BLANK : png}
    data-src={defer ? png : undefined}
    data-mrc-defer={defer ? '' : undefined}
    alt={alt}
    width={dims.w}
    height={dims.h}
    loading={defer ? 'lazy' : 'eager'}
    decoding="async"
    draggable="false"
  />
</picture>

<style>
  .marcy { display: block; line-height: 0; }
  .marcy img { display: block; max-width: 100%; height: auto; -webkit-user-select: none; user-select: none; }
</style>
