---
// Pie del sitio — "EL ARRIBO". Como las MONTAÑAS al fondo de un sitio de cielo (ejemplo del
// dueño): contenido limpio ARRIBA (el "cielo" estrellado) y, abajo del todo y a lo ancho, una
// banda decorativa = el HORIZONTE DE UN PLANETA (el "suelo" al que llegas). Los elementos
// decorativos NO se superponen con textos ni botones: viven en su propia banda inferior.
// Dirección visual del sitio: StarField (más denso) + glow de atmósfera + DS.
import { nap } from '../../i18n/content';
import LogoWordmark from '../brand/LogoWordmark.astro';
import StarField from '../StarField.astro';

interface Props { footer: any }
const { footer } = Astro.props;
const f = footer;
const telHou = nap.houston.replace(/[^\d+]/g, '');
const telMia = nap.miami.replace(/[^\d+]/g, '');
---
<footer class="footer" data-fx="gold" data-fx-density="1.5">
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href="#top" aria-label="Marcyan Studio — inicio" class="footer__logo">
        <LogoWordmark width={184} />
      </a>
      <p class="footer__tagline">{f.tagline}</p>
      {f.cta && (
        <a class="footer__cta" href={f.cta.href}>
          <span>{f.cta.label}</span>
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      )}
      <ul class="footer__contact">
        <li>
          <a href={`mailto:${nap.email}`}>{nap.email}</a>
          <button type="button" class="footer__copy" data-copy={nap.email} aria-label="Copiar correo">
            <svg class="footer__copy-ic footer__copy-ic--copy" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>
            <svg class="footer__copy-ic footer__copy-ic--ok" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
          </button>
        </li>
        <li>
          <span class="footer__city">Houston</span><a href={`tel:${telHou}`}>{nap.houston}</a>
          <button type="button" class="footer__copy" data-copy={nap.houston} aria-label="Copiar teléfono de Houston">
            <svg class="footer__copy-ic footer__copy-ic--copy" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>
            <svg class="footer__copy-ic footer__copy-ic--ok" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
          </button>
        </li>
        <li>
          <span class="footer__city">Miami</span><a href={`tel:${telMia}`}>{nap.miami}</a>
          <button type="button" class="footer__copy" data-copy={nap.miami} aria-label="Copiar teléfono de Miami">
            <svg class="footer__copy-ic footer__copy-ic--copy" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>
            <svg class="footer__copy-ic footer__copy-ic--ok" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
          </button>
        </li>
        <li class="footer__hours">{nap.hours}</li>
      </ul>
    </div>

    <nav class="footer__cols" aria-label="Enlaces del pie">
      {f.cols.map((col: any) => (
        <details class="footer__col">
          <summary class="footer__col-title">
            <span>{col.title}</span>
            <svg class="footer__col-chevron" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </summary>
          <ul>
            {col.links.map((l: any) => <li><a href={l.href}>{l.label}</a></li>)}
          </ul>
        </details>
      ))}
    </nav>
  </div>

  <div class="container footer__bottom">
    <span>{f.copy}</span>
    <span class="footer__legal">
      {f.legal.map((l: any) => <a href={l.href}>{l.label}</a>)}
    </span>
  </div>

  {/* "Suelo" del arribo: horizonte de un planeta a lo ancho, DEBAJO de todo (no toca texto) */}
  <div class="footer__ground" aria-hidden="true">
    <svg class="footer__ground-svg" viewBox="0 0 1440 300" preserveAspectRatio="none" fill="none">
      <defs>
        <linearGradient id="ftSurf" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#2a1e0f" />
          <stop offset="0.45" stop-color="#140d06" />
          <stop offset="1" stop-color="#080605" />
        </linearGradient>
        <linearGradient id="ftAtmos" x1="0" y1="1" x2="0" y2="0">
          <stop offset="0" stop-color="var(--accent-gold)" stop-opacity="0" />
          <stop offset="0.55" stop-color="var(--accent-gold)" stop-opacity=".24" />
          <stop offset="1" stop-color="var(--accent-gold)" stop-opacity="0" />
        </linearGradient>
        <radialGradient id="ftSun" cx="50%" cy="100%" r="45%">
          <stop offset="0" stop-color="#ffeec0" stop-opacity=".55" />
          <stop offset="55%" stop-color="var(--accent-gold)" stop-opacity=".18" />
          <stop offset="100%" stop-color="var(--accent-gold)" stop-opacity="0" />
        </radialGradient>
      </defs>
      {/* atmósfera (glow) por encima del horizonte */}
      <rect x="0" y="0" width="1440" height="150" fill="url(#ftAtmos)" />
      <ellipse cx="720" cy="128" rx="560" ry="92" fill="url(#ftSun)" />
      {/* superficie del planeta (limbo curvo = horizonte) */}
      <path d="M0,128 Q720,70 1440,128 L1440,300 L0,300 Z" fill="url(#ftSurf)" />
      {/* borde de atmósfera iluminado sobre el limbo */}
      <path d="M0,128 Q720,70 1440,128" stroke="var(--accent-gold)" stroke-width="1.6" stroke-opacity=".5" />
    </svg>
  </div>

  <StarField />
</footer>

<style>
  .footer {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    background: var(--bg-base);
    border-top: 1px solid var(--border);
    padding-top: var(--space-7);
    margin-top: var(--space-9);
  }

  /* ── Contenido (el "cielo" estrellado, arriba) ──────────────────── */
  .footer__inner {
    position: relative; z-index: 1;
    display: grid; grid-template-columns: 1fr; gap: var(--space-7);
  }
  .footer__brand { display: flex; flex-direction: column; gap: var(--space-3); min-width: 0; }
  .footer__logo { display: inline-flex; width: fit-content; }
  .footer__tagline { color: var(--fg-secondary); font-size: var(--text-sm); max-width: 36ch; margin: 0; }

  .footer__cta {
    display: inline-flex; align-items: center; gap: var(--space-3);
    width: fit-content; min-height: var(--tap-min); padding: 10px 18px;
    border-radius: var(--radius-md); background: var(--accent-gold); color: var(--fg-inverse);
    font-size: var(--text-sm); font-weight: 600; text-decoration: none;
    transition: background var(--duration-base), transform var(--duration-base), box-shadow var(--duration-base);
  }
  .footer__cta:hover { transform: translateY(-1px); box-shadow: var(--shadow-gold); }

  .footer__contact { list-style: none; display: flex; flex-direction: column; gap: var(--space-2); margin: var(--space-1) 0 0; padding: 0; }
  .footer__contact li { display: flex; align-items: center; gap: var(--space-2); min-width: 0; }
  .footer__contact a { color: var(--fg-secondary); font-size: var(--text-sm); text-decoration: none; transition: color var(--duration-fast); }
  .footer__contact a:hover { color: var(--accent-gold); }
  .footer__city { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--fg-subtle); text-transform: uppercase; letter-spacing: var(--tracking-wide); margin-right: calc(-1 * var(--space-1)); }
  .footer__hours { color: var(--fg-subtle); font-size: var(--text-xs); }

  /* Botón "copiar" junto a correo/teléfonos */
  .footer__copy {
    position: relative; flex: 0 0 auto;
    display: inline-grid; place-items: center;
    width: 22px; height: 22px; padding: 0;
    border: 0; border-radius: var(--radius-sm);
    background: transparent; color: var(--fg-subtle); cursor: pointer;
    transition: color var(--duration-fast), background var(--duration-fast);
  }
  .footer__copy:hover { color: var(--accent-gold); background: var(--accent-gold-dim); }
  .footer__copy:focus-visible { outline: 2px solid var(--accent-gold); outline-offset: 2px; }
  .footer__copy-ic { display: block; }
  .footer__copy-ic--ok { display: none; color: var(--accent-teal); }
  .footer__copy.is-copied { color: var(--accent-teal); }
  .footer__copy.is-copied .footer__copy-ic--copy { display: none; }
  .footer__copy.is-copied .footer__copy-ic--ok { display: block; }
  .footer__copy.is-copied::after {
    content: "¡Copiado!"; position: absolute; bottom: calc(100% + 6px); left: 50%; transform: translateX(-50%);
    background: var(--bg-elevated); color: var(--fg-primary); border: 1px solid var(--border);
    padding: 3px 8px; border-radius: var(--radius-sm); font-family: var(--font-body);
    font-size: var(--text-xs); line-height: 1; white-space: nowrap; pointer-events: none;
  }

  /* MÓVIL: columnas = acordeones plegables (tap) — evita el "scroll infinito" */
  .footer__cols { display: grid; grid-template-columns: 1fr; gap: 0; }
  .footer__col { border-top: 1px solid var(--border-subtle); }
  .footer__col:last-of-type { border-bottom: 1px solid var(--border-subtle); }
  .footer__col-title {
    display: flex; align-items: center; justify-content: space-between; gap: var(--space-3);
    list-style: none; cursor: pointer; min-height: var(--tap-min);
    padding: var(--space-3) 0; margin: 0;
    font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 500;
    letter-spacing: var(--tracking-wider); text-transform: uppercase; color: var(--accent-gold);
  }
  .footer__col-title::-webkit-details-marker { display: none; }
  .footer__col-title::marker { content: ""; }
  .footer__col-chevron { flex: 0 0 auto; color: var(--fg-subtle); transition: transform var(--duration-base); }
  .footer__col[open] .footer__col-chevron { transform: rotate(180deg); }
  .footer__col > ul { display: none; list-style: none; flex-direction: column; gap: var(--space-2); margin: 0 0 var(--space-4); padding: 0; }
  .footer__col[open] > ul { display: flex; }
  .footer__col a { color: var(--fg-secondary); font-size: var(--text-sm); text-decoration: none; transition: color var(--duration-fast), transform var(--duration-fast); display: inline-block; }
  .footer__col a:hover { color: var(--fg-primary); transform: translateX(2px); }

  /* ── Barra legal (todavía en el "cielo", encima del horizonte) ──── */
  .footer__bottom {
    position: relative; z-index: 1;
    display: flex; flex-wrap: wrap; gap: var(--space-3) var(--space-5);
    justify-content: space-between; align-items: center;
    margin-top: var(--space-7); padding: var(--space-4) 0 var(--space-6);
    border-top: 1px solid var(--border-subtle);
    font-size: var(--text-xs); color: var(--fg-subtle);
  }
  .footer__legal { display: inline-flex; gap: var(--space-4); }
  .footer__legal a { color: var(--fg-subtle); text-decoration: none; transition: color var(--duration-fast); }
  .footer__legal a:hover { color: var(--accent-gold); }

  /* ── "Suelo" del arribo: banda de horizonte, abajo del todo, a lo ancho ── */
  .footer__ground { position: relative; z-index: 0; width: 100%; height: 210px; overflow: hidden; }
  .footer__ground-svg { display: block; width: 100%; height: 210px; }
  @media (max-width: 640px) {
    .footer { padding-top: var(--space-6); }
    .footer__brand { gap: var(--space-3); }
    .footer__ground, .footer__ground-svg { height: 124px; }
    .footer__bottom { margin-top: var(--space-6); padding: var(--space-4) 0 var(--space-5); }
  }

  /* ── ≥ md: marca izquierda · columnas derecha ───────────────────── */
  @media (--md) {
    .footer__inner { grid-template-columns: 1.25fr 2fr; gap: var(--space-10); align-items: start; }
    /* DESKTOP: columnas abiertas siempre (sin acordeón) */
    .footer__cols { grid-template-columns: repeat(3, 1fr); gap: var(--space-6) var(--space-5); }
    .footer__col, .footer__col:last-of-type { border: 0; }
    .footer__col-title { cursor: default; pointer-events: none; min-height: 0; padding: 0 0 var(--space-4); }
    .footer__col-chevron { display: none; }
    .footer__col > ul { display: flex !important; margin-bottom: 0; }
  }
</style>

<script>
  // Copiar correo/teléfono al portapapeles (con fallback) + feedback "¡Copiado!"
  document.querySelectorAll<HTMLButtonElement>('.footer__copy').forEach((btn) => {
    let timer: number | undefined;
    btn.addEventListener('click', async () => {
      const val = btn.getAttribute('data-copy') || '';
      try {
        await navigator.clipboard.writeText(val);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = val; ta.style.position = 'fixed'; ta.style.opacity = '0';
        document.body.appendChild(ta); ta.focus(); ta.select();
        try { document.execCommand('copy'); } catch {}
        ta.remove();
      }
      btn.classList.add('is-copied');
      window.clearTimeout(timer);
      timer = window.setTimeout(() => btn.classList.remove('is-copied'), 1500);
    });
  });
</script>
