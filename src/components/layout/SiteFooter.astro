---
// Pie del sitio — COPIA FIEL del kit del dueño (marcyan-footer-assets):
// estructura del demo + SVGs reales + texturas + CSS del kit. ÚNICA adaptación:
// la tipografía es la del DS (Space Grotesk / DM Sans), por lo que el wordmark y
// la marca de agua se renderizan inline (los SVG de texto del kit usan Montserrat
// y como <img> no podrían tomar nuestra fuente). Contenido data-driven (content.ts)
// para conservar enlaces reales + i18n. Estilos en src/styles/marcyan-footer.css.
import { nap } from '../../i18n/content';
import '../../styles/marcyan-footer.css';

interface Props { footer: any; lang?: 'es' | 'en'; homeHref?: string }
const { footer, lang = 'es', homeHref = '/es/' } = Astro.props;
const f = footer;
const SVG = '/assets/marcyan-footer/svg';
const telHou = nap.houston.replace(/[^\d+]/g, '');
const telMia = nap.miami.replace(/[^\d+]/g, '');
// Iconos de los 4 atajos (en el orden del kit: web · seo-ai · ai-business · branding).
const SHORTCUT_ICONS = ['icon-web', 'icon-seo-ai', 'icon-ai-business', 'icon-branding'];
const homeLabel = lang === 'es' ? 'Marcyan Studio — inicio' : 'Marcyan Studio — home';
// Detecta la columna de Ciudades para insertar el divisor entre Houston y Miami.
const isCitiesCol = (title: string) => /ciudad|cities/i.test(title);
---
<footer class="marcyan-footer">
  <img class="marcyan-footer__illustration" src="/assets/marcyan-footer/textures/skyline-illustration.webp" alt="" aria-hidden="true" />
  <svg class="marcyan-footer__watermark" viewBox="0 0 1200 180" fill="none" aria-hidden="true">
    <text class="marcyan-footer__watermark-txt" x="0" y="145">MARCYAN</text>
  </svg>

  <div class="marcyan-footer__container">
    <div class="marcyan-footer__top">
      <section class="marcyan-footer__brand" aria-label="Marcyan Studio">
        <a class="marcyan-footer__brand-row" href={homeHref} aria-label={homeLabel}>
          <img class="marcyan-footer__logo-mark" src={`${SVG}/logo-mark.svg`} alt="" width="88" height="88" />
          <svg class="marcyan-footer__wordmark" viewBox="0 0 260 80" fill="none">
            <text class="marcyan-footer__wordmark-name" x="0" y="34">MARCYAN</text>
            <text class="marcyan-footer__wordmark-sub" x="2" y="62">DIGITAL STUDIO</text>
          </svg>
        </a>

        <p class="marcyan-footer__eyebrow">{f.tagline}</p>
        <h2 class="marcyan-footer__title">{f.brand.headline} <span>{f.brand.headlineEm}</span></h2>
        <p class="marcyan-footer__copy">{f.brand.blurb}</p>

        <a class="marcyan-footer__cta" href={f.brand.cta.href}>
          {f.brand.cta.label}
          <img src={`${SVG}/cta-arrow.svg`} alt="" width="24" height="24" />
        </a>

        <div class="marcyan-footer__shortcuts">
          {f.brand.shortcuts.map((s: any, i: number) => (
            <a class="marcyan-footer__shortcut" href={s.href}>
              <img src={`${SVG}/${SHORTCUT_ICONS[i] ?? 'icon-web'}.svg`} alt="" />
              {s.label}
            </a>
          ))}
        </div>
      </section>

      {f.cols.map((col: any) => (
        <nav class="marcyan-footer__col" aria-label={col.title}>
          <h3 class="marcyan-footer__heading">{col.title}</h3>
          <div class="marcyan-footer__links">
            {(() => { let dividerDone = false; return col.links.map((l: any) => {
              const needsDivider = isCitiesCol(col.title) && !dividerDone && /\/miami(\/|$)/.test(l.href);
              if (needsDivider) dividerDone = true;
              return (
                <>
                  {needsDivider && <div class="marcyan-footer__divider"></div>}
                  <a href={l.href}>{l.label}</a>
                </>
              );
            }); })()}
          </div>
        </nav>
      ))}

      <section class="marcyan-footer__col" aria-label={f.contactTitle}>
        <h3 class="marcyan-footer__heading">{f.contactTitle}</h3>
        <div class="marcyan-footer__contact-list">
          <div class="marcyan-footer__contact-item">
            <img src={`${SVG}/icon-email.svg`} alt="" />
            <span><a href={`mailto:${nap.email}`}>{nap.email}</a></span>
          </div>
          <div class="marcyan-footer__contact-item">
            <img src={`${SVG}/icon-phone.svg`} alt="" />
            <span><span class="marcyan-footer__contact-label">Houston</span><a href={`tel:${telHou}`}>{nap.houston}</a></span>
          </div>
          <div class="marcyan-footer__contact-item">
            <img src={`${SVG}/icon-phone.svg`} alt="" />
            <span><span class="marcyan-footer__contact-label">Miami</span><a href={`tel:${telMia}`}>{nap.miami}</a></span>
          </div>
          <div class="marcyan-footer__contact-item">
            <img src={`${SVG}/icon-clock.svg`} alt="" />
            <span>{nap.hours}</span>
          </div>
        </div>
        {f.social && (
          <div class="marcyan-footer__socials">
            {f.social.map((s: any) => (
              <a href={s.href} aria-label={s.label}><img src={`${SVG}/social-${s.name}.svg`} alt="" /></a>
            ))}
          </div>
        )}
      </section>
    </div>

    <div class="marcyan-footer__bottom-strip">
      <div class="marcyan-footer__mission">
        <img src={`${SVG}/icon-mission.svg`} alt="" />
        <div><strong>{f.mission.title}</strong><p>{f.mission.sub}</p></div>
      </div>
      <div class="marcyan-footer__stats">
        {f.stats.map((s: any) => (
          <div class="marcyan-footer__stat"><strong>{s.value}</strong><span>{s.label}</span></div>
        ))}
      </div>
      <div class="marcyan-footer__project-card">
        <img src={`${SVG}/icon-project.svg`} alt="" />
        <div>
          <strong>{f.projectCard.title}</strong>
          <p>{f.projectCard.sub}</p>
          <a href={f.projectCard.cta.href}>{f.projectCard.cta.label} →</a>
        </div>
      </div>
    </div>

    <div class="marcyan-footer__legal">
      <span>{f.copy}</span>
      <img src={`${SVG}/divider-planet.svg`} alt="" />
      <div class="marcyan-footer__legal-links">
        {f.legal.map((l: any) => <a href={l.href}>{l.label}</a>)}
      </div>
    </div>
  </div>
</footer>
