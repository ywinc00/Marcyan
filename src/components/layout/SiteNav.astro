---
// Navegación del sitio. Mobile-first:
//  · < md  → marca + hamburguesa → drawer off-canvas (links + lang + CTA dentro)
//            + barra de CTA fija inferior (aparece al pasar el hero).
//  · ≥ md  → barra completa (links + lang ES|EN + CTA outline inline).
// Sobre el hero la barra es TRANSPARENTE (se funde); al hacer scroll gana blur+fondo.
// Accesible: aria-expanded, aria-hidden/inert, foco atrapado, Esc/overlay cierran,
// objetivos ≥44px. NUNCA se oculta la nav sin reemplazo (regla dura nº2).
import Icon from '../ui/Icon.astro';
import BrandType from '../brand/BrandType.astro';
import Button from '../ui/Button.astro';

interface Props {
  nav: any;
  lang?: string;
  homeHref?: string;
  hasEn?: boolean;
  currentPath?: string;
  showCtaBar?: boolean;
}
const {
  nav,
  lang = 'es',
  homeHref = '/es/',
  hasEn = true,
  currentPath,
  showCtaBar = true,
} = Astro.props;

// aria-current: marca el link activo (no aplica al ancla de #contacto).
const isActive = (href: string) =>
  !!currentPath && href !== '#contacto' && currentPath.startsWith(href);
---
<header class="nav" data-nav>
  <div class="nav__bar container">
    <a class="nav__logo" href={homeHref} aria-label="Marcyan Studio — inicio">
      <BrandType />
    </a>

    <nav class="nav__links" aria-label="Principal">
      {nav.links.map((l: any) => <a href={l.href} aria-current={isActive(l.href) ? 'page' : undefined}>{l.label}</a>)}
    </nav>

    <div class="nav__actions">
      <div class="nav__lang" aria-label="Idioma">
        {lang === 'es'
          ? <span class="nav__lang-opt is-on" aria-current="true">ES</span>
          : <a class="nav__lang-opt" href={nav.langHref} hreflang="es">ES</a>}
        <span class="nav__lang-sep" aria-hidden="true"></span>
        {lang === 'en'
          ? <span class="nav__lang-opt is-on" aria-current="true">EN</span>
          : hasEn
            ? <a class="nav__lang-opt" href={nav.langHref} hreflang="en">EN</a>
            : <span class="nav__lang-opt is-disabled" aria-disabled="true" title="Disponible próximamente en inglés">EN</span>}
      </div>
      <a class="nav__cta" href={nav.cta.href}>{nav.cta.label}</a>
      <button class="nav__toggle" type="button" aria-expanded="false" aria-controls="nav-drawer" data-nav-toggle>
        <span class="sr-only">{nav.openMenu}</span>
        <Icon name="lucide:menu" />
      </button>
    </div>
  </div>

  <div class="nav__overlay" data-nav-overlay></div>

  <aside id="nav-drawer" class="nav__drawer" data-nav-drawer aria-label="Menú" aria-hidden="true" inert>
    <div class="nav__drawer-head">
      <BrandType />
      <button class="nav__close" type="button" data-nav-close>
        <span class="sr-only">{nav.closeMenu}</span>
        <Icon name="lucide:x" />
      </button>
    </div>
    <nav class="nav__drawer-links" aria-label="Menú móvil">
      {nav.links.map((l: any) => <a href={l.href} data-nav-link aria-current={isActive(l.href) ? 'page' : undefined}>{l.label}</a>)}
    </nav>
    <div class="nav__drawer-foot">
      <Button href={nav.cta.href} variant="primary" size="lg" class="u-full" data-nav-link>{nav.cta.label}</Button>
    </div>
  </aside>
</header>

{showCtaBar && (
  <div class="nav__cta-bar" data-nav-ctabar>
    <Button href={nav.cta.href} variant="primary" size="lg" class="u-full">{nav.cta.label}</Button>
  </div>
)}

<style>
  .nav {
    position: fixed; inset: 0 0 auto 0; z-index: var(--z-nav);
    transition: background var(--duration-slow) var(--ease-out-expo),
                border-color var(--duration-slow), backdrop-filter var(--duration-slow);
    border-bottom: 1px solid transparent;
  }
  /* Sobre el hero: transparente (se funde). Al hacer scroll: blur + fondo. */
  .nav.is-scrolled {
    background: var(--bg-overlay);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    border-bottom-color: var(--border);
  }
  .nav__bar {
    display: flex; align-items: center; justify-content: space-between; gap: var(--space-4);
    height: var(--nav-h);
  }
  .nav__logo { flex: 0 0 auto; display: inline-flex; align-items: center; }

  .nav__links { display: none; }
  .nav__actions { display: flex; align-items: center; gap: var(--space-3); }

  /* Switch de idioma ES | EN (ambos visibles, el activo en oro) — visible también en móvil */
  .nav__lang { display: inline-flex; align-items: center; gap: var(--space-2); }
  .nav__lang-opt {
    font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide);
    color: var(--fg-subtle); transition: color var(--duration-fast);
    min-height: var(--tap-min); display: inline-flex; align-items: center;
  }
  .nav__lang-opt.is-on { color: var(--accent-gold); }
  .nav__lang-opt.is-disabled { color: var(--fg-subtle); opacity: .5; cursor: default; }
  a.nav__lang-opt:hover { color: var(--fg-primary); }
  .nav__lang-sep { width: 1px; height: 13px; background: var(--border); }

  /* CTA outline dorado (se funde con el hero, no es un bloque sólido) */
  .nav__cta {
    display: none; align-items: center; justify-content: center;
    min-height: var(--tap-min); padding: 9px 18px; border-radius: var(--radius-md);
    font-family: var(--font-body); font-size: var(--text-sm); font-weight: 600;
    color: var(--accent-gold); background: var(--accent-gold-dim);
    border: 1px solid var(--accent-gold-line);
    transition: background var(--duration-fast) var(--ease-out-expo), color var(--duration-fast);
  }
  .nav__cta:hover { background: var(--accent-gold); color: var(--fg-inverse); }

  .nav__toggle {
    display: inline-flex; align-items: center; justify-content: center;
    width: var(--tap-min); height: var(--tap-min); color: var(--fg-primary);
    border-radius: var(--radius-md);
  }
  .nav__toggle :global(svg) { width: 26px; height: 26px; stroke-width: 1.75; }

  /* página actual (aria-current) — aplica en barra y drawer, todos los breakpoints */
  .nav__links a[aria-current="page"], .nav__drawer-links a[aria-current="page"] { color: var(--accent-gold); }

  /* ── ≥ md: barra completa ─────────────────────────────── */
  @media (--md) {
    /* gap ajustado para que 6 enlaces + marca + lang + CTA quepan a 768px */
    .nav__links { display: flex; align-items: center; gap: var(--space-4); }
    .nav__links a {
      font-family: var(--font-body); font-size: var(--text-sm); color: var(--fg-secondary);
      padding: var(--space-2) 0; transition: color var(--duration-fast); white-space: nowrap;
    }
    .nav__links a:hover { color: var(--fg-primary); }
    .nav__lang { display: inline-flex; }
    .nav__cta { display: inline-flex; }
    .nav__toggle { display: none; }
  }
  /* ≥ lg: hay espacio de sobra → respira más entre enlaces */
  @media (--lg) { .nav__links { gap: var(--space-6); } }

  /* ── Drawer (off-canvas) ──────────────────────────────── */
  .nav__overlay {
    position: fixed; inset: 0; z-index: var(--z-drawer);
    background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(2px);
    opacity: 0; pointer-events: none; transition: opacity var(--duration-base) var(--ease-out-expo);
  }
  .nav__overlay[data-open] { opacity: 1; pointer-events: auto; }

  .nav__drawer {
    position: fixed; inset: 0 0 0 auto; z-index: calc(var(--z-drawer) + 1);
    width: min(86vw, 360px); max-width: 100%;
    display: flex; flex-direction: column; gap: var(--space-6);
    padding: var(--space-5) var(--space-5) calc(var(--space-6) + env(safe-area-inset-bottom));
    background: var(--bg-elevated); border-left: 1px solid var(--border);
    transform: translateX(100%); transition: transform var(--duration-slow) var(--ease-out-expo);
    overflow-y: auto; overscroll-behavior: contain;
  }
  .nav__drawer[data-open] { transform: translateX(0); }

  .nav__drawer-head { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); }
  .nav__close {
    display: inline-flex; align-items: center; justify-content: center;
    width: var(--tap-min); height: var(--tap-min); color: var(--fg-secondary);
    border-radius: var(--radius-md); flex: 0 0 auto;
  }
  .nav__close:hover { color: var(--fg-primary); }
  .nav__close :global(svg) { width: 24px; height: 24px; stroke-width: 1.75; }

  .nav__drawer-links { display: flex; flex-direction: column; }
  .nav__drawer-links a {
    display: flex; align-items: center; min-height: var(--tap-min);
    font-family: var(--font-display); font-size: var(--text-lg); font-weight: 500;
    color: var(--fg-primary); padding: var(--space-3) 0;
    border-bottom: 1px solid var(--border-subtle);
  }
  .nav__drawer-links a:hover { color: var(--accent-gold); }

  .nav__drawer-foot { margin-top: auto; display: flex; flex-direction: column; gap: var(--space-4); }

  @media (--md) { .nav__overlay, .nav__drawer { display: none; } }

  /* ── Barra CTA fija inferior (móvil) ──────────────────── */
  .nav__cta-bar {
    position: fixed; inset: auto 0 0 0; z-index: var(--z-nav);
    padding: var(--space-3) var(--container-pad) calc(var(--space-3) + env(safe-area-inset-bottom));
    background: var(--bg-overlay); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid var(--border);
    transform: translateY(110%); transition: transform var(--duration-slow) var(--ease-out-expo);
  }
  .nav__cta-bar.is-visible { transform: translateY(0); }
  @media (--md) { .nav__cta-bar { display: none; } }
  @media (--motion-reduce) {
    .nav, .nav__overlay, .nav__drawer, .nav__cta-bar { transition: none; }
  }

  /* reservar espacio para la barra CTA inferior (móvil) → no tapa el footer */
  @media (--lt-md) {
    :global(body) { padding-bottom: calc(var(--tap-min) + var(--space-3) * 2 + env(safe-area-inset-bottom)); }
  }
</style>

<script>
  const root = document.querySelector('[data-nav]');
  if (root) {
    const toggle = root.querySelector('[data-nav-toggle]') as HTMLButtonElement;
    const drawer = root.querySelector('[data-nav-drawer]') as HTMLElement;
    const overlay = root.querySelector('[data-nav-overlay]') as HTMLElement;
    const closeBtn = root.querySelector('[data-nav-close]') as HTMLButtonElement;
    const links = Array.from(drawer.querySelectorAll<HTMLElement>('[data-nav-link], a'));
    const ctabar = document.querySelector('[data-nav-ctabar]') as HTMLElement;
    let lastFocus: HTMLElement | null = null;

    const focusables = () =>
      Array.from(drawer.querySelectorAll<HTMLElement>('a[href], button:not([disabled])'))
        .filter((el) => el.offsetParent !== null);

    function open() {
      lastFocus = document.activeElement as HTMLElement;
      drawer.setAttribute('data-open', '');
      overlay.setAttribute('data-open', '');
      drawer.removeAttribute('inert');
      drawer.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      focusables()[0]?.focus();
    }
    function close() {
      drawer.removeAttribute('data-open');
      overlay.removeAttribute('data-open');
      drawer.setAttribute('inert', '');
      drawer.setAttribute('aria-hidden', 'true');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      lastFocus?.focus();
    }

    // Tras el scroll a #contacto, mover el foco al primer campo del formulario.
    // Si #contacto no existe en la página, no hace nada (no lanza error).
    const focusContact = () => {
      requestAnimationFrame(() => {
        const t = document.getElementById('contacto');
        if (t) {
          t.setAttribute('tabindex', '-1');
          const f = t.querySelector<HTMLElement>('input,select,textarea');
          (f || t).focus({ preventScroll: true });
        }
      });
    };
    const isContactLink = (el: Element | null): el is HTMLAnchorElement =>
      !!el && el instanceof HTMLAnchorElement &&
      (el.getAttribute('href') || '').endsWith('#contacto');

    toggle.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    overlay.addEventListener('click', close);
    // Links del drawer: cerrar primero; si apuntan a #contacto, scroll+focus en el
    // siguiente frame para evitar el salto a medias mientras el drawer se cierra.
    links.forEach((l) => l.addEventListener('click', () => {
      close();
      if (isContactLink(l)) requestAnimationFrame(focusContact);
    }));

    // Cualquier otro enlace a #contacto (nav__cta inline, barra CTA inferior):
    // tras el scroll nativo del ancla, mover el foco al primer campo.
    document.addEventListener('click', (e) => {
      const a = (e.target as Element | null)?.closest?.('a[href$="#contacto"]');
      if (!a) return;
      if (drawer.contains(a)) return; // ya manejado arriba (con cierre previo)
      focusContact();
    });

    document.addEventListener('keydown', (e) => {
      if (!drawer.hasAttribute('data-open')) return;
      if (e.key === 'Escape') { close(); return; }
      if (e.key === 'Tab') {
        const f = focusables();
        if (!f.length) return;
        const first = f[0], last = f[f.length - 1];
        if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
        else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    });

    // estado scrolled + barra CTA inferior tras pasar el hero
    const onScroll = () => {
      root.classList.toggle('is-scrolled', window.scrollY > 24);
      const showBar = window.scrollY > 560;
      if (ctabar) ctabar.classList.toggle('is-visible', showBar);
      // señal global para que el FAB del chat suba por encima de la barra (solo móvil)
      document.body.classList.toggle('has-ctabar', showBar);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
