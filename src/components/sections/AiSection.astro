---
// Sección "Tecnología Marcyan" (IA) — 2 columnas:
//  · Izquierda: intro + 4 capacidades (TEXTOS reales de content.ts).
//  · Derecha: demo ILUSTRATIVO de un asistente (burbujas que se escriben solas,
//    typing dots, "lead capturado") + riel de flujo. Es decorativo (aria-hidden):
//    SSR renderiza el estado final → sin JS / reduced-motion se ve completo y quieto;
//    con JS + movimiento permitido, se re-anima en bucle. Acento teal.
import Icon from '../ui/Icon.astro';
import Kicker from '../ui/Kicker.astro';
import Button from '../ui/Button.astro';

interface Props { ai: any }
const { ai } = Astro.props;
const demo = ai.demo;
---
<section class="section ai" id="ia" data-fx="teal">
  <div class="container ai__inner">
    <!-- IZQUIERDA: intro + capacidades -->
    <div class="ai__intro">
      <Kicker tone="teal">{ai.tag}</Kicker>
      <h2 class="h2" set:html={ai.title} />
      <p class="lead">{ai.desc}</p>

      <ul class="ai__caps">
        {ai.features.map((f: any) => (
          <li class="ai__cap">
            <span class="ai__cap-ic"><Icon name={f.icon} /></span>
            <div class="ai__cap-tx">
              <h3>{f.title}</h3>
              <p>{f.desc}</p>
            </div>
          </li>
        ))}
      </ul>

      {ai.cta && (
        <Button href={ai.cta.href} variant="teal" size="md" class="ai__cta">{ai.cta.label}</Button>
      )}
    </div>

    <!-- DERECHA: demo de asistente (ilustrativo, decorativo) -->
    {demo && (
      <div class="ai__demo" data-ai-demo aria-hidden="true">
        <div class="chatwin">
          <div class="chat-bar">
            <span class="chat-av"><Icon name="lucide:bot" /></span>
            <span class="chat-who">
              <b>{demo.title}</b>
              <span class="chat-status"><span class="chat-live"></span>{demo.status}</span>
            </span>
            <span class="chat-lang">{demo.lang}</span>
          </div>

          <div class="chat-body" data-chat-body>
            {demo.messages.map((m: any) => (
              <div class:list={['bub', m.who, 'show']}>
                <span>{m.text}</span>
                {m.who === 'ai' && m.meta && <span class="bub-meta">{m.meta}</span>}
              </div>
            ))}
          </div>

          <div class="lead-toast show" data-lead-toast>
            <span class="lt-ic"><Icon name="lucide:user-check" /></span>
            <span class="lt-tx"><b>{demo.toast.title}</b><span>{demo.toast.sub}</span></span>
          </div>
        </div>

        <div class="ai__flow" data-flow>
          {demo.flow.map((label: string, i: number) => (
            <Fragment>
              {i > 0 && <span class="ai__flow-arr"><Icon name="lucide:chevron-right" /></span>}
              <span class="ai__flow-node lit" data-node>{label}</span>
            </Fragment>
          ))}
        </div>

        <script type="application/json" data-ai-demo-data set:html={JSON.stringify(demo)} />
      </div>
    )}
  </div>
</section>

<style>
  .ai :global(em) { color: var(--accent-teal); font-style: normal; }
  .ai__inner { display: grid; grid-template-columns: 1fr; gap: var(--space-7); align-items: start; }

  /* ── Izquierda: intro + capacidades ─────────────────────── */
  .ai__intro { display: flex; flex-direction: column; gap: var(--space-4); align-items: flex-start; min-width: 0; }
  .ai__caps { list-style: none; display: flex; flex-direction: column; gap: var(--space-4); margin-top: var(--space-2); width: 100%; }
  .ai__cap { display: flex; gap: var(--space-4); align-items: flex-start; min-width: 0; }
  .ai__cap-ic {
    flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center;
    width: 44px; height: 44px; border-radius: var(--radius-md);
    background: var(--accent-teal-dim); border: 1px solid var(--accent-teal-line); color: var(--accent-teal);
  }
  .ai__cap-ic :global(svg) { width: 20px; height: 20px; stroke-width: 1.5; }
  .ai__cap-tx { min-width: 0; }
  .ai__cap-tx h3 { font-family: var(--font-display); font-size: var(--text-md); font-weight: 600; margin-bottom: 2px; }
  .ai__cap-tx p { color: var(--fg-secondary); font-size: var(--text-sm); line-height: var(--leading-normal); }
  .ai__cta { margin-top: var(--space-2); }

  /* ── Derecha: ventana de chat ───────────────────────────── */
  .ai__demo { min-width: 0; display: flex; flex-direction: column; gap: var(--space-4); }
  .chatwin {
    position: relative; display: flex; flex-direction: column; height: 420px;
    background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card); overflow: hidden;
  }
  .chat-bar {
    display: flex; align-items: center; gap: var(--space-3);
    padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, var(--accent-teal-dim), transparent);
  }
  .chat-av {
    flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--accent-teal-dim); border: 1px solid var(--accent-teal-line); color: var(--accent-teal);
  }
  .chat-av :global(svg) { width: 18px; height: 18px; }
  .chat-who { display: flex; flex-direction: column; line-height: 1.25; min-width: 0; flex: 1; }
  .chat-who b { font-family: var(--font-display); font-size: var(--text-sm); font-weight: 600; }
  .chat-status { display: inline-flex; align-items: center; gap: var(--space-2); font-size: var(--text-xs); color: var(--fg-secondary); }
  .chat-live { width: 6px; height: 6px; border-radius: 50%; background: var(--accent-teal); box-shadow: 0 0 0 0 var(--accent-teal); animation: chatlive 2s ease-out infinite; }
  .chat-lang { flex: 0 0 auto; font-family: var(--font-mono); font-size: var(--text-xs); color: var(--fg-subtle); letter-spacing: var(--tracking-wide); }

  .chat-body {
    flex: 1; min-height: 0; display: flex; flex-direction: column; justify-content: flex-end;
    gap: var(--space-3); padding: var(--space-4); overflow: hidden;
  }
  /* Las burbujas y el "typing" las crea el JS dinámicamente → no reciben el atributo
     de scope de Astro. Sus estilos viven en el <style is:global> de abajo (scopeados
     a .ai__demo a mano). Aquí solo quedan los elementos renderizados por Astro. */

  .lead-toast {
    display: flex; align-items: center; gap: var(--space-3);
    margin: 0 var(--space-4) var(--space-4); padding: var(--space-3) var(--space-4);
    background: var(--accent-teal-dim); border: 1px solid var(--accent-teal-line); border-radius: var(--radius-md);
    opacity: 0; transform: translateY(8px);
    transition: opacity 0.4s var(--ease-out-expo), transform 0.4s var(--ease-out-expo);
  }
  .lead-toast.show { opacity: 1; transform: none; }
  .lt-ic {
    flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center;
    width: 34px; height: 34px; border-radius: 50%; background: var(--accent-teal); color: var(--fg-inverse);
  }
  .lt-ic :global(svg) { width: 18px; height: 18px; }
  .lt-tx { display: flex; flex-direction: column; line-height: 1.3; min-width: 0; }
  .lt-tx b { font-size: var(--text-sm); font-weight: 600; }
  .lt-tx span { font-size: var(--text-xs); color: var(--fg-secondary); }

  /* riel de flujo */
  .ai__flow { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-2); }
  .ai__flow-node {
    font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide);
    padding: var(--space-1) var(--space-3); border-radius: var(--radius-pill);
    border: 1px solid var(--border); color: var(--fg-subtle); background: var(--bg-card);
    transition: color 0.35s var(--ease-out-expo), border-color 0.35s var(--ease-out-expo), background 0.35s var(--ease-out-expo);
  }
  .ai__flow-node.lit { color: var(--accent-teal); border-color: var(--accent-teal-line); background: var(--accent-teal-dim); }
  .ai__flow-arr { display: inline-flex; color: var(--fg-subtle); }
  .ai__flow-arr :global(svg) { width: 14px; height: 14px; }

  @keyframes chatlive { 0% { box-shadow: 0 0 0 0 var(--accent-teal); } 70% { box-shadow: 0 0 0 5px transparent; } 100% { box-shadow: 0 0 0 0 transparent; } }
  @media (--motion-reduce) { .chat-live, .typing i { animation: none; } }

  @media (--lg) {
    .ai__inner { grid-template-columns: 1.05fr 0.95fr; gap: var(--space-9); align-items: center; }
  }
</style>

<style is:global>
  /* Burbujas y "typing" del demo. GLOBAL (scopeado a .ai__demo a mano) porque el JS
     las inyecta dinámicamente y no llevan el atributo data-astro-cid del scope. */
  .ai__demo .bub {
    max-width: 84%; padding: var(--space-3) var(--space-4); border-radius: 14px;
    font-size: var(--text-sm); line-height: var(--leading-normal);
    opacity: 0; transform: translateY(6px);
    transition: opacity 0.3s var(--ease-out-expo), transform 0.3s var(--ease-out-expo);
  }
  .ai__demo .bub.show { opacity: 1; transform: none; }
  .ai__demo .bub.user { align-self: flex-end; background: var(--accent-teal); color: var(--fg-inverse); border-bottom-right-radius: 4px; }
  .ai__demo .bub.ai { align-self: flex-start; background: var(--bg-elevated); border: 1px solid var(--border); color: var(--fg-primary); border-bottom-left-radius: 4px; }
  .ai__demo .bub-meta { display: block; margin-top: var(--space-1); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--accent-teal); }

  .ai__demo .typing {
    align-self: flex-start; display: inline-flex; gap: 4px;
    padding: var(--space-3) var(--space-4); background: var(--bg-elevated); border: 1px solid var(--border);
    border-radius: 14px; border-bottom-left-radius: 4px; opacity: 0; transition: opacity 0.3s;
  }
  .ai__demo .typing.show { opacity: 1; }
  .ai__demo .typing i { width: 6px; height: 6px; border-radius: 50%; background: var(--fg-subtle); animation: mc-typedot 1.2s infinite ease-in-out; }
  .ai__demo .typing i:nth-child(2) { animation-delay: 0.15s; }
  .ai__demo .typing i:nth-child(3) { animation-delay: 0.3s; }
  @keyframes mc-typedot { 0%, 60%, 100% { transform: translateY(0); opacity: 0.4; } 30% { transform: translateY(-4px); opacity: 1; } }
  @media (prefers-reduced-motion: reduce) { .ai__demo .typing i { animation: none; } }
</style>

<script>
  const demoEl = document.querySelector('[data-ai-demo]') as HTMLElement | null;
  const dataEl = document.querySelector('[data-ai-demo-data]') as HTMLElement | null;
  if (demoEl && dataEl) {
    const REDUCE = matchMedia('(prefers-reduced-motion: reduce)').matches;
    let demo: any = null;
    try { demo = JSON.parse(dataEl.textContent || 'null'); } catch (_) { /* deja el estado SSR */ }

    const body = demoEl.querySelector('[data-chat-body]') as HTMLElement;
    const toast = demoEl.querySelector('[data-lead-toast]') as HTMLElement;
    const nodes = Array.from(demoEl.querySelectorAll<HTMLElement>('[data-node]'));
    const wait = (ms: number) => new Promise((r) => setTimeout(r, ms));
    let running = false;

    function clearChat() {
      body.innerHTML = '';
      toast.classList.remove('show');
      nodes.forEach((n) => n.classList.remove('lit'));
    }
    function addBubble(m: any) {
      return new Promise<void>((res) => {
        if (m.who === 'ai') {
          const t = document.createElement('div');
          t.className = 'typing';
          t.innerHTML = '<i></i><i></i><i></i>';
          body.appendChild(t);
          requestAnimationFrame(() => t.classList.add('show'));
          setTimeout(() => {
            t.remove();
            const b = document.createElement('div');
            b.className = 'bub ai';
            const sp = document.createElement('span'); sp.textContent = m.text; b.appendChild(sp);
            if (m.meta) { const mt = document.createElement('span'); mt.className = 'bub-meta'; mt.textContent = m.meta; b.appendChild(mt); }
            body.appendChild(b);
            requestAnimationFrame(() => b.classList.add('show'));
            res();
          }, 1100);
        } else {
          const b = document.createElement('div');
          b.className = 'bub user';
          const sp = document.createElement('span'); sp.textContent = m.text; b.appendChild(sp);
          body.appendChild(b);
          requestAnimationFrame(() => b.classList.add('show'));
          setTimeout(res, 520);
        }
      });
    }
    async function run() {
      if (running || !demo) return;
      running = true;
      while (true) {
        clearChat();
        nodes[0]?.classList.add('lit');
        await wait(420);
        for (let i = 0; i < demo.messages.length; i++) {
          await addBubble(demo.messages[i]);
          await wait(420);
          if (demo.messages[i].who === 'ai') nodes[1]?.classList.add('lit');
        }
        await wait(420);
        nodes[2]?.classList.add('lit');
        toast.classList.add('show');
        await wait(900);
        nodes[3]?.classList.add('lit');
        await wait(4400);
      }
    }

    if (!REDUCE) {
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => { if (e.isIntersecting) { run(); io.disconnect(); } });
        }, { rootMargin: '0px 0px -120px 0px' });
        io.observe(demoEl);
      } else {
        run();
      }
    }
    // reduced-motion: se conserva el estado SSR (conversación completa + lead + nodos encendidos)
  }
</script>
