---
// Índice "En esta guía" — TOC colapsable de los H2 del artículo (solo si hay ≥3).
// Las anclas usan el slug que Astro genera para cada heading (rehype-slug);
// el cuerpo del artículo ya tiene scroll-margin-top para que el salto respire.
interface Heading { depth: number; slug: string; text: string }
interface Props { headings: Heading[]; label: string }
const { headings, label } = Astro.props;
const items = headings.filter((h) => h.depth === 2);
---
{items.length >= 3 && (
  <div class="toc-wrap">
    <div class="container">
      <details class="toc">
        <summary class="toc__sum">{label}<span class="toc__chev" aria-hidden="true"></span></summary>
        <ol class="toc__list">
          {items.map((h, i) => (
            <li>
              <a href={`#${h.slug}`}><span class="toc__n">{String(i + 1).padStart(2, '0')}</span><span>{h.text}</span></a>
            </li>
          ))}
        </ol>
      </details>
    </div>
  </div>
)}

<style>
  .toc-wrap { margin-block: var(--space-6); }
  .toc {
    max-width: 72ch; margin-inline: auto;
    background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg);
    padding: var(--space-4) var(--space-5);
  }
  .toc__sum {
    cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: space-between;
    font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide);
    text-transform: uppercase; color: var(--accent-gold); min-height: var(--tap-min);
  }
  .toc__sum::-webkit-details-marker { display: none; }
  .toc__chev {
    width: 8px; height: 8px; flex: 0 0 auto;
    border-right: 1.5px solid currentColor; border-bottom: 1.5px solid currentColor;
    transform: rotate(45deg); transition: transform var(--duration-fast);
  }
  .toc[open] .toc__chev { transform: rotate(-135deg); }
  .toc__list {
    list-style: none; display: flex; flex-direction: column; gap: var(--space-1);
    margin-top: var(--space-3); padding-top: var(--space-3); border-top: 1px solid var(--border-subtle);
  }
  .toc__list a {
    display: flex; align-items: baseline; gap: var(--space-3); min-height: var(--tap-min);
    color: var(--fg-secondary); font-size: var(--text-sm); line-height: var(--leading-snug);
    transition: color var(--duration-fast);
  }
  .toc__list a:hover { color: var(--accent-gold); }
  .toc__n { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--fg-subtle); flex: 0 0 auto; }
  @media (--motion-reduce) { .toc__chev { transition: none; } }
</style>
