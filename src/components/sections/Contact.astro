---
// Sección Contacto — form real que envía a /api/brief (mismo pipeline que /formulario).
// Mapeo de campos idéntico al del sitio anterior: owner_name · email · business_name ·
// city_state · main_objective · additional_notes (+ honeypot website_hp).
import Icon from '../ui/Icon.astro';
import Kicker from '../ui/Kicker.astro';
import Button from '../ui/Button.astro';
import { nap } from '../../i18n/content';

interface Props { contact: any }
const { contact } = Astro.props;
const f = contact.form;
const telHou = nap.houston.replace(/[^\d+]/g, '');
const telMia = nap.miami.replace(/[^\d+]/g, '');
---
<section class="section contact" id="contacto" data-fx="gold">
  <div class="container contact__inner">
    <div class="contact__intro">
      <Kicker>{contact.tag}</Kicker>
      <h2 class="h2" set:html={contact.title} />
      <p class="lead">{contact.desc}</p>
    </div>

    <form
      class="contact__form" id="home-contact-form" novalidate
      data-sending={f.sending} data-success={f.success} data-error={f.error} data-invalid={f.emailInvalid}
    >
      <input type="text" name="website_hp" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />

      <div class="field-row">
        <label class="field">
          <span class="field__lbl">{f.name.label}</span>
          <input type="text" name="owner_name" placeholder={f.name.ph} autocomplete="name" />
        </label>
        <label class="field">
          <span class="field__lbl">{f.email.label}</span>
          <input type="email" name="email" placeholder={f.email.ph} autocomplete="email" required />
        </label>
      </div>

      <div class="field-row">
        <label class="field">
          <span class="field__lbl">{f.company.label}</span>
          <input type="text" name="business_name" placeholder={f.company.ph} autocomplete="organization" />
        </label>
        <label class="field">
          <span class="field__lbl">{f.city.label}</span>
          <select name="city_state">
            <option value="">{f.city.ph}</option>
            {f.city.opts.map((o: string) => <option value={o}>{o}</option>)}
          </select>
        </label>
      </div>

      <label class="field">
        <span class="field__lbl">{f.service.label}</span>
        <select name="main_objective">
          <option value="">{f.service.ph}</option>
          {f.service.opts.map((o: string) => <option value={o}>{o}</option>)}
        </select>
      </label>

      <label class="field">
        <span class="field__lbl">{f.message.label}</span>
        <textarea name="additional_notes" rows="4" placeholder={f.message.ph}></textarea>
      </label>

      <Button type="submit" variant="primary" size="lg" class="u-full" data-submit>{f.submit}</Button>

      <p class="form-status form-status--error" id="home-form-error" role="alert" hidden></p>
      <p class="form-status form-status--ok" id="home-form-success" role="status" hidden></p>
    </form>

    <ul class="contact__info">
      <li>
        <span class="contact__info-ic"><Icon name="lucide:mail" /></span>
        <a href={`mailto:${nap.email}`}>{nap.email}</a>
      </li>
      <li>
        <span class="contact__info-ic"><Icon name="lucide:phone" /></span>
        <span><span class="contact__info-lbl">Houston</span> <a href={`tel:${telHou}`}>{nap.houston}</a></span>
      </li>
      <li>
        <span class="contact__info-ic"><Icon name="lucide:phone" /></span>
        <span><span class="contact__info-lbl">Miami</span> <a href={`tel:${telMia}`}>{nap.miami}</a></span>
      </li>
      <li>
        <span class="contact__info-ic"><Icon name="lucide:clock" /></span>
        <span><span class="contact__info-lbl">{contact.info.hoursLbl}</span> {contact.info.hours}</span>
      </li>
    </ul>
  </div>
</section>

<style>
  .contact :global(em) { color: var(--accent-gold); font-style: normal; }
  .contact__inner { display: grid; grid-template-columns: 1fr; gap: var(--space-8); }
  .contact__intro { display: flex; flex-direction: column; gap: var(--space-4); }

  .contact__info { list-style: none; display: flex; flex-direction: column; gap: var(--space-3); margin-top: var(--space-3); }
  .contact__info li { display: flex; align-items: center; gap: var(--space-3); min-width: 0; }
  .contact__info-ic {
    flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center;
    width: 38px; height: 38px; border-radius: var(--radius-md);
    background: var(--bg-card); border: 1px solid var(--border); color: var(--accent-gold);
  }
  .contact__info-ic :global(svg) { width: 18px; height: 18px; stroke-width: 1.5; }
  .contact__info a { color: var(--fg-primary); font-size: var(--text-sm); overflow-wrap: anywhere; }
  .contact__info a:hover { color: var(--accent-gold); }
  .contact__info-lbl { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--fg-subtle); text-transform: uppercase; letter-spacing: var(--tracking-wide); margin-right: var(--space-1); }

  .contact__form {
    display: flex; flex-direction: column; gap: var(--space-4);
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: var(--space-6); min-width: 0;
  }
  .hp { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }
  .field-row { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  .field { display: flex; flex-direction: column; gap: var(--space-2); min-width: 0; }
  .field__lbl { font-family: var(--font-body); font-size: var(--text-xs); font-weight: 600; letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--fg-secondary); }
  .field input, .field select, .field textarea {
    width: 100%; min-width: 0; min-height: var(--tap-min);
    background: var(--bg-elevated); border: 1px solid var(--border); border-radius: var(--radius-md);
    color: var(--fg-primary); font-family: var(--font-body); font-size: var(--text-base);
    padding: 11px 14px; transition: border-color var(--duration-fast), box-shadow var(--duration-fast);
  }
  .field textarea { resize: vertical; min-height: 110px; }
  .field input::placeholder, .field textarea::placeholder { color: var(--fg-subtle); }
  .field select { appearance: none; cursor: pointer; }
  .field input:focus, .field select:focus, .field textarea:focus {
    outline: none; border-color: var(--accent-gold); box-shadow: 0 0 0 3px var(--accent-gold-dim);
  }

  .form-status { font-size: var(--text-sm); padding: var(--space-3) var(--space-4); border-radius: var(--radius-md); }
  .form-status--error { background: rgba(224, 92, 92, 0.12); border: 1px solid rgba(224, 92, 92, 0.3); color: #e07a7a; }
  .form-status--ok { background: var(--accent-teal-dim); border: 1px solid var(--accent-teal-line); color: var(--accent-teal); }

  @media (--sm) { .field-row { grid-template-columns: 1fr 1fr; } }
  @media (--lg) {
    /* izquierda: intro + info · derecha: formulario (abarca ambas filas) */
    .contact__inner { grid-template-columns: 0.9fr 1.1fr; gap: var(--space-7) var(--space-9); align-items: start; }
    .contact__intro { grid-column: 1; grid-row: 1; }
    .contact__info  { grid-column: 1; grid-row: 2; }
    .contact__form  { grid-column: 2; grid-row: 1 / span 2; }
  }
</style>

<script>
  const form = document.getElementById('home-contact-form') as HTMLFormElement | null;
  if (form) {
    const btn = form.querySelector('[data-submit]') as HTMLButtonElement;
    const errorBox = document.getElementById('home-form-error') as HTMLElement;
    const okBox = document.getElementById('home-form-success') as HTMLElement;
    const S = form.dataset;
    const isEmail = (v: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorBox.hidden = true; okBox.hidden = true;
      const emailEl = form.querySelector('[name="email"]') as HTMLInputElement | null;
      emailEl?.removeAttribute('aria-invalid');

      const fd = new FormData(form);
      const data: Record<string, string> = {};
      for (const [k, v] of fd.entries()) data[k] = typeof v === 'string' ? v.trim() : '';

      if (data.website_hp) return; // honeypot
      if (!isEmail(data.email || '')) {
        errorBox.textContent = S.invalid || 'Email inválido.'; errorBox.hidden = false;
        if (emailEl) { emailEl.setAttribute('aria-invalid', 'true'); emailEl.setAttribute('aria-describedby', 'home-form-error'); emailEl.focus(); }
        return;
      }

      const orig = btn.textContent;
      btn.disabled = true; btn.textContent = S.sending || 'Enviando…';
      try {
        const res = await fetch('/api/contact', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data),
        });
        let payload: any = null;
        try { payload = await res.json(); } catch (_) { /* ignore */ }

        if (!res.ok || !payload || !payload.ok) {
          errorBox.textContent = (payload && payload.error) || S.error || 'Error.';
          errorBox.hidden = false; btn.disabled = false; btn.textContent = orig;
          return;
        }
        okBox.textContent = (S.success || '✓') + (payload.refId ? ' · ' + payload.refId : '');
        okBox.hidden = false;
        form.querySelectorAll('input, select, textarea, button').forEach((el) => ((el as HTMLInputElement).disabled = true));
        btn.textContent = S.success || '✓';
      } catch (err) {
        errorBox.textContent = S.error || 'Error de red.';
        errorBox.hidden = false; btn.disabled = false; btn.textContent = orig;
      }
    });
  }
</script>
