---
// HERO de la home.
//  · SSR / fallback (siempre): titular + CTAs + nodos "lunas" como <a> reales (chips).
//    Funciona sin JS, en móvil, y con prefers-reduced-motion.
//  · Realce (solo desktop + hover + motion-ok): motor planetario 2.5D — los mismos
//    enlaces orbitan el planeta con proyección isométrica, parallax con cursor y
//    energía al pasar el cursor. Sin Three.js: SVG + DOM + CSS + requestAnimationFrame.
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';
import Card from '../ui/Card.astro';

interface Props { hero: any }
const { hero } = Astro.props;
const uid = 'hero' + Math.random().toString(36).slice(2, 7);
---
<section class="hero" id="top" data-hero>
  <div class="hero__bg" aria-hidden="true"></div>

  <div class="container hero__inner">
    <div class="hero__text">
      <Badge variant="teal" class="hero__tag">{hero.tag}</Badge>
      <h1 class="display hero__h1" set:html={hero.h1} />
      <p class="lead hero__sub">{hero.sub}</p>
      <div class="hero__cta">
        <Button href={hero.primary.href} variant="primary" size="lg">{hero.primary.label}</Button>
        <Button href={hero.secondary.href} variant="secondary" size="lg">{hero.secondary.label}</Button>
      </div>
      <nav class="hero__moons" aria-label="Explorar el sitio" data-hero-moons>
        {hero.nodes.map((n: any, i: number) => (
          <a class="moon" href={n.href} data-accent={i % 2 ? 'teal' : 'gold'}>
            <span class="moon__dot" aria-hidden="true"></span>{n.label}
          </a>
        ))}
      </nav>
    </div>

    <div class="hero__visual" data-hero-visual>
      <div class="hero__stage" data-hero-stage>
        <svg viewBox="0 0 400 400" role="img" aria-label="Marcyan — planeta en órbita" class="hero__svg">
          <defs>
            <radialGradient id={`${uid}-p`} cx="44%" cy="36%" r="60%">
              <stop offset="0%" stop-color="var(--accent-gold)" />
              <stop offset="52%" stop-color="var(--accent-gold-deep)" />
              <stop offset="100%" stop-color="var(--planet-core)" />
            </radialGradient>
            <radialGradient id={`${uid}-g`} cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="var(--accent-gold)" stop-opacity="0.20" />
              <stop offset="100%" stop-color="var(--accent-gold)" stop-opacity="0" />
            </radialGradient>
            <clipPath id={`${uid}-c`}><circle cx="200" cy="200" r="110" /></clipPath>
          </defs>
          <circle cx="200" cy="200" r="180" fill={`url(#${uid}-g)`} />
          <ellipse cx="200" cy="200" rx="186" ry="58" fill="none" stroke="var(--accent-gold)" stroke-width="1" stroke-opacity="0.14" transform="rotate(-18 200 200)" />
          <ellipse cx="200" cy="200" rx="150" ry="44" fill="none" stroke="var(--accent-teal)" stroke-width="1" stroke-opacity="0.12" transform="rotate(-18 200 200)" />
          <circle cx="64" cy="116" r="1.6" fill="var(--fg-primary)" opacity="0.5" />
          <circle cx="348" cy="290" r="1.3" fill="var(--fg-primary)" opacity="0.4" />
          <circle cx="316" cy="92" r="1.8" fill="var(--accent-gold)" opacity="0.5" />
          {/* órbita principal · mitad trasera */}
          <path d="M28.8 245.6 A180 52 -18 0 0 371.2 154.4" fill="none" stroke="var(--accent-gold)" stroke-width="2" stroke-opacity="0.32" stroke-linecap="round" />
          {/* planeta */}
          <circle cx="200" cy="200" r="110" fill={`url(#${uid}-p)`} />
          <ellipse cx="226" cy="210" rx="102" ry="102" fill="rgba(0,0,0,0.42)" clip-path={`url(#${uid}-c)`} />
          {/* órbita principal · mitad delantera */}
          <path d="M28.8 245.6 A180 52 -18 0 1 371.2 154.4" fill="none" stroke="var(--accent-gold)" stroke-width="2.4" stroke-opacity="0.9" stroke-linecap="round" />
          {/* satélite = IA */}
          <circle cx="371.2" cy="154.4" r="8" fill="var(--accent-teal)" />
        </svg>
        <div class="hero__orbit" data-hero-orbit aria-hidden="true"></div>
      </div>

      <Card class="hero__caso0">
        <span class="hero__caso0-label">
          <span class="hero__live" aria-hidden="true"></span>{hero.caso0.label}
        </span>
        <ul class="hero__caso0-rows">
          {hero.caso0.rows.map((r: any) => (
            <li><span class="hero__caso0-l">{r.l}</span><span class="hero__caso0-v">{r.v}</span></li>
          ))}
        </ul>
      </Card>
    </div>
  </div>
</section>

<style>
  .hero { position: relative; padding-top: calc(var(--nav-h) + var(--space-7)); padding-bottom: var(--space-9); overflow: clip; }
  .hero__bg {
    position: absolute; inset: 0; z-index: -1; pointer-events: none;
    background: radial-gradient(60% 50% at 70% 28%, var(--accent-gold-dim), transparent 70%);
  }
  .hero__inner { display: grid; grid-template-columns: 1fr; gap: var(--space-8); align-items: center; }

  .hero__text { display: flex; flex-direction: column; align-items: flex-start; gap: var(--space-5); min-width: 0; }
  .hero__h1 { margin-top: var(--space-1); }
  .hero__h1 :global(em) { color: var(--accent-gold); font-style: normal; }
  .hero__sub { max-width: 52ch; }
  .hero__cta { display: flex; flex-wrap: wrap; gap: var(--space-3); }

  .hero__moons { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-top: var(--space-2); }
  .moon {
    display: inline-flex; align-items: center; gap: var(--space-2);
    min-height: 38px; padding: 7px 14px; border-radius: var(--radius-pill);
    border: 1px solid var(--border); background: var(--bg-card);
    font-size: var(--text-sm); color: var(--fg-secondary);
    transition: border-color var(--duration-fast), color var(--duration-fast);
  }
  .moon__dot { width: 7px; height: 7px; border-radius: 50%; background: var(--accent-teal); flex: 0 0 auto; }
  .moon[data-accent="gold"] .moon__dot { background: var(--accent-gold); }
  .moon:hover { border-color: var(--border-accent); color: var(--fg-primary); }

  .hero__visual { display: flex; flex-direction: column; align-items: center; gap: var(--space-5); min-width: 0; }
  .hero__stage { position: relative; width: 100%; max-width: 440px; aspect-ratio: 1 / 1; margin-inline: auto; }
  .hero__svg { position: absolute; inset: 0; width: 100%; height: 100%; display: block; overflow: visible; }
  .hero__orbit { position: absolute; inset: 0; z-index: 3; }

  /* Los nodos/partículas orbitales se inyectan por JS → sus estilos van en un bloque
     is:global más abajo (el CSS scopeado no alcanza elementos creados en runtime). */
  .hero--orbital .hero__moons { display: none; }

  .hero__caso0 { width: 100%; max-width: 360px; padding: var(--space-5); }
  .hero__caso0-label {
    display: flex; align-items: center; gap: var(--space-2);
    font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide);
    text-transform: uppercase; color: var(--fg-secondary); margin-bottom: var(--space-4);
  }
  .hero__live { width: 8px; height: 8px; border-radius: 50%; background: var(--accent-teal); animation: pulse 2.4s var(--ease-out-expo) infinite; }
  .hero__caso0-rows { list-style: none; display: flex; flex-direction: column; gap: var(--space-3); }
  .hero__caso0-rows li { display: flex; align-items: baseline; justify-content: space-between; gap: var(--space-4); border-bottom: 1px solid var(--border-subtle); padding-bottom: var(--space-2); }
  .hero__caso0-rows li:last-child { border-bottom: 0; padding-bottom: 0; }
  .hero__caso0-l { color: var(--fg-secondary); font-size: var(--text-sm); }
  .hero__caso0-v { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--accent-gold); }

  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 var(--accent-teal-dim); }
    70% { box-shadow: 0 0 0 8px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }
  @media (--motion-reduce) { .hero__live { animation: none; } }

  @media (--lg) {
    .hero { padding-top: calc(var(--nav-h) + var(--space-9)); padding-bottom: var(--space-10); min-height: 92svh; }
    .hero__inner { grid-template-columns: 1.05fr 0.95fr; gap: var(--space-9); }
    .hero__visual { align-items: flex-end; }
    .hero__stage { max-width: 480px; }
    .hero__caso0 { align-self: flex-end; }
  }
</style>

<!-- Estilos de los cuerpos orbitales (inyectados por JS, por eso is:global, namespaced bajo .hero__orbit) -->
<style is:global>
  .hero__orbit .hero-node {
    position: absolute; left: 0; top: 0; display: inline-flex; align-items: center; gap: 8px;
    padding: 7px 14px 7px 11px; border-radius: var(--radius-pill); white-space: nowrap; text-decoration: none;
    background: rgba(18, 18, 18, 0.85); -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px);
    border: 1px solid var(--accent-gold-line); color: var(--fg-primary);
    font-family: var(--font-body); font-size: var(--text-sm); font-weight: 600; line-height: 1;
    box-shadow: 0 8px 26px rgba(0, 0, 0, 0.5); opacity: 0; will-change: transform, opacity;
    transition: border-color var(--duration-fast), box-shadow var(--duration-fast);
  }
  .hero__orbit .hero-node.teal { border-color: var(--accent-teal-line); }
  .hero__orbit .hero-node__dot { width: 7px; height: 7px; border-radius: 50%; background: var(--accent-gold); flex: 0 0 auto; }
  .hero__orbit .hero-node.teal .hero-node__dot { background: var(--accent-teal); }
  .hero__orbit .hero-node:hover { border-color: var(--accent-gold); box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6), 0 0 0 4px var(--accent-gold-dim); }
  .hero__orbit .hero-node.teal:hover { border-color: var(--accent-teal); box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6), 0 0 0 4px var(--accent-teal-dim); }
  .hero__orbit .hero-amb {
    position: absolute; left: 0; top: 0; width: 5px; height: 5px; border-radius: 50%;
    background: var(--accent-gold); box-shadow: 0 0 8px var(--accent-gold);
    opacity: 0; pointer-events: none; will-change: transform, opacity;
  }
</style>

<script>
  // Motor planetario — realce progresivo. Solo se activa en desktop con puntero fino
  // y sin prefers-reduced-motion. En cualquier otro caso, los chips estáticos quedan.
  const hero = document.querySelector('[data-hero]') as HTMLElement | null;
  if (hero) {
    const stage = hero.querySelector('[data-hero-stage]') as HTMLElement;
    const orbit = hero.querySelector('[data-hero-orbit]') as HTMLElement;
    const visual = hero.querySelector('[data-hero-visual]') as HTMLElement;
    const moons = hero.querySelector('[data-hero-moons]') as HTMLElement;

    const mqOrbital = window.matchMedia('(min-width: 1024px) and (hover: hover) and (pointer: fine)');
    const mqReduce = window.matchMedia('(prefers-reduced-motion: reduce)');

    const ROLL = -18 * Math.PI / 180, COS = Math.cos(ROLL), SIN = Math.sin(ROLL), FLATTEN = 0.42;
    let bodies: any[] = [];
    let cx = 0, cy = 0, maxR = 0;
    let energy = 0.7, target = 0.7;
    let tiltX = 0, tiltY = 0, tTiltX = 0, tTiltY = 0;
    let rafId = 0, last = 0, running = false;
    let ro: ResizeObserver | null = null;

    function measure() {
      const r = stage.getBoundingClientRect();
      cx = r.width / 2; cy = r.height / 2;
      maxR = Math.min(r.width, r.height) * 0.5;
    }
    function project(R: number, ang: number) {
      const ux = Math.cos(ang) * R, uy = Math.sin(ang) * R * FLATTEN;
      return { x: cx + (ux * COS - uy * SIN), y: cy + (ux * SIN + uy * COS), depth: Math.sin(ang) };
    }
    function build() {
      const links = Array.from(moons.querySelectorAll('a'));
      orbit.innerHTML = '';
      bodies = [];
      const n = links.length;
      links.forEach((a, idx) => {
        const teal = a.getAttribute('data-accent') === 'teal';
        const el = document.createElement('a');
        el.className = 'hero-node' + (teal ? ' teal' : '');
        el.href = a.getAttribute('href') || '#';
        el.innerHTML = `<span class="hero-node__dot"></span><span>${a.textContent!.trim()}</span>`;
        orbit.appendChild(el);
        bodies.push({ el, R: 0.74 + 0.18 * (idx % 2), ang: (idx / n) * Math.PI * 2 + 0.3, speed: 0.05 + 0.012 * (idx % 3), node: true });
      });
      for (let i = 0; i < 6; i++) {
        const el = document.createElement('span');
        el.className = 'hero-amb';
        orbit.appendChild(el);
        bodies.push({ el, R: 0.5 + 0.5 * (i / 6), ang: (i / 6) * Math.PI * 2, speed: 0.06 + 0.02 * (i % 3), sz: 0.6 + 0.7 * ((i % 3) / 3) });
      }
    }
    function frame(now: number) {
      const dt = Math.min(0.05, (now - last) / 1000); last = now;
      energy += (target - energy) * Math.min(1, dt * 5);
      tiltX += (tTiltX - tiltX) * Math.min(1, dt * 4);
      tiltY += (tTiltY - tiltY) * Math.min(1, dt * 4);
      stage.style.transform = `perspective(1200px) rotateX(${tiltX}deg) rotateY(${tiltY}deg)`;
      for (const b of bodies) {
        b.ang += b.speed * dt * (0.5 + 0.7 * energy);
        const p = project(b.R * maxR, b.ang);
        const front = (p.depth + 1) / 2;
        if (b.node) {
          const sc = 0.85 + 0.15 * p.depth;
          b.el.style.transform = `translate(-50%,-50%) translate(${p.x}px,${p.y}px) scale(${sc})`;
          b.el.style.opacity = (0.25 + 0.75 * front).toFixed(3);
          b.el.style.zIndex = p.depth > 0 ? '6' : '1';
          b.el.style.pointerEvents = p.depth > -0.35 ? 'auto' : 'none';
        } else {
          b.el.style.transform = `translate(-50%,-50%) translate(${p.x}px,${p.y}px) scale(${b.sz})`;
          b.el.style.opacity = (0.25 + 0.45 * front).toFixed(3);
          b.el.style.zIndex = p.depth > 0 ? '5' : '0';
        }
      }
      rafId = requestAnimationFrame(frame);
    }

    const onEnter = () => { target = 1; };
    const onLeave = () => { target = 0.7; };
    const onMove = (e: PointerEvent) => {
      const r = hero.getBoundingClientRect();
      const nx = (e.clientX - r.left) / r.width - 0.5;
      const ny = (e.clientY - r.top) / r.height - 0.5;
      tTiltY = nx * 6; tTiltX = -ny * 4;
    };

    function enable() {
      if (running) return;
      running = true;
      hero.classList.add('hero--orbital');
      measure(); build();
      visual.addEventListener('pointerenter', onEnter);
      visual.addEventListener('pointerleave', onLeave);
      hero.addEventListener('pointermove', onMove);
      // re-mide en cuanto el stage tiene su tamaño real (y ante cualquier cambio)
      ro = new ResizeObserver(() => measure());
      ro.observe(stage);
      if (document.fonts && document.fonts.ready) document.fonts.ready.then(() => { if (running) measure(); });
      last = performance.now();
      rafId = requestAnimationFrame(frame);
    }
    function disable() {
      if (!running) return;
      running = false;
      cancelAnimationFrame(rafId);
      hero.classList.remove('hero--orbital');
      orbit.innerHTML = '';
      stage.style.transform = '';
      visual.removeEventListener('pointerenter', onEnter);
      visual.removeEventListener('pointerleave', onLeave);
      hero.removeEventListener('pointermove', onMove);
      if (ro) { ro.disconnect(); ro = null; }
    }
    function sync() {
      if (mqOrbital.matches && !mqReduce.matches) enable();
      else disable();
    }
    mqOrbital.addEventListener('change', sync);
    mqReduce.addEventListener('change', sync);
    sync();
  }
</script>
