---
// HERO de la home — acercado a la muestra (Hero PC Marcyan).
//  · SSR / fallback (siempre): titular + nodos "lunas" como <a> reales (chips) + CTA.
//    Funciona sin JS, en móvil y con prefers-reduced-motion.
//  · Realce: motor planetario 2.5D (SVG + DOM + CSS + rAF, sin WebGL).
//      Escritorio (puntero fino): arranca CALMO → el hover energiza el sistema (rápido y
//        natural); los nodos se iluminan al pasar el cursor y una luz sutil sigue el mouse
//        recorriendo el camino. El titular cede foco y el "Caso 0" se escribe abajo-dcha.
//      Táctil / móvil: el planeta es el MAPA DE NAVEGACIÓN, pero NO orbita hasta el primer
//        toque (calmo con pista "Toca para explorar"). Sin parallax. Resize NO reinicia.
import Kicker from '../ui/Kicker.astro';
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';

interface Props { hero: any }
const { hero } = Astro.props;
const uid = 'hero' + Math.random().toString(36).slice(2, 7);
---
<section class="hero" id="top" data-hero>
  <div class="hero__stars" data-hero-stars aria-hidden="true"></div>

  <div class="container hero__inner">
    <div class="hero__headline" data-hero-headline>
      <Kicker>{hero.tag}</Kicker>
      <h1 class="display hero__h1" set:html={hero.h1} />
      <p class="lead hero__sub">{hero.sub}</p>
      <nav class="hero__moons" aria-label="Explorar el sitio" data-hero-moons>
        {hero.nodes.map((n: any, i: number) => (
          <a class="moon" href={n.href} data-accent={i % 2 ? 'teal' : 'gold'}>
            {n.icon ? <Icon name={n.icon} class="moon__icon" /> : <span class="moon__dot" aria-hidden="true"></span>}
            <span>{n.label}</span>
          </a>
        ))}
      </nav>
    </div>

    <div class="hero__stage" data-hero-stage>
      <div class="hero__cursorlight" data-hero-cursorlight aria-hidden="true"></div>
      <svg viewBox="0 0 400 400" role="img" aria-label="Marcyan — planeta en órbita" class="hero__svg">
        <defs>
          <radialGradient id={`${uid}-p`} cx="44%" cy="36%" r="62%">
            <stop offset="0%" stop-color="var(--accent-gold)" />
            <stop offset="52%" stop-color="var(--accent-gold-deep)" />
            <stop offset="100%" stop-color="var(--planet-core)" />
          </radialGradient>
          <radialGradient id={`${uid}-g`} cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="var(--accent-gold)" stop-opacity="0.22" />
            <stop offset="100%" stop-color="var(--accent-gold)" stop-opacity="0" />
          </radialGradient>
          <clipPath id={`${uid}-c`}><circle cx="200" cy="200" r="110" /></clipPath>
        </defs>
        <circle cx="200" cy="200" r="190" fill={`url(#${uid}-g)`} />
        {/* órbita · mitad trasera */}
        <path d="M28.8 255.6 A180 52 -18 0 0 371.2 144.4" fill="none" stroke="var(--accent-gold)" stroke-width="1.6" stroke-opacity="0.30" stroke-linecap="round" />
        {/* planeta */}
        <circle cx="200" cy="200" r="110" fill={`url(#${uid}-p)`} />
        <ellipse cx="222" cy="212" rx="100" ry="100" fill="rgba(0,0,0,0.42)" clip-path={`url(#${uid}-c)`} />
        {/* órbita · mitad delantera */}
        <path d="M28.8 255.6 A180 52 -18 0 1 371.2 144.4" fill="none" stroke="var(--accent-gold)" stroke-width="2.2" stroke-opacity="0.88" stroke-linecap="round" />
        {/* satélite = IA */}
        <circle cx="371" cy="144" r="8" fill="var(--accent-teal)" />
      </svg>
      <div class="hero__orbit" data-hero-orbit aria-hidden="true"></div>
      <div class="hero__hit" data-hero-hit aria-hidden="true"></div>
      <div class="hero__hint" data-hero-hint aria-hidden="true"><span class="hero__hint-dot"></span><span data-hero-hint-txt>Pasa el cursor sobre el planeta</span></div>
    </div>
  </div>

  <div class="hero__caso0" data-hero-caso0 aria-hidden="true">
    <div class="hero__caso0-head">{hero.caso0.label}</div>
    <ul class="hero__caso0-rows">
      {hero.caso0.rows.map((r: any) => (
        <li><span class="hero__caso0-l">{r.l}</span><span class="hero__caso0-v">{r.v}</span></li>
      ))}
    </ul>
  </div>

  <div class="hero__dock">
    <Button href={hero.primary.href} variant="primary" size="lg">{hero.primary.label}</Button>
    <a class="hero__dock-link" href={hero.secondary.href}>{hero.secondary.label} →</a>
  </div>
</section>

<style>
  .hero {
    position: relative; overflow: clip;
    padding-top: calc(var(--nav-h) + var(--space-7)); padding-bottom: var(--space-9);
  }
  /* viñeta de la muestra: oro tenue + fondo oscuro inferior (da profundidad, no sobre-ilumina) */
  .hero::after {
    content: ""; position: absolute; inset: 0; z-index: -1; pointer-events: none;
    background:
      radial-gradient(78% 70% at 62% 48%, var(--accent-gold-dim), transparent 62%),
      radial-gradient(120% 90% at 50% 120%, rgba(0, 0, 0, 0.6), transparent 60%);
  }
  .hero__stars { position: absolute; inset: 0; z-index: -1; pointer-events: none; overflow: hidden; }
  .hero__inner { display: grid; grid-template-columns: 1fr; gap: var(--space-7); align-items: center; }

  .hero__headline { display: flex; flex-direction: column; align-items: flex-start; gap: var(--space-5); min-width: 0; text-align: left; }
  .hero__h1 { margin-top: var(--space-1); }
  .hero__h1 :global(em) { color: var(--accent-gold); font-style: normal; }
  .hero__sub { max-width: 50ch; }

  .hero__moons { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-top: var(--space-1); }
  .moon {
    display: inline-flex; align-items: center; gap: var(--space-2);
    min-height: var(--tap-min); padding: var(--space-2) var(--space-4); border-radius: var(--radius-pill);
    border: 1px solid var(--border); background: var(--bg-card);
    font-size: var(--text-sm); color: var(--fg-secondary);
    transition: border-color var(--duration-fast), color var(--duration-fast);
  }
  .moon__dot { width: 7px; height: 7px; border-radius: 50%; background: var(--accent-teal); flex: 0 0 auto; }
  .moon[data-accent="gold"] .moon__dot { background: var(--accent-gold); }
  .moon :global(.moon__icon), .moon :global(svg) { width: 16px; height: 16px; color: var(--accent-teal); flex: 0 0 auto; }
  .moon[data-accent="gold"] :global(svg) { color: var(--accent-gold); }
  .moon:hover { border-color: var(--border-accent); color: var(--fg-primary); }
  .hero--orbital .hero__moons { display: none; }

  /* ── escenario del planeta ─────────────────────────────── */
  .hero__stage { position: relative; width: 100%; max-width: 380px; aspect-ratio: 1 / 1; margin-inline: auto; will-change: transform; }
  .hero__svg { position: absolute; inset: 0; width: 100%; height: 100%; display: block; overflow: visible; }
  .hero__orbit { position: absolute; inset: 0; z-index: 3; }
  /* luz que sigue al cursor (escritorio) — recorre el camino de los nodos */
  .hero__cursorlight {
    position: absolute; left: 0; top: 0; width: 200px; height: 200px; border-radius: 50%;
    background: radial-gradient(circle, var(--accent-gold-glow), transparent 68%);
    opacity: 0; pointer-events: none; z-index: 2; mix-blend-mode: screen;
    transition: opacity var(--duration-base) var(--ease-out-expo);
  }
  .hero__hit { position: absolute; left: 50%; top: 50%; width: 64%; aspect-ratio: 1; transform: translate(-50%, -50%); border-radius: 50%; z-index: 6; cursor: pointer; }
  .hero__hint {
    position: absolute; left: 50%; bottom: -8px; transform: translate(-50%, 100%); z-index: 5;
    display: none; align-items: center; gap: var(--space-2);
    font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide);
    text-transform: uppercase; color: var(--fg-secondary); white-space: nowrap; pointer-events: none;
  }
  .hero__hint-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent-gold); box-shadow: 0 0 0 0 var(--accent-gold-glow); animation: hpulse 2.4s ease-out infinite; }
  @keyframes hpulse { 0% { box-shadow: 0 0 0 0 var(--accent-gold-glow); } 70% { box-shadow: 0 0 0 12px transparent; } 100% { box-shadow: 0 0 0 0 transparent; } }
  @media (--motion-reduce) { .hero__hint-dot { animation: none; } }

  /* ── Caso 0 — texto desnudo, abajo-dcha, SOLO escritorio ── */
  .hero__caso0 { display: none; }
  .hero__caso0-head {
    font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide);
    text-transform: uppercase; color: var(--accent-gold); margin-bottom: var(--space-3);
  }
  .hero__caso0-rows { list-style: none; display: flex; flex-direction: column; gap: var(--space-2); align-items: flex-end; }
  .hero__caso0-rows li { display: flex; gap: var(--space-4); align-items: baseline; font-family: var(--font-mono); font-size: var(--text-xs); }
  .hero__caso0-l { color: var(--fg-subtle); letter-spacing: 0.04em; }
  .hero__caso0-v { color: var(--fg-secondary); min-width: 120px; text-align: right; }

  /* ── CTA dock — abajo, centro ──────────────────────────── */
  .hero__dock { display: flex; flex-direction: column; align-items: center; gap: var(--space-3); margin-top: var(--space-7); }
  .hero__dock-link {
    display: inline-flex; align-items: center; min-height: var(--tap-min);
    font-family: var(--font-mono); font-size: var(--text-sm); letter-spacing: var(--tracking-wide);
    color: var(--fg-secondary); transition: color var(--duration-fast);
  }
  .hero__dock-link:hover { color: var(--accent-gold); }

  /* ── ≥ lg: titular izq · planeta der · Caso0 abajo-dcha · dock abajo-centro ── */
  @media (--lg) {
    .hero { padding-top: calc(var(--nav-h) + var(--space-8)); padding-bottom: var(--space-10); min-height: 92svh; }
    .hero__inner { grid-template-columns: 1.05fr 0.95fr; gap: var(--space-8); }
    .hero__stage { max-width: 440px; }
    .hero__caso0 { display: block; position: absolute; right: var(--container-pad); bottom: var(--space-8); text-align: right; pointer-events: none; opacity: 0; transform: translateY(8px); transition: opacity var(--duration-slow) var(--ease-out-expo), transform var(--duration-slow) var(--ease-out-expo); }
    .hero__caso0.is-shown { opacity: 1; transform: none; }
    .hero__dock { position: absolute; left: 50%; bottom: var(--space-7); transform: translateX(-50%); flex-direction: row; align-items: center; gap: var(--space-4); margin-top: 0; }
  }
</style>

<!-- Estilos de los cuerpos orbitales (inyectados por JS → is:global, bajo .hero__orbit) -->
<style is:global>
  .hero__orbit .hero-node {
    position: absolute; left: 0; top: 0; display: inline-flex; align-items: center; gap: 8px;
    padding: 7px 14px 7px 12px; border-radius: var(--radius-pill); white-space: nowrap; text-decoration: none;
    background: rgba(18, 18, 18, 0.85); -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px);
    border: 1px solid var(--accent-gold-line); color: var(--fg-primary);
    font-family: var(--font-body); font-size: var(--text-sm); font-weight: 600; line-height: 1;
    box-shadow: 0 8px 26px rgba(0, 0, 0, 0.5); opacity: 0; will-change: transform, opacity;
    transition: border-color var(--duration-fast), box-shadow var(--duration-fast), background var(--duration-fast);
  }
  .hero__orbit .hero-node.teal { border-color: var(--accent-teal-line); }
  .hero__orbit .hero-node svg { width: 15px; height: 15px; color: var(--accent-gold); flex: 0 0 auto; }
  .hero__orbit .hero-node.teal svg { color: var(--accent-teal); }
  .hero__orbit .hero-node .moon__dot { width: 7px; height: 7px; border-radius: 50%; background: var(--accent-gold); flex: 0 0 auto; }
  .hero__orbit .hero-node.teal .moon__dot { background: var(--accent-teal); }
  /* hover: el nodo se ILUMINA (borde + fondo + halo) */
  .hero__orbit .hero-node:hover {
    background: rgba(34, 30, 22, 0.92); border-color: var(--accent-gold); color: var(--fg-primary);
    box-shadow: 0 10px 32px rgba(0, 0, 0, 0.6), 0 0 0 1px var(--accent-gold), 0 0 22px var(--accent-gold-glow);
  }
  .hero__orbit .hero-node.teal:hover {
    border-color: var(--accent-teal);
    box-shadow: 0 10px 32px rgba(0, 0, 0, 0.6), 0 0 0 1px var(--accent-teal), 0 0 22px var(--accent-teal-dim);
  }
  .hero__orbit .hero-amb {
    position: absolute; left: 0; top: 0; width: 5px; height: 5px; border-radius: 50%;
    background: var(--accent-gold); box-shadow: 0 0 8px var(--accent-gold);
    opacity: 0; pointer-events: none; will-change: transform, opacity;
  }
</style>

<script>
  const hero = document.querySelector('[data-hero]') as HTMLElement | null;
  if (hero) {
    const stage = hero.querySelector('[data-hero-stage]') as HTMLElement;
    const orbit = hero.querySelector('[data-hero-orbit]') as HTMLElement;
    const moons = hero.querySelector('[data-hero-moons]') as HTMLElement;
    const headline = hero.querySelector('[data-hero-headline]') as HTMLElement;
    const hint = hero.querySelector('[data-hero-hint]') as HTMLElement;
    const hintTxt = hero.querySelector('[data-hero-hint-txt]') as HTMLElement;
    const caso0 = hero.querySelector('[data-hero-caso0]') as HTMLElement;
    const starsEl = hero.querySelector('[data-hero-stars]') as HTMLElement;
    const cursorLight = hero.querySelector('[data-hero-cursorlight]') as HTMLElement;

    const mqFine = window.matchMedia('(hover: hover) and (pointer: fine)');
    const mqReduce = window.matchMedia('(prefers-reduced-motion: reduce)');
    const auto = () => !mqFine.matches || window.innerWidth < 1024; // táctil / apilado (<lg) → toque-activado

    // campo estelar sutil
    (function fillStars() {
      if (!starsEl || starsEl.childElementCount) return;
      const n = window.innerWidth < 768 ? 60 : 100;
      const frag = document.createDocumentFragment();
      for (let i = 0; i < n; i++) {
        const s = document.createElement('span');
        const sz = (i % 7) * 0.28 + 0.5;
        s.style.cssText = `position:absolute;border-radius:50%;background:var(--fg-primary);width:${sz}px;height:${sz}px;` +
          `top:${(i * 137) % 100}%;left:${(i * 53) % 100}%;opacity:.18;` +
          (mqReduce.matches ? '' : `animation:hstar ${2 + (i % 5)}s ease-in-out ${(i % 9) * 0.4}s infinite;`);
        frag.appendChild(s);
      }
      starsEl.appendChild(frag);
      if (!document.getElementById('hstar-kf')) {
        const st = document.createElement('style'); st.id = 'hstar-kf';
        st.textContent = '@keyframes hstar{0%,100%{opacity:.12}50%{opacity:.6}}';
        document.head.appendChild(st);
      }
    })();

    const ROLL = -18 * Math.PI / 180, COS = Math.cos(ROLL), SIN = Math.sin(ROLL), FLATTEN = 0.42;
    let bodies: any[] = [];
    let cx = 0, cy = 0, maxR = 0, isAuto = auto(), lastAuto = isAuto, activated = false;
    let energy = 0, target = 0;
    let tiltX = 0, tiltY = 0, tTiltX = 0, tTiltY = 0;
    let rafId = 0, last = 0, running = false;
    let ro: ResizeObserver | null = null;

    function measure() {
      const r = stage.getBoundingClientRect();
      cx = r.width / 2; cy = r.height / 2;
      maxR = Math.min(r.width, r.height) * 0.5;
    }
    function project(R: number, ang: number) {
      const ux = Math.cos(ang) * R, uy = Math.sin(ang) * R * FLATTEN;
      return { x: cx + (ux * COS - uy * SIN), y: cy + (ux * SIN + uy * COS), depth: Math.sin(ang) };
    }
    function build() {
      const links = Array.from(moons.querySelectorAll('a'));
      orbit.innerHTML = '';
      bodies = [];
      const n = links.length;
      const lanes = isAuto ? [0.84, 1.0] : [0.72, 0.92];
      links.forEach((a, idx) => {
        const teal = a.getAttribute('data-accent') === 'teal';
        const el = document.createElement('a');
        el.className = 'hero-node' + (teal ? ' teal' : '');
        el.href = a.getAttribute('href') || '#';
        el.innerHTML = a.innerHTML; // conserva icono + etiqueta
        orbit.appendChild(el);
        bodies.push({ el, R: lanes[idx % lanes.length], ang: (idx / n) * Math.PI * 2 + 0.3, speed: 0.06 + 0.015 * (idx % 3), node: true });
      });
      const ambN = isAuto ? 3 : 6;
      for (let i = 0; i < ambN; i++) {
        const el = document.createElement('span');
        el.className = 'hero-amb';
        orbit.appendChild(el);
        bodies.push({ el, R: 0.5 + 0.5 * (i / ambN), ang: (i / ambN) * Math.PI * 2, speed: 0.07 + 0.025 * (i % 3), sz: 0.6 + 0.7 * ((i % 3) / 3) });
      }
    }
    function frame(now: number) {
      const dt = Math.min(0.05, (now - last) / 1000); last = now;
      energy += (target - energy) * Math.min(1, dt * 8); // emergencia rápida y natural
      // en reposo total no tocamos el DOM (ahorra CPU/batería); el loop sigue barato
      if (energy < 0.004 && target < 0.004) { rafId = requestAnimationFrame(frame); return; }
      if (!isAuto) {
        tiltX += (tTiltX - tiltX) * Math.min(1, dt * 5);
        tiltY += (tTiltY - tiltY) * Math.min(1, dt * 5);
        stage.style.transform = `perspective(1200px) rotateX(${tiltX}deg) rotateY(${tiltY}deg)`;
      }
      for (const b of bodies) {
        b.ang += b.speed * dt * (0.5 + 0.9 * energy);
        const p = project(b.R * maxR * (0.6 + 0.4 * energy), b.ang);
        const front = (p.depth + 1) / 2;
        if (b.node) {
          const sc = 0.85 + 0.15 * p.depth;
          b.el.style.transform = `translate(-50%,-50%) translate(${p.x}px,${p.y}px) scale(${sc})`;
          b.el.style.opacity = (energy * (0.2 + 0.8 * front)).toFixed(3);
          b.el.style.zIndex = p.depth > 0 ? '6' : '1';
          b.el.style.pointerEvents = (energy > 0.5 && p.depth > -0.35) ? 'auto' : 'none';
        } else {
          b.el.style.transform = `translate(-50%,-50%) translate(${p.x}px,${p.y}px) scale(${b.sz})`;
          b.el.style.opacity = (energy * (0.2 + 0.4 * front)).toFixed(3);
          b.el.style.zIndex = p.depth > 0 ? '5' : '0';
        }
      }
      hint.style.opacity = Math.max(0, 1 - energy * 2.4).toFixed(3);
      if (!isAuto) {
        headline.style.opacity = (1 - energy * 0.5).toFixed(3);
        caso0.classList.toggle('is-shown', energy > 0.5);
      }
      rafId = requestAnimationFrame(frame);
    }

    const onEnter = () => { if (!isAuto) target = 1; };
    const onLeave = () => { if (!isAuto) { target = 0; cursorLight.style.opacity = '0'; } };
    const onMove = (e: PointerEvent) => {
      if (isAuto) return;
      const hr = hero.getBoundingClientRect();
      tTiltY = ((e.clientX - hr.left) / hr.width - 0.5) * 6;
      tTiltX = -((e.clientY - hr.top) / hr.height - 0.5) * 4;
      // luz que sigue al cursor, sólo cerca del escenario del planeta
      const sr = stage.getBoundingClientRect();
      const lx = e.clientX - sr.left, ly = e.clientY - sr.top;
      const near = lx > -90 && lx < sr.width + 90 && ly > -90 && ly < sr.height + 90;
      cursorLight.style.opacity = near ? '1' : '0';
      cursorLight.style.transform = `translate(${lx}px,${ly}px) translate(-50%,-50%)`;
    };
    // primer toque (móvil): recién entonces sale la órbita
    const onActivate = () => { if (isAuto && !activated) { activated = true; target = 1; } };

    function enable() {
      if (running) return;
      running = true;
      hero.classList.add('hero--orbital');
      isAuto = auto(); lastAuto = isAuto; activated = false;
      target = 0; energy = 0;                       // siempre arranca calmo (móvil: hasta el toque)
      hintTxt.textContent = isAuto ? 'Toca para explorar' : 'Pasa el cursor sobre el planeta';
      hint.style.display = 'inline-flex'; hint.style.opacity = '1';
      headline.style.opacity = '';
      measure(); build();
      hero.addEventListener('pointerenter', onEnter);
      hero.addEventListener('pointerleave', onLeave);
      hero.addEventListener('pointermove', onMove);
      hero.addEventListener('pointerdown', onActivate);
      hero.addEventListener('click', onActivate);
      ro = new ResizeObserver(() => measure());
      ro.observe(stage);
      if (document.fonts && document.fonts.ready) document.fonts.ready.then(() => { if (running) measure(); });
      last = performance.now();
      rafId = requestAnimationFrame(frame);
    }
    function disable() {
      if (!running) return;
      running = false;
      cancelAnimationFrame(rafId);
      hero.classList.remove('hero--orbital');
      orbit.innerHTML = '';
      stage.style.transform = '';
      hint.style.display = 'none';
      headline.style.opacity = '';
      cursorLight.style.opacity = '0';
      hero.removeEventListener('pointerenter', onEnter);
      hero.removeEventListener('pointerleave', onLeave);
      hero.removeEventListener('pointermove', onMove);
      hero.removeEventListener('pointerdown', onActivate);
      hero.removeEventListener('click', onActivate);
      if (ro) { ro.disconnect(); ro = null; }
    }
    function sync() {
      if (mqReduce.matches) { disable(); return; } // reduced-motion → chips estáticos
      disable(); enable();
    }
    mqReduce.addEventListener('change', sync);
    mqFine.addEventListener('change', sync);
    // En resize NO reiniciamos la animación (eso causaba el bug del scroll en móvil:
    // la barra del navegador dispara resize → sólo re-medimos. Sólo si cruza el umbral
    // (apilado ↔ desktop) reconstruimos.)
    let rt: number;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      rt = window.setTimeout(() => {
        if (auto() !== lastAuto) { sync(); } else { measure(); }
      }, 150);
    }, { passive: true });
    sync();
  }
</script>
