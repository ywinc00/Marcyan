---
// Portafolio · rejilla de proyectos reales. Cada proyecto se muestra en una
// maqueta de dispositivo (laptop + teléfono) con su captura real, alternando
// imagen/info en escritorio. Reusa el lenguaje visual de Projects.astro (home),
// pero estático y mostrando TODOS los proyectos (no carrusel).
import Icon from '../ui/Icon.astro';
import Kicker from '../ui/Kicker.astro';
import type { PortfolioProject } from '../../i18n/portfolio';

interface Props {
  tag: string;
  title: string;
  intro?: string;
  projects: PortfolioProject[];
}
const { tag, title, intro, projects } = Astro.props;
---
<section class="section pwf" data-fx="gold">
  <div class="container">
    <header class="pwf__head">
      <Kicker>{tag}</Kicker>
      <h2 class="h2" set:html={title} />
      {intro && <p class="pwf__intro">{intro}</p>}
    </header>

    <div class="pwf__list">
      {projects.map((p, idx) => (
        <article class={`pwork${idx % 2 === 1 ? ' is-rev' : ''}`} data-accent={p.accent}>
          <div class="pwork__devices">
            {/* LAPTOP */}
            <div class="dvp-laptop">
              <div class="dvp-screen">
                <span class="dvp-cam" aria-hidden="true"></span>
                <img
                  class="dvp-shot"
                  src={`/Galeria/${p.slug}-pc.webp`}
                  alt={`${p.name} — vista de escritorio del sitio`}
                  width="1920" height="1080" loading="lazy" decoding="async"
                />
              </div>
              <div class="dvp-deck" aria-hidden="true"><span class="dvp-lip"></span></div>
            </div>
            {/* TELÉFONO */}
            <div class="dvp-phone">
              <span class="dvp-island" aria-hidden="true"></span>
              <div class="dvp-pscreen">
                <img
                  class="dvp-pshot"
                  src={`/Galeria/${p.slug}-movil.webp`}
                  alt={`${p.name} — vista móvil del sitio`}
                  width="1320" height={p.mh} loading="lazy" decoding="async"
                />
              </div>
            </div>
          </div>

          <div class="pwork__info">
            <span class="pwork__badge">{p.badge}</span>
            <h3 class="pwork__name">{p.name}</h3>
            <span class="pwork__cat">{p.cat}</span>
            <p class="pwork__did">{p.did}</p>
            <p class="pwork__result"><Icon name="lucide:check" /> {p.result}</p>
            <div class="pwork__tags">
              {p.tags.map((t, ti) => <span class={`pwork__tag pwork__tag--${ti % 3}`}>{t}</span>)}
            </div>
            <a class="pwork__link" href={p.serviceHref}>
              {p.serviceLabel} <Icon name="lucide:arrow-right" />
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .pwf :global(em) { color: var(--accent-gold); font-style: normal; }
  .pwf__head { display: flex; flex-direction: column; gap: var(--space-4); margin-bottom: var(--space-8); }
  .pwf__intro { color: var(--fg-secondary); font-size: var(--text-base); line-height: var(--leading-loose); max-width: 70ch; }

  .pwf__list { display: flex; flex-direction: column; gap: var(--space-9); }
  .pwork { display: grid; grid-template-columns: 1fr; gap: var(--space-6); align-items: center; }

  /* ── escenario de dispositivos (espejo de Projects.astro) ── */
  .pwork__devices {
    position: relative; aspect-ratio: 16 / 10; border-radius: var(--radius-lg);
    border: 1px solid var(--border); --a: var(--accent-gold);
    background:
      radial-gradient(120% 120% at 18% 0%, color-mix(in srgb, var(--a), transparent 86%), transparent 60%),
      var(--bg-2);
    padding: clamp(14px, 5%, 40px); min-width: 0;
  }
  .pwork[data-accent="teal"] .pwork__devices { --a: var(--accent-teal); }

  .dvp-laptop { position: absolute; left: 50%; top: 50%; transform: translate(-58%, -52%); width: 70%; }
  .dvp-screen {
    position: relative; background: #0a0a0b; border: 1px solid #34343a;
    border-radius: 12px 12px 5px 5px; padding: 7px 7px 9px;
    box-shadow: 0 22px 32px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }
  .dvp-cam {
    position: absolute; top: 3px; left: 50%; transform: translateX(-50%);
    width: 4px; height: 4px; border-radius: 50%; background: #14201f;
    box-shadow: 0 0 0 1px #000, inset 0 0 1px rgba(79, 195, 161, 0.7);
  }
  .dvp-shot {
    display: block; width: 100%; aspect-ratio: 16 / 9; object-fit: cover; object-position: top center;
    border-radius: 3px; background: var(--bg-base);
  }
  .dvp-deck {
    position: relative; width: 118%; left: -9%; height: clamp(8px, 1.5vw, 14px); margin-top: -1px;
    background: linear-gradient(180deg, #46474b 0%, #2a2b2e 42%, #131315 100%);
    border-radius: 1px 1px 12px 12px; box-shadow: 0 12px 18px rgba(0, 0, 0, 0.42);
  }
  .dvp-lip {
    position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 15%; height: 4px; border-radius: 0 0 7px 7px; background: #0c0c0e;
    box-shadow: inset 0 -1px 1px rgba(255, 255, 255, 0.06);
  }
  .dvp-phone {
    position: absolute; right: 3%; bottom: 13%; z-index: 3; width: 24%; aspect-ratio: 9 / 16;
    background: #0a0a0b; border: 1px solid #34343a; border-radius: clamp(13px, 1.5vw, 20px); padding: 4px;
    box-shadow: 0 24px 40px rgba(0, 0, 0, 0.6), 0 3px 8px rgba(0, 0, 0, 0.4);
  }
  .dvp-pscreen {
    position: relative; width: 100%; height: 100%; overflow: hidden;
    border-radius: clamp(10px, 1.3vw, 16px); background: var(--bg-base);
  }
  .dvp-pshot { display: block; width: 100%; height: 100%; object-fit: cover; object-position: top center; }
  .dvp-island {
    position: absolute; top: 7px; left: 50%; transform: translateX(-50%); z-index: 4;
    width: 30%; height: 6px; border-radius: 100px; background: #000;
  }

  /* ── info ── */
  .pwork__info { display: flex; flex-direction: column; gap: var(--space-2); min-width: 0; }
  .pwork__badge {
    align-self: flex-start; font-family: var(--font-mono); font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--accent-teal);
    background: var(--accent-teal-dim); border: 1px solid var(--accent-teal-line);
    border-radius: var(--radius-pill); padding: var(--space-1) var(--space-3); margin-bottom: var(--space-1);
  }
  .pwork__name { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 600; }
  .pwork__cat { font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--fg-secondary); }
  .pwork__did { color: var(--fg-secondary); font-size: var(--text-base); line-height: var(--leading-loose); margin-top: var(--space-2); max-width: 60ch; }
  .pwork__result {
    display: flex; align-items: flex-start; gap: var(--space-2);
    color: var(--fg-primary); font-size: var(--text-base); line-height: var(--leading-normal); margin-top: var(--space-1);
  }
  .pwork__result :global(svg) { width: 18px; height: 18px; color: var(--accent-teal); flex: 0 0 auto; margin-top: 2px; }
  .pwork__tags { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-top: var(--space-3); }
  .pwork__tag { font-size: var(--text-xs); border-radius: var(--radius-pill); padding: var(--space-1) var(--space-3); border: 1px solid var(--border); color: var(--fg-secondary); background: var(--bg-elevated); }
  .pwork__tag--0 { color: var(--accent-gold); border-color: var(--accent-gold-line); background: var(--accent-gold-dim); }
  .pwork__tag--2 { color: var(--accent-teal); border-color: var(--accent-teal-line); background: var(--accent-teal-dim); }
  .pwork__link {
    align-self: flex-start; display: inline-flex; align-items: center; gap: var(--space-2);
    margin-top: var(--space-4); min-height: var(--tap-min);
    font-family: var(--font-body); font-size: var(--text-sm); font-weight: 600; color: var(--accent-gold);
    transition: gap var(--duration-fast) var(--ease-out-expo), color var(--duration-fast);
  }
  .pwork__link:hover { color: var(--fg-primary); gap: var(--space-3); }
  .pwork__link :global(svg) { width: 16px; height: 16px; }

  @media (--md) {
    .pwork { grid-template-columns: 1.05fr 0.95fr; gap: var(--space-8); }
    /* alterna: en filas impares la info va primero (imagen a la derecha) */
    .pwork.is-rev .pwork__devices { order: 2; }
    .pwork.is-rev .pwork__info { order: 1; }
  }
</style>
