---
// Grid de precios (Fase 0) — N tarjetas "desde $X + qué incluye + CTA".
// Publicar precio = palanca AEO + confianza. Cada tarjeta lleva su tono (gold |
// teal). Datos desde i18n/pricing (misma fuente que el OfferCatalog del schema).
import Icon from '../ui/Icon.astro';
import Kicker from '../ui/Kicker.astro';
import type { PriceService } from '../../i18n/pricing';

interface Props {
  tag: string;
  title: string;
  intro?: string;
  items: PriceService[];
}
const { tag, title, intro, items } = Astro.props;
---
<section class="section pgrid" id="precios" data-fx="gold">
  <div class="container">
    <header class="pgrid__head">
      <Kicker>{tag}</Kicker>
      <h2 class="h2" set:html={title} />
      {intro && <p class="lead">{intro}</p>}
    </header>

    <div class="pgrid__grid">
      {items.map((s) => (
        <article class:list={['pcard', `pcard--${s.tone}`]}>
          <div class="pcard__top">
            <span class="pcard__icon"><Icon name={s.icon} /></span>
            {s.free
              ? <span class="pcard__badge"><Icon name="lucide:sparkles" /> Diagnóstico gratis</span>
              : (
                <span class="pcard__price">
                  <span class="pcard__from">desde</span>
                  <span class="pcard__amt">{s.displayPrice}{s.monthly ? <span class="pcard__per">/mes</span> : null}</span>
                </span>
              )}
          </div>
          <h3 class="pcard__name">{s.name}</h3>
          <p class="pcard__tagline">{s.tagline}</p>
          <ul class="pcard__features">
            {s.includes.map((f) => (
              <li><Icon name="lucide:check" /> <span>{f}</span></li>
            ))}
          </ul>
          <a class="pcard__cta" href={s.href}>
            <span>{s.ctaLabel}</span>
            <Icon name="lucide:arrow-right" />
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .pgrid :global(.h2 em) { color: var(--accent-gold); font-style: normal; }
  .pgrid__head { display: flex; flex-direction: column; gap: var(--space-4); margin-bottom: var(--space-7); max-width: 62ch; }

  .pgrid__grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }

  .pcard {
    min-width: 0; display: flex; flex-direction: column; gap: var(--space-3);
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--radius-lg); box-shadow: var(--shadow-card);
    padding: var(--space-6); height: 100%;
    transition: border-color var(--duration-base) var(--ease-out-expo);
  }
  .pcard:hover { border-color: var(--border-accent); }
  .pcard--gold { --tint: var(--accent-gold); --tint-dim: var(--accent-gold-dim); --tint-line: var(--accent-gold-line); }
  .pcard--teal { --tint: var(--accent-teal); --tint-dim: var(--accent-teal-dim); --tint-line: var(--accent-teal-line); }

  .pcard__top { display: flex; align-items: flex-start; justify-content: space-between; gap: var(--space-3); }
  .pcard__icon {
    display: inline-flex; align-items: center; justify-content: center; flex: 0 0 auto;
    width: 44px; height: 44px; border-radius: var(--radius-md);
    background: var(--tint-dim); border: 1px solid var(--tint-line); color: var(--tint);
  }
  .pcard__icon :global(svg) { width: 22px; height: 22px; stroke-width: 1.5; }

  .pcard__price { display: flex; flex-direction: column; align-items: flex-end; text-align: right; line-height: 1.1; }
  .pcard__from { font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: var(--tracking-wide); color: var(--fg-secondary); }
  .pcard__amt { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 700; color: var(--tint); }
  .pcard__per { font-family: var(--font-mono); font-size: var(--text-md); font-weight: 400; color: var(--fg-secondary); }
  .pcard__badge {
    display: inline-flex; align-items: center; gap: var(--space-2);
    font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide); text-transform: uppercase;
    color: var(--accent-teal); background: var(--accent-teal-dim); border: 1px solid var(--accent-teal-line);
    border-radius: var(--radius-pill); padding: var(--space-1) var(--space-3);
  }
  .pcard__badge :global(svg) { width: 13px; height: 13px; flex: 0 0 auto; }

  .pcard__name { font-family: var(--font-display); font-size: var(--text-xl); font-weight: 600; margin-top: var(--space-1); }
  .pcard__tagline { color: var(--fg-secondary); font-size: var(--text-sm); line-height: var(--leading-normal); }

  .pcard__features { list-style: none; display: grid; gap: var(--space-2); margin-top: var(--space-1); }
  .pcard__features li { display: flex; align-items: flex-start; gap: var(--space-2); font-size: var(--text-sm); color: var(--fg-primary); min-width: 0; }
  .pcard__features :global(svg) { width: 16px; height: 16px; color: var(--tint); flex: 0 0 auto; margin-top: 3px; }

  .pcard__cta {
    display: inline-flex; align-items: center; gap: var(--space-2);
    margin-top: auto; padding-top: var(--space-4);
    min-height: var(--tap-min);
    font-family: var(--font-body); font-size: var(--text-sm); font-weight: 600; color: var(--tint);
  }
  .pcard__cta :global(svg) { width: 16px; height: 16px; transition: transform var(--duration-base) var(--ease-out-expo); }
  .pcard:hover .pcard__cta :global(svg) { transform: translateX(4px); }

  @media (--motion-reduce) { .pcard:hover .pcard__cta :global(svg) { transform: none; } }
  @media (--sm) { .pgrid__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (--lg) { .pgrid__grid { grid-template-columns: repeat(3, 1fr); gap: var(--space-5); } }
</style>
