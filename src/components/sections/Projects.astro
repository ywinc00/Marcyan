---
// Sección Proyectos — Variante B "Renderizado en dispositivo", como la muestra:
// UN trabajo destacado a la vez: maqueta de SITIO (laptop con chrome de navegador +
// contenido wireframe + planeta + tarjetas) y teléfono, con la info al lado. Se cambia
// de trabajo con flechitas sutiles izquierda/derecha (sin puntos ni contador). Sin
// enlaces vivos (la URL es leyenda). La pantalla queda lista para una <img> real.
import Icon from '../ui/Icon.astro';
import Kicker from '../ui/Kicker.astro';
import Button from '../ui/Button.astro';

interface Props { projects: any }
const { projects } = Astro.props;
const items = projects.items;
---
<section class="section projects" id="proyectos" data-fx="gold">
  <div class="container">
    <header class="projects__head">
      <div class="projects__intro">
        <Kicker>{projects.tag}</Kicker>
        <h2 class="h2" set:html={projects.title} />
      </div>
      <Button href={projects.cta.href} variant="secondary" class="projects__head-cta">{projects.cta.label}</Button>
    </header>

    <div class="pf" data-projects role="group" aria-label={projects.tag}>
      <button class="pf__arrow pf__arrow--prev" type="button" data-prev aria-label="Trabajo anterior"><Icon name="lucide:chevron-left" /></button>

      <div class="pf__stage">
        {items.map((p: any, idx: number) => (
          <article class={`pf__slide${idx === 0 ? ' is-active' : ''}`} data-slide data-accent={p.accent} aria-hidden={idx === 0 ? 'false' : 'true'}>
            <div class="pf__devices" aria-hidden="true">
              <div class="pf__laptop">
                <div class="pf__screen">
                  <div class="pf__browser"><i></i><i></i><i></i><span class="pf__pill"></span></div>
                  <div class="pf__site">
                    <div class="pf__srow">
                      <div class="pf__lines">
                        <span style="width:80%"></span>
                        <span class="acc" style="width:46%"></span>
                        <span style="width:64%"></span>
                        <span style="width:38%"></span>
                      </div>
                      <svg class="pf__planet" viewBox="0 0 60 60" aria-hidden="true">
                        <circle cx="30" cy="28" r="15" fill="var(--planet-core)" stroke="var(--a)" stroke-opacity="0.5" />
                        <ellipse cx="30" cy="28" rx="27" ry="8" fill="none" stroke="var(--a)" stroke-width="1.4" transform="rotate(-18 30 28)" />
                      </svg>
                    </div>
                    <div class="pf__cards">
                      <span><i></i></span><span><i class="t"></i></span><span><i></i></span>
                    </div>
                  </div>
                </div>
                <div class="pf__base"></div>
              </div>
              <div class="pf__phone">
                <div class="pf__pscreen">
                  <span class="pf__pnotch"></span>
                  <span style="width:70%"></span>
                  <span class="acc" style="width:50%"></span>
                  <span style="width:60%"></span>
                  <span class="dot"></span>
                </div>
              </div>
            </div>

            <div class="pf__info">
              {p.badge && <span class="pf__badge">{p.badge}</span>}
              <h3 class="pf__name">{p.name}</h3>
              <span class="pf__cat">{p.cat}</span>
              <p class="pf__result">{p.result}</p>
              {p.tags && <div class="pf__tags">{p.tags.map((t: string, ti: number) => <span class={`pf__tag pf__tag--${ti % 3}`}>{t}</span>)}</div>}
              <span class="pf__url"><Icon name="lucide:globe" />{p.display}</span>
            </div>
          </article>
        ))}
      </div>

      <button class="pf__arrow pf__arrow--next" type="button" data-next aria-label="Trabajo siguiente"><Icon name="lucide:chevron-right" /></button>

      <button class="pf__more" type="button" data-more aria-expanded="false">
        <span>{projects.more ?? 'Ver Proyectos'}</span>
        <Icon name="lucide:chevron-down" class="pf__more-ic" />
      </button>
    </div>
  </div>
</section>

<style>
  .projects :global(em) { color: var(--accent-gold); font-style: normal; }
  .projects__head { display: flex; flex-direction: column; gap: var(--space-5); align-items: flex-start; margin-bottom: var(--space-7); }
  .projects__intro { display: flex; flex-direction: column; gap: var(--space-4); }

  .pf { position: relative; display: flex; flex-direction: column; }
  .pf__stage { display: grid; }
  .pf__slide { grid-area: 1 / 1; display: none; }
  .pf__slide.is-active { display: grid; grid-template-columns: 1fr; gap: var(--space-6); align-items: center; animation: pfin var(--duration-slow) var(--ease-out-expo); }
  @keyframes pfin { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
  @media (--motion-reduce) { .pf__slide.is-active { animation: none; } }

  /* ── maqueta de dispositivo ────────────────────────────── */
  .pf__devices {
    position: relative; aspect-ratio: 16 / 9; border-radius: var(--radius-lg); border: 1px solid var(--border);
    --a: var(--accent-gold);
    background: radial-gradient(130% 130% at 14% 6%, color-mix(in srgb, var(--a), transparent 84%), transparent 58%), var(--bg-2);
    display: flex; align-items: center; justify-content: center; overflow: hidden;
  }
  .pf__slide[data-accent="teal"] .pf__devices { --a: var(--accent-teal); }

  .pf__laptop { position: relative; width: 70%; }
  .pf__screen {
    border-radius: 10px 10px 0 0; border: 1px solid var(--border); border-bottom: 0; overflow: hidden;
    background: var(--bg-base); aspect-ratio: 16 / 10; display: flex; flex-direction: column;
  }
  .pf__browser { display: flex; align-items: center; gap: 5px; padding: 7px 10px; border-bottom: 1px solid var(--border); background: var(--bg-card); }
  .pf__browser i { width: 6px; height: 6px; border-radius: 50%; background: var(--fg-subtle); flex: 0 0 auto; }
  .pf__browser i:nth-child(3) { background: var(--accent-teal); }
  .pf__pill { margin-left: auto; width: 38%; height: 8px; border-radius: 100px; background: var(--bg-elevated); }
  .pf__site { flex: 1; padding: clamp(8px, 2.2vw, 16px); display: flex; flex-direction: column; justify-content: space-between; gap: clamp(8px, 2vw, 16px); }
  .pf__srow { display: flex; align-items: center; gap: var(--space-4); }
  .pf__lines { flex: 1; display: flex; flex-direction: column; gap: 7px; min-width: 0; }
  .pf__lines span { height: 7px; border-radius: 100px; background: var(--fg-subtle); opacity: 0.7; }
  .pf__lines span.acc { background: var(--a); opacity: 0.85; }
  .pf__planet { width: clamp(42px, 9vw, 64px); height: auto; flex: 0 0 auto; }
  .pf__cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
  .pf__cards span { aspect-ratio: 3 / 2; border-radius: 6px; background: var(--bg-card); border: 1px solid var(--border); display: flex; align-items: flex-end; padding: 6px; }
  .pf__cards i { width: 8px; height: 8px; border-radius: 50%; background: var(--accent-gold); display: block; }
  .pf__cards i.t { background: var(--accent-teal); }
  .pf__base { height: 12px; border-radius: 0 0 9px 9px; background: var(--bg-elevated); border: 1px solid var(--border); }

  .pf__phone { position: absolute; right: 8%; bottom: 8%; width: 16%; aspect-ratio: 1 / 2; border-radius: 12px; border: 1px solid var(--border); background: var(--bg-elevated); padding: 4px; box-shadow: 0 14px 30px rgba(0, 0, 0, 0.6); }
  .pf__pscreen { position: relative; width: 100%; height: 100%; border-radius: 8px; background: var(--bg-base); padding: 14px 7px 7px; display: flex; flex-direction: column; gap: 5px; overflow: hidden; }
  .pf__pnotch { position: absolute; top: 5px; left: 50%; transform: translateX(-50%); width: 28%; height: 4px; border-radius: 100px; background: var(--bg-elevated); }
  .pf__pscreen span { height: 5px; border-radius: 100px; background: var(--fg-subtle); opacity: 0.7; }
  .pf__pscreen span.acc { background: var(--a); opacity: 0.85; }
  .pf__pscreen .dot { width: 9px; height: 9px; border-radius: 50%; background: var(--accent-teal); opacity: 1; margin-top: 4px; }

  /* ── info ──────────────────────────────────────────────── */
  .pf__info { display: flex; flex-direction: column; gap: var(--space-2); min-width: 0; }
  .pf__badge { align-self: flex-start; font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--accent-teal); background: var(--accent-teal-dim); border: 1px solid var(--accent-teal-line); border-radius: var(--radius-pill); padding: var(--space-1) var(--space-3); margin-bottom: var(--space-1); }
  .pf__name { font-family: var(--font-display); font-size: var(--text-xl); font-weight: 600; }
  .pf__cat { font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--fg-secondary); }
  .pf__result { color: var(--fg-secondary); font-size: var(--text-base); line-height: var(--leading-normal); margin-top: var(--space-1); }
  .pf__tags { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-top: var(--space-3); }
  .pf__tag { font-size: var(--text-xs); border-radius: var(--radius-pill); padding: var(--space-1) var(--space-3); border: 1px solid var(--border); color: var(--fg-secondary); background: var(--bg-elevated); }
  .pf__tag--0 { color: var(--accent-gold); border-color: var(--accent-gold-line); background: var(--accent-gold-dim); }
  .pf__tag--2 { color: var(--accent-teal); border-color: var(--accent-teal-line); background: var(--accent-teal-dim); }
  .pf__url { display: inline-flex; align-items: center; gap: var(--space-2); margin-top: var(--space-3); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--fg-subtle); }
  .pf__url :global(svg) { width: 14px; height: 14px; }

  /* ── flechitas sutiles izq/der ─────────────────────────── */
  .pf__arrow {
    position: absolute; top: 38%; transform: translateY(-50%); z-index: 4;
    display: none; align-items: center; justify-content: center;
    width: var(--tap-min); height: var(--tap-min); border-radius: var(--radius-pill);
    color: var(--fg-subtle); background: transparent; border: 0;
    transition: color var(--duration-fast), background var(--duration-fast);
  }
  .pf__arrow:hover { color: var(--accent-gold); background: var(--accent-gold-dim); }
  .pf__arrow :global(svg) { width: 24px; height: 24px; }
  .pf__arrow--prev { left: calc(var(--space-2) * -1); }
  .pf__arrow--next { right: calc(var(--space-2) * -1); }

  /* "Ver Proyectos" — móvil: muestra UN trabajo y al tocar despliega todos */
  .pf__more {
    align-self: center; display: inline-flex; align-items: center; gap: var(--space-2);
    margin-top: var(--space-6); min-height: var(--tap-min); padding: var(--space-2) var(--space-4);
    color: var(--fg-secondary); background: transparent; border: 0; cursor: pointer;
    font-family: var(--font-mono); font-size: var(--text-sm); letter-spacing: var(--tracking-wide); text-transform: uppercase;
    transition: color var(--duration-fast);
  }
  .pf__more:hover { color: var(--accent-gold); }
  .pf__more-ic { width: 16px; height: 16px; transition: transform var(--duration-base) var(--ease-out-expo); }
  .pf.is-expanded .pf__more-ic { transform: rotate(180deg); }
  /* desplegado: se ven todos, apilados */
  .pf.is-expanded .pf__stage { display: flex; flex-direction: column; gap: var(--space-9); }
  .pf.is-expanded .pf__slide { grid-area: auto; display: grid; grid-template-columns: 1fr; gap: var(--space-6); animation: none; }

  @media (--md) {
    .projects__head { flex-direction: row; align-items: flex-end; justify-content: space-between; }
    .pf { padding-inline: var(--space-7); }
    .pf__arrow { display: inline-flex; }
    .pf__more { display: none; }
    .pf__slide.is-active { grid-template-columns: 1.1fr 0.9fr; gap: var(--space-8); }
    .pf__arrow--prev { left: calc(var(--space-2) * -1); }
    .pf__arrow--next { right: calc(var(--space-2) * -1); }
  }
</style>

<script>
  const root = document.querySelector('[data-projects]');
  if (root) {
    const slides = Array.from(root.querySelectorAll<HTMLElement>('[data-slide]'));
    const prev = root.querySelector<HTMLButtonElement>('[data-prev]');
    const next = root.querySelector<HTMLButtonElement>('[data-next]');
    const n = slides.length;
    let i = 0;
    function go(k: number) {
      i = (k + n) % n;
      slides.forEach((s, idx) => { const on = idx === i; s.classList.toggle('is-active', on); s.setAttribute('aria-hidden', on ? 'false' : 'true'); });
    }
    prev?.addEventListener('click', () => go(i - 1));
    next?.addEventListener('click', () => go(i + 1));
    root.addEventListener('keydown', (e) => {
      const k = (e as KeyboardEvent).key;
      if (k === 'ArrowLeft') go(i - 1);
      else if (k === 'ArrowRight') go(i + 1);
    });

    // "Ver Proyectos" (móvil): despliega / recoge todos los trabajos
    const more = root.querySelector<HTMLButtonElement>('[data-more]');
    more?.addEventListener('click', () => {
      const exp = root.classList.toggle('is-expanded');
      more.setAttribute('aria-expanded', exp ? 'true' : 'false');
      slides.forEach((s, idx) => s.setAttribute('aria-hidden', exp ? 'false' : (idx === i ? 'false' : 'true')));
    });
  }
</script>
