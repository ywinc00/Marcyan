---
// Sección Proyectos — 4 trabajos REALES con enlaces vivos (sin contenido falso).
import Icon from '../ui/Icon.astro';
import Kicker from '../ui/Kicker.astro';
import Button from '../ui/Button.astro';

interface Props { projects: any }
const { projects } = Astro.props;
---
<section class="section projects" id="proyectos">
  <div class="container">
    <header class="projects__head">
      <div class="projects__intro">
        <Kicker>{projects.tag}</Kicker>
        <h2 class="h2" set:html={projects.title} />
      </div>
      <Button href={projects.cta.href} variant="secondary" class="projects__head-cta">{projects.cta.label}</Button>
    </header>

    <div class="projects__grid">
      {projects.items.map((p: any) => (
        <a class="project" href={p.url} target="_blank" rel="noopener" data-accent={p.accent}>
          <div class="project__visual" aria-hidden="true">
            <span class="project__wm">{p.name}</span>
            <span class="project__dot"></span>
          </div>
          <div class="project__body">
            <span class="project__cat">{p.cat}</span>
            <h3 class="project__name">{p.name}</h3>
            <p class="project__result">{p.result}</p>
            <span class="project__link">{p.display} <Icon name="lucide:arrow-up-right" /></span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .projects :global(em) { color: var(--accent-gold); font-style: normal; }
  .projects__head { display: flex; flex-direction: column; gap: var(--space-5); align-items: flex-start; margin-bottom: var(--space-7); }
  .projects__intro { display: flex; flex-direction: column; gap: var(--space-4); }

  .projects__grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }

  .project {
    display: flex; flex-direction: column; min-width: 0; overflow: hidden;
    background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg);
    color: inherit; text-decoration: none;
    transition: border-color var(--duration-base) var(--ease-out-expo), box-shadow var(--duration-base), transform var(--duration-base);
  }
  .project:hover { border-color: var(--border-accent); box-shadow: var(--shadow-hover); transform: translateY(-2px); }
  @media (--motion-reduce) { .project:hover { transform: none; } }

  .project__visual {
    position: relative; aspect-ratio: 16 / 7; overflow: hidden;
    display: flex; align-items: center; padding: var(--space-5);
    border-bottom: 1px solid var(--border);
    --a: var(--accent-gold);
    background:
      radial-gradient(120% 140% at 12% 20%, color-mix(in srgb, var(--a), transparent 78%), transparent 60%),
      var(--bg-2);
  }
  .project[data-accent="teal"] .project__visual { --a: var(--accent-teal); }
  .project__wm {
    font-family: var(--font-display); font-weight: 700; font-size: clamp(28px, 6vw, 44px);
    line-height: 1; color: color-mix(in srgb, var(--a), transparent 55%); letter-spacing: -0.02em;
    max-width: 100%; overflow-wrap: anywhere;
  }
  .project__dot { position: absolute; top: 50%; right: var(--space-5); width: 12px; height: 12px; border-radius: 50%; background: var(--a); box-shadow: 0 0 18px var(--a); }

  .project__body { display: flex; flex-direction: column; gap: var(--space-2); padding: var(--space-5); }
  .project__cat { font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--fg-secondary); }
  .project__name { font-family: var(--font-display); font-size: var(--text-lg); font-weight: 600; }
  .project__result { color: var(--fg-secondary); font-size: var(--text-sm); flex: 1; }
  .project__link { display: inline-flex; align-items: center; gap: var(--space-1); margin-top: var(--space-2); font-family: var(--font-mono); font-size: var(--text-sm); color: var(--accent-teal); }
  .project__link :global(svg) { width: 15px; height: 15px; }

  @media (--md) {
    .projects__head { flex-direction: row; align-items: flex-end; justify-content: space-between; }
    .projects__grid { grid-template-columns: repeat(2, 1fr); gap: var(--space-5); }
  }
</style>
