---
// Sección Proyectos — Variante B "Renderizado en dispositivo".
// Cada trabajo real se muestra como un RENDER en marco (laptop + móvil) + info
// (badge, nombre, ciudad, resultado, tags). Sin enlaces sueltos: la URL es leyenda,
// no enlace vivo (no se rompe si el cliente cambia su web). Equal-height + alineado.
// La pantalla del laptop está lista para una <img> de captura real más adelante.
import Icon from '../ui/Icon.astro';
import Kicker from '../ui/Kicker.astro';
import Button from '../ui/Button.astro';

interface Props { projects: any }
const { projects } = Astro.props;
---
<section class="section projects" id="proyectos">
  <div class="container">
    <header class="projects__head">
      <div class="projects__intro">
        <Kicker>{projects.tag}</Kicker>
        <h2 class="h2" set:html={projects.title} />
      </div>
      <Button href={projects.cta.href} variant="secondary" class="projects__head-cta">{projects.cta.label}</Button>
    </header>

    <div class="projects__grid">
      {projects.items.map((p: any) => (
        <article class="proj" data-accent={p.accent}>
          <div class="proj__devices" aria-hidden="true">
            <div class="proj__laptop">
              <div class="proj__screen"><span class="proj__wm">{p.name}</span></div>
              <div class="proj__base"></div>
            </div>
            <div class="proj__phone"><div class="proj__pscreen"></div></div>
          </div>
          <div class="proj__info">
            {p.badge && <span class="proj__badge">{p.badge}</span>}
            <h3 class="proj__name">{p.name}</h3>
            <span class="proj__cat">{p.cat}</span>
            <p class="proj__result">{p.result}</p>
            {p.tags && (
              <div class="proj__tags">{p.tags.map((t: string) => <span class="proj__tag">{t}</span>)}</div>
            )}
            <span class="proj__url"><Icon name="lucide:globe" />{p.display}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .projects :global(em) { color: var(--accent-gold); font-style: normal; }
  .projects__head { display: flex; flex-direction: column; gap: var(--space-5); align-items: flex-start; margin-bottom: var(--space-7); }
  .projects__intro { display: flex; flex-direction: column; gap: var(--space-4); }

  .projects__grid { display: grid; grid-template-columns: 1fr; gap: var(--space-5); align-items: stretch; }

  .proj {
    display: flex; flex-direction: column; min-width: 0; overflow: hidden;
    background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg);
    --a: var(--accent-gold);
    transition: border-color var(--duration-base) var(--ease-out-expo), box-shadow var(--duration-base);
  }
  .proj[data-accent="teal"] { --a: var(--accent-teal); }
  .proj:hover { border-color: var(--border-accent); box-shadow: var(--shadow-hover); }

  /* ── render en dispositivo ─────────────────────────────── */
  .proj__devices {
    position: relative; aspect-ratio: 16 / 9; overflow: hidden;
    border-bottom: 1px solid var(--border);
    background:
      radial-gradient(120% 120% at 18% 10%, color-mix(in srgb, var(--a), transparent 82%), transparent 60%),
      var(--bg-2);
    display: flex; align-items: center; justify-content: center;
  }
  .proj__laptop { position: relative; width: 70%; }
  .proj__screen {
    position: relative; aspect-ratio: 16 / 10; border-radius: 10px 10px 0 0;
    border: 1px solid var(--border); border-bottom: 0;
    background:
      radial-gradient(120% 140% at 12% 0%, color-mix(in srgb, var(--a), transparent 70%), transparent 58%),
      var(--bg-base);
    display: flex; align-items: center; justify-content: center; overflow: hidden;
  }
  .proj__screen :global(img) { width: 100%; height: 100%; object-fit: cover; }
  .proj__wm {
    font-family: var(--font-display); font-weight: 700; font-size: clamp(18px, 4vw, 30px); line-height: 1;
    color: color-mix(in srgb, var(--a), transparent 45%); letter-spacing: -0.02em; text-align: center;
    padding: var(--space-3); max-width: 100%; overflow-wrap: anywhere;
  }
  .proj__base { height: 10px; border-radius: 0 0 7px 7px; background: var(--bg-elevated); border: 1px solid var(--border); }
  .proj__phone {
    position: absolute; right: 12%; bottom: 10%; width: 16%; aspect-ratio: 1 / 2;
    border-radius: 9px; border: 1px solid var(--border); background: var(--bg-elevated); padding: 3px;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.5);
  }
  .proj__pscreen {
    width: 100%; height: 100%; border-radius: 6px;
    background:
      radial-gradient(120% 80% at 50% 0%, color-mix(in srgb, var(--a), transparent 72%), transparent 60%),
      var(--bg-base);
  }

  /* ── info ──────────────────────────────────────────────── */
  .proj__info { display: flex; flex-direction: column; gap: var(--space-2); padding: var(--space-5); flex: 1; }
  .proj__badge {
    align-self: flex-start; font-family: var(--font-mono); font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--a);
    background: color-mix(in srgb, var(--a), transparent 88%); border: 1px solid color-mix(in srgb, var(--a), transparent 70%);
    border-radius: var(--radius-pill); padding: var(--space-1) var(--space-3); margin-bottom: var(--space-1);
  }
  .proj__name { font-family: var(--font-display); font-size: var(--text-lg); font-weight: 600; }
  .proj__cat { font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--fg-secondary); }
  .proj__result { color: var(--fg-secondary); font-size: var(--text-sm); line-height: var(--leading-normal); flex: 1; margin-top: var(--space-1); }
  .proj__tags { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-top: var(--space-2); }
  .proj__tag {
    font-size: var(--text-xs); color: var(--fg-secondary);
    background: var(--bg-elevated); border: 1px solid var(--border); border-radius: var(--radius-pill);
    padding: var(--space-1) var(--space-3);
  }
  .proj__url { display: inline-flex; align-items: center; gap: var(--space-2); margin-top: var(--space-3); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--fg-subtle); }
  .proj__url :global(svg) { width: 14px; height: 14px; }

  @media (--md) {
    .projects__head { flex-direction: row; align-items: flex-end; justify-content: space-between; }
    .projects__grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
