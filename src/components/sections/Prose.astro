---
// Bloque de texto editorial (p.ej. "por qué en esta ciudad" / contexto local).
// Párrafos legibles, ancho de lectura controlado. Acepta <em> en los párrafos.
import Kicker from '../ui/Kicker.astro';

interface Props {
  tag?: string;
  title: string;
  /** Párrafos en HTML (permiten <em>/<strong>). */
  paragraphs: string[];
  tone?: 'gold' | 'teal';
}
const { tag, title, paragraphs, tone = 'gold' } = Astro.props;
---
<section class:list={['section prose', `prose--${tone}`]}>
  <div class="container prose__inner">
    {tag && <Kicker tone={tone}>{tag}</Kicker>}
    <h2 class="h2" set:html={title} />
    <div class="prose__body">
      {paragraphs.map((p) => <p set:html={p} />)}
    </div>
  </div>
</section>

<style>
  .prose :global(.h2 em), .prose :global(.prose__body em) { font-style: normal; }
  .prose--gold :global(em) { color: var(--accent-gold); }
  .prose--teal :global(em) { color: var(--accent-teal); }

  .prose__inner { display: flex; flex-direction: column; gap: var(--space-4); }
  .prose__body { display: flex; flex-direction: column; gap: var(--space-4); margin-top: var(--space-2); max-width: 70ch; }
  .prose__body p { color: var(--fg-secondary); font-size: var(--text-md); line-height: var(--leading-loose); }
  .prose__body :global(strong) { color: var(--fg-primary); font-weight: 600; }
</style>
