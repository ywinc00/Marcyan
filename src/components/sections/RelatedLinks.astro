---
// Enlaces relacionados (cluster ↔ cluster). Tarjetas-enlace internas que tejen
// el clúster de servicio+ciudad (clave SEO de arquitectura de enlazado).
import Icon from '../ui/Icon.astro';
import Card from '../ui/Card.astro';
import Kicker from '../ui/Kicker.astro';

interface LinkItem { label: string; href: string; desc: string; icon?: string }
interface Props {
  tag: string;
  title: string;
  links: LinkItem[];
}
const { tag, title, links } = Astro.props;
---
<section class="section related">
  <div class="container">
    <header class="related__head">
      <Kicker>{tag}</Kicker>
      <h2 class="h3" set:html={title} />
    </header>
    <div class="related__grid">
      {links.map((l) => (
        <Card href={l.href} class="related__item">
          <span class="related__icon"><Icon name={l.icon ?? 'lucide:link'} /></span>
          <div class="related__body">
            <h3 class="related__title">{l.label}</h3>
            <p class="related__desc">{l.desc}</p>
          </div>
          <Icon name="lucide:arrow-right" class="related__go" />
        </Card>
      ))}
    </div>
  </div>
</section>

<style>
  .related__head { display: flex; flex-direction: column; gap: var(--space-3); margin-bottom: var(--space-6); }
  .related__grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }

  .related__item { display: flex; align-items: center; gap: var(--space-4); }
  .related__icon {
    flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center;
    width: 44px; height: 44px; border-radius: var(--radius-md);
    background: var(--accent-gold-dim); border: 1px solid var(--accent-gold-line); color: var(--accent-gold);
  }
  .related__icon :global(svg) { width: 20px; height: 20px; stroke-width: 1.5; }
  .related__body { min-width: 0; flex: 1; }
  .related__title { font-family: var(--font-display); font-size: var(--text-md); font-weight: 600; }
  .related__desc { color: var(--fg-secondary); font-size: var(--text-sm); margin-top: 2px; }
  .related__go { flex: 0 0 auto; width: 18px; height: 18px; color: var(--fg-subtle); transition: transform var(--duration-base), color var(--duration-base); }
  .related__item:hover .related__go { color: var(--accent-gold); transform: translateX(3px); }
  @media (--motion-reduce) { .related__item:hover .related__go { transform: none; } }

  @media (--md) { .related__grid { grid-template-columns: repeat(3, 1fr); gap: var(--space-5); } }
</style>
