---
// Sección Servicios — Variante C "Destacado + compactas".
// 1 servicio ESTRELLA destacado (badge + icono + título + desc + Explorar→ + precio)
// + lista vertical de servicios compactos (icono + título + precio + flecha).
// Dirige la atención y muestra precios (citable para AEO). Equal-height + alineado.
import Icon from '../ui/Icon.astro';
import Kicker from '../ui/Kicker.astro';
import Button from '../ui/Button.astro';

interface Props { services: any }
const { services } = Astro.props;
const [featured, ...rest] = services.items;
---
<section class="section services" id="servicios" data-fx="gold">
  <div class="container">
    <header class="services__head">
      <div class="services__intro">
        <Kicker>{services.tag}</Kicker>
        <h2 class="h2" set:html={services.title} />
        {services.note && <p class="services__note">{services.note}</p>}
      </div>
      <Button href={services.cta.href} variant="secondary" class="services__head-cta">{services.cta.label}</Button>
    </header>

    <div class="svc-c">
      <a class="svc-hero" href={featured.href}>
        {services.featuredBadge && <span class="svc-hero__badge">{services.featuredBadge}</span>}
        <Icon name={featured.icon} class="svc-hero__icon" />
        <h3 class="svc-hero__title">{featured.title}</h3>
        <p class="svc-hero__desc">{featured.desc}</p>
        <div class="svc-hero__foot">
          <span class="svc-hero__explore">{services.explore} <Icon name="lucide:arrow-right" /></span>
          <span class="svc-hero__price">{featured.price}</span>
        </div>
      </a>

      <ul class="svc-list">
        {rest.map((s: any) => (
          <li>
            <a class="svc-item" href={s.href} data-accent={s.icon?.includes('message') ? 'teal' : 'gold'}>
              <span class="svc-item__ic"><Icon name={s.icon} /></span>
              <span class="svc-item__tx">
                <span class="svc-item__title">{s.title}</span>
                <span class="svc-item__price">{s.price}</span>
              </span>
              <span class="svc-item__arr"><Icon name="lucide:arrow-up-right" /></span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .services__head { display: flex; flex-direction: column; gap: var(--space-5); align-items: flex-start; margin-bottom: var(--space-7); }
  .services__intro { display: flex; flex-direction: column; gap: var(--space-4); }
  .services__intro :global(.h2) :global(em) { color: var(--accent-gold); font-style: normal; }
  .services__note {
    display: inline-flex; align-items: center; gap: var(--space-2);
    font-family: var(--font-mono); font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide); color: var(--accent-teal); max-width: 56ch;
  }

  .svc-c { display: grid; grid-template-columns: 1fr; gap: var(--space-4); align-items: stretch; }

  /* Servicio estrella */
  .svc-hero {
    color: inherit; text-decoration: none;
    display: flex; flex-direction: column; gap: var(--space-3);
    background:
      radial-gradient(120% 120% at 0% 0%, var(--accent-gold-dim), transparent 55%),
      var(--bg-card);
    border: 1px solid var(--accent-gold-line); border-radius: var(--radius-lg);
    padding: var(--space-6); box-shadow: var(--shadow-card);
  }
  .svc-hero__badge {
    align-self: flex-start; font-family: var(--font-mono); font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--accent-gold);
    background: var(--accent-gold-dim); border: 1px solid var(--accent-gold-line);
    border-radius: var(--radius-pill); padding: var(--space-1) var(--space-3);
  }
  .svc-hero__icon { width: 34px; height: 34px; color: var(--accent-gold); stroke-width: 1.5; margin-top: var(--space-2); }
  .svc-hero__title { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 600; line-height: var(--leading-snug); }
  .svc-hero__desc { color: var(--fg-secondary); font-size: var(--text-base); line-height: var(--leading-normal); flex: 1; }
  .svc-hero__foot { display: flex; align-items: center; justify-content: space-between; gap: var(--space-3); margin-top: var(--space-3); padding-top: var(--space-4); border-top: 1px solid var(--border); }
  .svc-hero__explore { display: inline-flex; align-items: center; gap: var(--space-2); font-size: var(--text-sm); font-weight: 600; color: var(--accent-gold); }
  .svc-hero__explore :global(svg) { width: 16px; height: 16px; transition: transform var(--duration-base) var(--ease-out-expo); }
  .svc-hero:hover .svc-hero__explore :global(svg) { transform: translateX(4px); }
  .svc-hero__price { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--fg-secondary); }

  /* Lista compacta */
  .svc-list { list-style: none; display: flex; flex-direction: column; gap: var(--space-2); }
  .svc-list li { min-width: 0; }
  .svc-item {
    color: inherit; text-decoration: none;
    display: flex; align-items: center; gap: var(--space-4);
    background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg);
    padding: var(--space-4) var(--space-5); min-height: 64px;
    transition: border-color var(--duration-base) var(--ease-out-expo);
  }
  .svc-item:hover { border-color: var(--border-accent); }
  .svc-item__ic { display: inline-flex; flex: 0 0 auto; }
  .svc-item__ic :global(svg) { width: 22px; height: 22px; color: var(--fg-secondary); stroke-width: 1.5; transition: color var(--duration-base); }
  .svc-item:hover .svc-item__ic :global(svg) { color: var(--accent-gold); }
  .svc-item__tx { display: flex; flex-direction: column; gap: 2px; flex: 1; min-width: 0; }
  .svc-item__title { font-family: var(--font-display); font-size: var(--text-md); font-weight: 600; }
  .svc-item__price { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--fg-secondary); }
  .svc-item__arr { display: inline-flex; flex: 0 0 auto; color: var(--fg-subtle); transition: color var(--duration-base); }
  .svc-item__arr :global(svg) { width: 16px; height: 16px; }
  .svc-item:hover .svc-item__arr { color: var(--accent-gold); }
  /* item de IA = señal teal (icono teal + hover teal en vez de oro) */
  .svc-item[data-accent="teal"] .svc-item__ic :global(svg) { color: var(--accent-teal); }
  .svc-item[data-accent="teal"]:hover { border-color: var(--accent-teal-line); }
  .svc-item[data-accent="teal"]:hover .svc-item__arr { color: var(--accent-teal); }

  @media (--lg) {
    .services__head { flex-direction: row; align-items: flex-end; justify-content: space-between; }
    .svc-c { grid-template-columns: 1.05fr 0.95fr; gap: var(--space-5); }
    .svc-hero { padding: var(--space-7); }
    /* la pila se reparte para cuadrar su alto con el del servicio destacado */
    .svc-list { justify-content: space-between; }
  }
</style>
