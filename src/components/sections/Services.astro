---
// Sección Servicios — 6 servicios reales con precio "desde $". Cards mobile-first
// (1→2→3 col) con hover borde→oro. Icono Lucide por servicio.
import { Icon } from 'astro-icon/components';
import Card from '../ui/Card.astro';
import Kicker from '../ui/Kicker.astro';
import Button from '../ui/Button.astro';

interface Props { services: any }
const { services } = Astro.props;
---
<section class="section services" id="servicios">
  <div class="container">
    <header class="services__head">
      <div class="services__intro">
        <Kicker>{services.tag}</Kicker>
        <h2 class="h2" set:html={services.title} />
      </div>
      <Button href={services.cta.href} variant="secondary" class="services__head-cta">{services.cta.label}</Button>
    </header>

    <div class="services__grid">
      {services.items.map((s: any) => (
        <Card class="svc">
          <div class="svc__top">
            <span class="svc__num">{s.n}</span>
            <Icon name={s.icon} class="svc__icon" />
          </div>
          <h3 class="svc__title">{s.title}</h3>
          <p class="svc__desc">{s.desc}</p>
          <div class="svc__foot">
            <span class="svc__price">{s.price}</span>
            <span class="svc__explore">{services.explore} <Icon name="lucide:arrow-up-right" /></span>
          </div>
        </Card>
      ))}
    </div>
  </div>
</section>

<style>
  .services__head {
    display: flex; flex-direction: column; gap: var(--space-5);
    align-items: flex-start; margin-bottom: var(--space-7);
  }
  .services__intro { display: flex; flex-direction: column; gap: var(--space-4); }
  .services__intro :global(.h2) :global(em) { color: var(--accent-gold); font-style: normal; }

  .services__grid {
    display: grid; grid-template-columns: 1fr; gap: var(--space-4);
  }

  .svc { display: flex; flex-direction: column; gap: var(--space-3); height: 100%; }
  .svc__top { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-1); }
  .svc__num { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--accent-gold); letter-spacing: var(--tracking-wide); }
  .svc__icon { width: 26px; height: 26px; color: var(--fg-secondary); stroke-width: 1.5; transition: color var(--duration-base); }
  .svc:hover .svc__icon { color: var(--accent-gold); }
  .svc__title { font-family: var(--font-display); font-size: var(--text-xl); font-weight: 600; line-height: var(--leading-snug); }
  .svc__desc { color: var(--fg-secondary); font-size: var(--text-sm); line-height: var(--leading-normal); flex: 1; }
  .svc__foot {
    display: flex; align-items: center; justify-content: space-between; gap: var(--space-3);
    margin-top: var(--space-3); padding-top: var(--space-4); border-top: 1px solid var(--border-subtle);
  }
  .svc__price { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--accent-gold); }
  .svc__explore { display: inline-flex; align-items: center; gap: var(--space-1); font-size: var(--text-xs); color: var(--accent-teal); text-transform: uppercase; letter-spacing: var(--tracking-wide); }
  .svc__explore :global(svg) { width: 14px; height: 14px; }

  @media (--sm) { .services__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (--lg) {
    .services__grid { grid-template-columns: repeat(3, 1fr); gap: var(--space-5); }
    .services__head { flex-direction: row; align-items: flex-end; justify-content: space-between; }
  }
</style>
