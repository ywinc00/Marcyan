---
// Badge / pill — etiqueta de acento. gold (por defecto) o teal (IA/señal).
interface Props { variant?: 'gold' | 'teal'; class?: string }
const { variant = 'gold', class: cls } = Astro.props;
---
<span class:list={['badge', `badge--${variant}`, cls]}><slot /></span>

<style>
  .badge {
    display: inline-flex; align-items: center; gap: var(--space-2);
    padding: 7px 14px; border-radius: var(--radius-pill);
    font-family: var(--font-body); font-size: var(--text-sm); font-weight: 600;
    line-height: 1; white-space: nowrap; max-width: 100%;
  }
  .badge--gold { background: var(--accent-gold-dim); border: 1px solid var(--accent-gold-line); color: var(--accent-gold); }
  .badge--teal { background: var(--accent-teal-dim); border: 1px solid var(--accent-teal-line); color: var(--accent-teal); }
</style>
