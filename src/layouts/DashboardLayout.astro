---
// ─────────────────────────────────────────────────────────────
// Layout del PANEL (/dashboard). Aislado del Layout público:
//   · noindex (zona privada), sin nav/footer/ChatWidget del sitio.
//   · carga fuentes auto-hospedadas + tokens del Design System.
//   · fondo dark; la app interactiva vive en una isla Svelte.
// ─────────────────────────────────────────────────────────────
import '@fontsource-variable/space-grotesk/index.css';
import '@fontsource-variable/dm-sans/index.css';
import '@fontsource-variable/jetbrains-mono/index.css';
import '../styles/tokens.css';

interface Props { title?: string }
const { title = 'Marcyan · Panel' } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#080808" />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ccircle cx='16' cy='16' r='9' fill='%23c8a96e'/%3E%3Cellipse cx='16' cy='16' rx='15' ry='4.5' fill='none' stroke='%23c8a96e' stroke-width='1.4'/%3E%3Ccircle cx='30' cy='13' r='2' fill='%234fc3a1'/%3E%3C/svg%3E"
    />
    <link rel="manifest" href="/dashboard/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/dashboard/icon.svg" />
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function () {
          navigator.serviceWorker.register('/dashboard/sw.js', { scope: '/dashboard' }).catch(function () {});
        });
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    background: var(--bg-base);
    color: var(--fg-primary);
    font-family: var(--font-body);
    font-weight: 400;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
  button, input, select, textarea { font-family: inherit; }
  a { color: inherit; }
</style>
