---
// ─────────────────────────────────────────────────────────────
// Layout base de Marcyan — design system v2 "Space-Tech".
// Auto-hospeda las 3 fuentes (Fontsource, sin Google CDN), carga los
// tokens/reset globales y arma <head> SEO/i18n (hreflang es/en/x-default).
// Todas las páginas del sitio nuevo deben extender de aquí.
// ─────────────────────────────────────────────────────────────
import '@fontsource-variable/space-grotesk/index.css';
import '@fontsource-variable/dm-sans/index.css';
import '@fontsource-variable/jetbrains-mono/index.css';
import '../styles/global.css';
import { nap } from '../i18n/content';

interface Props {
  title: string;
  description?: string;
  lang?: 'es' | 'en';
  /** Ruta SIN prefijo de idioma, p.ej. "/" o "/servicios". Construye canonical + hreflang. */
  path?: string;
  canonical?: string;
  noindex?: boolean;
  ogImage?: string;
  /** Si la página tiene espejo en el otro idioma. false → no emitir hreflang en
   *  (las landings de cluster son solo-ES hasta la Ola 3; apuntar a /en/ daría 404). */
  hasEn?: boolean;
}

const SITE = 'https://marcyanstudio.com';
const {
  title,
  description = 'Marcyan Studio — diseño web, IA y SEO para PYMEs en Houston y Miami.',
  lang = 'es',
  path = '/',
  canonical,
  noindex = false,
  ogImage = '/assets/og/og-default.png',
  hasEn = true,
} = Astro.props;

const clean = path === '/' ? '' : `/${path.replace(/^\/+|\/+$/g, '')}`;
const canon = canonical ?? `${SITE}/${lang}${clean}/`;
// Páginas SIN prefijo de idioma (legales, formulario) pasan `canonical` explícito:
// el hreflang es/x-default debe apuntar a ESA URL, no a la auto /es/{path}/ (sería 404).
const esHref = canonical ?? `${SITE}/es${clean}/`;
const enHref = `${SITE}/en${clean}/`;
const ogLocale = lang === 'es' ? 'es_US' : 'en_US';

// JSON-LD @graph (Organization + LocalBusiness por ciudad) — server-rendered,
// restaura el structured data del Sprint 0. NAP desde i18n/content (DRY).
const tel = (p: string) => p.replace(/[^\d+]/g, '');
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SITE}/#organization`,
      name: 'Marcyan Studio',
      url: `${SITE}/`,
      email: nap.email,
      description:
        'Agencia de diseño web, inteligencia artificial aplicada y SEO para pequeñas y medianas empresas en Houston y Miami. Atención bilingüe español e inglés.',
      slogan: 'Diseño web que piensa por ti',
      knowsLanguage: ['es', 'en'],
      areaServed: [
        { '@type': 'City', name: 'Houston' },
        { '@type': 'City', name: 'Miami' },
      ],
    },
    {
      '@type': 'ProfessionalService',
      '@id': `${SITE}/#houston`,
      name: 'Marcyan Studio',
      parentOrganization: { '@id': `${SITE}/#organization` },
      url: `${SITE}/`,
      telephone: tel(nap.houston),
      email: nap.email,
      priceRange: '$$',
      knowsLanguage: ['es', 'en'],
      address: { '@type': 'PostalAddress', addressLocality: 'Houston', addressRegion: 'TX', addressCountry: 'US' },
      areaServed: { '@type': 'City', name: 'Houston' },
    },
    {
      '@type': 'ProfessionalService',
      '@id': `${SITE}/#miami`,
      name: 'Marcyan Studio',
      parentOrganization: { '@id': `${SITE}/#organization` },
      url: `${SITE}/`,
      telephone: tel(nap.miami),
      email: nap.email,
      priceRange: '$$',
      knowsLanguage: ['es', 'en'],
      address: { '@type': 'PostalAddress', addressLocality: 'Miami', addressRegion: 'FL', addressCountry: 'US' },
      areaServed: { '@type': 'City', name: 'Miami' },
    },
  ],
};
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canon} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="alternate" hreflang="es" href={esHref} />
    {hasEn && <link rel="alternate" hreflang="en" href={enHref} />}
    <link rel="alternate" hreflang="x-default" href={esHref} />

    <meta name="theme-color" content="#080808" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Marcyan Studio" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canon} />
    <meta property="og:image" content={`${SITE}${ogImage}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale} />
    {hasEn && <meta property="og:locale:alternate" content={lang === 'es' ? 'en_US' : 'es_US'} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={`${SITE}${ogImage}`} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

    {/* Favicon planeta (placeholder en línea; el mark real llega en Fase B) */}
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ccircle cx='16' cy='16' r='9' fill='%23c8a96e'/%3E%3Cellipse cx='16' cy='16' rx='15' ry='4.5' fill='none' stroke='%23c8a96e' stroke-width='1.4'/%3E%3Ccircle cx='30' cy='13' r='2' fill='%234fc3a1'/%3E%3C/svg%3E"
    />

    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">{lang === 'es' ? 'Saltar al contenido' : 'Skip to content'}</a>
    <slot />
  </body>
</html>
