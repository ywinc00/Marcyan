---
// HOME · /en/ — mismo design system y componentes que /es/, contenido en inglés.
// El toggle ES/EN es un <a href> real entre URLs (sin swap JS).
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/layout/SiteNav.astro';
import SiteFooter from '../../components/layout/SiteFooter.astro';
import Hero from '../../components/sections/Hero.astro';
import Services from '../../components/sections/Services.astro';
import AiSection from '../../components/sections/AiSection.astro';
import Process from '../../components/sections/Process.astro';
import Projects from '../../components/sections/Projects.astro';
import Guarantees from '../../components/sections/Guarantees.astro';
import Locations from '../../components/sections/Locations.astro';
import Contact from '../../components/sections/Contact.astro';
import { content } from '../../i18n/content';

const c = content.en;
---
<Layout
  title="Marcyan Studio — AI Web Design · Houston & Miami"
  description="Premium web design, conversational AI, and SEO for small businesses in Houston and Miami. Personalized proposal in under 24 hours, no commitment."
  lang="en"
  path="/"
>
  <SiteNav nav={c.nav} lang="en" homeHref="/en/" />
  <main id="main">
    <Hero hero={c.hero} />
    <Services services={c.services} />
    <AiSection ai={c.ai} />
    <Process process={c.process} />
    <Projects projects={c.projects} />
    <Guarantees guarantees={c.guarantees} />
    <Locations locations={c.locations} />
    <Contact contact={c.contact} />
  </main>
  <SiteFooter footer={c.footer} />
</Layout>
