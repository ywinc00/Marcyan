<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Marcyan Studio — AI Web Design · Houston & Miami</title>
  <meta name="description" content="Marcyan Studio: web design, AI, and SEO for small businesses in Houston and Miami. We're rebuilding our site — tell us about your project." />
  <link rel="canonical" href="https://marcyanstudio.com/en/" />
  <link rel="alternate" hreflang="es" href="https://marcyanstudio.com/es/" />
  <link rel="alternate" hreflang="en" href="https://marcyanstudio.com/en/" />
  <link rel="alternate" hreflang="x-default" href="https://marcyanstudio.com/es/" />
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%23080808'/%3E%3Ctext x='16' y='24' font-family='Georgia,serif' font-size='22' fill='%23c8a96e' text-anchor='middle'%3EM%3C/text%3E%3C/svg%3E" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400&family=DM+Sans:wght@300;400&family=Space+Mono&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/assets/css/variables.css" />
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:28px;
      background:var(--black,#080808);color:var(--white,#f0ede8);font-family:var(--font-body,'DM Sans',sans-serif);font-weight:300;text-align:center;padding:32px;-webkit-font-smoothing:antialiased}
    .tag{font-family:var(--font-mono,'Space Mono',monospace);font-size:12px;letter-spacing:4px;text-transform:uppercase;color:var(--accent,#c8a96e)}
    .logo{font-family:var(--font-display,'Cormorant Garamond',serif);font-size:clamp(56px,10vw,104px);font-weight:300;line-height:1;letter-spacing:1px}
    .logo span{color:var(--accent,#c8a96e)}
    .msg{color:var(--muted,rgba(240,237,232,.55));max-width:46ch;line-height:1.8;font-size:16px}
    .links{display:flex;flex-wrap:wrap;gap:24px;font-family:var(--font-mono,'Space Mono',monospace);font-size:12px;letter-spacing:2px;text-transform:uppercase}
    .links a{color:var(--accent2,#4fc3a1);text-decoration:none;border-bottom:1px solid transparent;transition:border-color .3s}
    .links a:hover{border-bottom-color:var(--accent2,#4fc3a1)}
  </style>
</head>
<body>
  <div class="tag">Houston · Miami</div>
  <div class="logo">Mar<span>c</span>yan</div>
  <p class="msg">We're rebuilding our site. In the meantime, tell us about your project and we'll send a proposal in under 24 hours.</p>
  <nav class="links">
    <a href="/formulario">Start a project</a>
    <a href="/es/">Español</a>
    <a href="mailto:contact@marcyanstudio.com">contact@marcyanstudio.com</a>
  </nav>
</body>
</html>
