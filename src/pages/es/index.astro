---
// HOME · /es/ — re-vestida con el design system v2.
// Secciones: Nav · Hero · Servicios · IA · Proceso · Proyectos · Garantías ·
// Ubicaciones · Contacto (form → /api/brief) · Footer.
// Pendiente: motor planetario animado del hero (Fase D) + espejo /en/.
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/layout/SiteNav.astro';
import SiteFooter from '../../components/layout/SiteFooter.astro';
import Hero from '../../components/sections/Hero.astro';
import Services from '../../components/sections/Services.astro';
import AiSection from '../../components/sections/AiSection.astro';
import Process from '../../components/sections/Process.astro';
import Projects from '../../components/sections/Projects.astro';
import Guarantees from '../../components/sections/Guarantees.astro';
import Locations from '../../components/sections/Locations.astro';
import Contact from '../../components/sections/Contact.astro';
import StarField from '../../components/StarField.astro';
import OfferCatalogLd from '../../components/seo/OfferCatalogLd.astro';
import { content } from '../../i18n/content';
import { offerItems } from '../../i18n/pricing';

const c = content.es;
---
<Layout
  title="Marcyan Studio — Diseño web con IA · Houston & Miami"
  description="Diseño web premium, IA conversacional y SEO para PYMEs en Houston y Miami. Propuesta personalizada en menos de 24 horas, sin compromiso."
  lang="es"
  path="/"
>
  {/* OfferCatalog con los 6 servicios + precio (Offer/priceSpecification) — munición AEO. */}
  <OfferCatalogLd slot="head" items={offerItems} url="/es/precios" />

  <SiteNav nav={c.nav} lang="es" homeHref="/es/" />
  <main id="main">
    <Hero hero={c.hero} />
    <Services services={c.services} />
    <AiSection ai={c.ai} />
    <Process process={c.process} />
    <Projects projects={c.projects} />
    <Guarantees guarantees={c.guarantees} />
    <Locations locations={c.locations} />
    <Contact contact={c.contact} />
    <StarField />
  </main>
  <SiteFooter footer={c.footer} />
</Layout>
