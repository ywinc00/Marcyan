---
// HUB DE CIUDAD · /es/miami — nodo del silo geográfico (Ola 2 · B3).
// Presenta Miami + enlaza a los servicios ×Miami. Reusa los componentes del DS
// (patrón /es/houston). Schema: ItemList de los servicios + BreadcrumbList. El
// @graph base ya da la ProfessionalService de Miami. ES por ahora (hasEn=false).
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/layout/SiteNav.astro';
import SiteFooter from '../../components/layout/SiteFooter.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import LandingHero from '../../components/sections/LandingHero.astro';
import AnswerBlock from '../../components/sections/AnswerBlock.astro';
import RelatedLinks from '../../components/sections/RelatedLinks.astro';
import Prose from '../../components/sections/Prose.astro';
import Faq from '../../components/sections/Faq.astro';
import CtaBand from '../../components/sections/CtaBand.astro';
import Contact from '../../components/sections/Contact.astro';
import ItemListLd from '../../components/seo/ItemListLd.astro';
import { content } from '../../i18n/content';
import { clusterNav } from '../../i18n/clusters';
import { miamiHub as h } from '../../i18n/miami';

const c = content.es;
---
<Layout
  title={h.meta.title}
  description={h.meta.description}
  lang="es"
  path="miami"
  hasEn={false}
>
  <ItemListLd slot="head" items={h.itemList} name="Servicios de Marcyan en Miami" />

  <SiteNav nav={clusterNav} lang="es" homeHref="/es/" hasEn={false} currentPath={Astro.url.pathname} />

  <main id="main">
    <LandingHero
      badge={h.hero.badge}
      badgeIcon={h.hero.badgeIcon}
      kicker={h.hero.kicker}
      h1={h.hero.h1}
      sub={h.hero.sub}
      primary={h.hero.primary}
      secondary={h.hero.secondary}
      chips={h.hero.chips}
      tone={h.hero.tone}
    >
      <Breadcrumb slot="breadcrumb" items={h.breadcrumb} lang="es" />
    </LandingHero>

    <AnswerBlock q={h.answer.q} a={h.answer.a} source={h.answer.source} />

    <RelatedLinks tag={h.services.tag} title={h.services.title} links={h.services.links} />

    <RelatedLinks tag={h.barrios.tag} title={h.barrios.title} links={h.barrios.links} />

    <Prose
      tag={h.local.tag}
      title={h.local.title}
      paragraphs={h.local.paragraphs}
      tone={h.local.tone}
    />

    <RelatedLinks tag={h.related.tag} title={h.related.title} links={h.related.links} />

    <Faq tag={h.faq.tag} title={h.faq.title} items={h.faq.items} />

    <CtaBand
      title={h.cta.title}
      sub={h.cta.sub}
      primary={h.cta.primary}
      secondary={h.cta.secondary}
      tone={h.cta.tone}
    />

    <Contact contact={c.contact} defaultCity="Miami, FL" />
  </main>

  <SiteFooter footer={c.footer} />
</Layout>
